# Dependencies
node_modules/
.pnp
.pnp.js

# Build outputs
dist/
build/
.next/
.astro/
out/
*.tsbuildinfo

# Environment files — never commit real secrets
.env
.env.local
.env.*.local
# Allow only the example template
!.env.example

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# OS artifacts
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Editors
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json
.idea/
*.swp
*.swo

# Turbo cache
.turbo/

# Testing
coverage/
playwright-report/
test-results/
blob-report/

# Generated artifacts (rebuilt by tools)
packages/komercia-client/src/generated/
docs/api-discovery-report.md

# Changesets
.changeset/*.md
!.changeset/config.json
!.changeset/README.md
.vercel

# Local brand-asset originals (favicon source JPEGs, logo SVG sources, etc).
# The processed/optimized copies that actually ship live in apps/web/public/.
images/

# One-off local scripts not part of the build (debug probes, manual
# validators, etc). Run from the repo root via `node scripts/...`.
scripts/debug-*.mjs
scripts/validate-*.mjs
