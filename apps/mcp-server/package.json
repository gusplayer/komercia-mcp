{
  "name": "@komercia-mcp/mcp-server",
  "version": "0.1.0",
  "description": "NestJS MCP server — exposes Komercia store data as Model Context Protocol tools for Claude",
  "license": "MIT",
  "author": "Gustavo Moreno (https://github.com/gusplayer)",
  "homepage": "https://github.com/gusplayer/komercia-mcp/tree/main/apps/mcp-server#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gusplayer/komercia-mcp.git",
    "directory": "apps/mcp-server"
  },
  "bugs": "https://github.com/gusplayer/komercia-mcp/issues",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -b",
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@komercia-mcp/komercia-client": "workspace:*",
    "@komercia-mcp/shared": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@nestjs/common": "^10.4.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/platform-express": "^10.4.0",
    "@nestjs/throttler": "^6.2.0",
    "nestjs-pino": "^4.1.0",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "postgres": "^3.4.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@komercia-mcp/eslint-config": "workspace:*",
    "@nestjs/cli": "^10.4.0",
    "@nestjs/schematics": "^10.2.0",
    "@nestjs/testing": "^10.4.0",
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^2.1.0",
    "eslint": "^9.14.0",
    "pino-pretty": "^11.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  }
}
