{
  "name": "@komercia-mcp/discovery",
  "version": "0.1.0",
  "description": "CLI tool that maps Komercia's API surface and generates typed client stubs",
  "license": "MIT",
  "author": "Gustavo Moreno (https://github.com/gusplayer)",
  "homepage": "https://github.com/gusplayer/komercia-mcp/tree/main/apps/discovery#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gusplayer/komercia-mcp.git",
    "directory": "apps/discovery"
  },
  "bugs": "https://github.com/gusplayer/komercia-mcp/issues",
  "private": true,
  "type": "module",
  "bin": {
    "komercia-discover": "./dist/bin/discover.js"
  },
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --build --watch",
    "discover": "node dist/bin/discover.js",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@komercia-mcp/shared": "workspace:*",
    "quicktype-core": "^23.0.0",
    "undici": "^7.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@komercia-mcp/eslint-config": "workspace:*",
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^4.1.6",
    "eslint": "^10.3.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
