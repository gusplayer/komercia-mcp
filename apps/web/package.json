{
  "name": "@komercia-mcp/web",
  "version": "0.1.0",
  "description": "Astro web app — landing page, sign-in flow and token issuer for Komercia MCP",
  "license": "MIT",
  "author": "Gustavo Moreno (https://github.com/gusplayer)",
  "homepage": "https://mcp.komercia.co",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gusplayer/komercia-mcp.git",
    "directory": "apps/web"
  },
  "bugs": "https://github.com/gusplayer/komercia-mcp/issues",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node scripts/generate-og.mjs && astro build",
    "dev": "node --env-file=../../.env node_modules/astro/astro.js dev --port 4321",
    "preview": "astro preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "lint": "eslint src",
    "typecheck": "astro check && tsc --noEmit",
    "clean": "rm -rf dist .astro tsconfig.tsbuildinfo",
    "og:generate": "node scripts/generate-og.mjs"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.4.2",
    "@astrojs/tailwind": "^5.1.0",
    "@astrojs/vercel": "^8.0.0",
    "@komercia-mcp/komercia-client": "workspace:*",
    "@komercia-mcp/shared": "workspace:*",
    "astro": "^5.0.0",
    "jose": "^5.9.0",
    "postgres": "^3.4.0",
    "resend": "^4.0.0",
    "tailwindcss": "^3.4.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@komercia-mcp/eslint-config": "workspace:*",
    "@playwright/test": "^1.48.0",
    "@resvg/resvg-js": "^2.6.2",
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^2.1.0",
    "eslint": "^9.14.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  }
}
