---
// 404.astro — Not found page, terminal aesthetic.
import Base from '../layouts/Base.astro';
---

<Base
  title="404 — komercia/mcp"
  description="Página no encontrada."
  noindex={true}
>
  <div class="page">
    <main class="main">
      <div class="terminal">
        <div class="prompt">
          <span class="muted">user@komercia ~$</span>
          <span class="cmd">cd {Astro.url.pathname}</span><span class="caret">_</span>
        </div>

        <p class="error-line">bash: no such file or directory · <span class="muted">404</span></p>

        <p class="hint">la ruta que buscas no existe. tal vez se movió o nunca existió.</p>

        <div class="actions">
          <a href="/" class="btn-pill">volver al inicio →</a>
          <a href="/sign-in" class="btn-ghost-pill">obtener_token</a>
        </div>
      </div>
    </main>
  </div>
</Base>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&display=swap');

  .page {
    --c-bg: #000000;
    --c-fg: #ffffff;
    --c-surface: #1d1d1d;
    --c-border: #383838;
    --c-muted: #888888;
    --r: 10px;

    min-height: 100vh;
    background: var(--c-bg);
    color: var(--c-fg);
    font-family: 'Space Mono', ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 16px;
    line-height: 1.4;
    letter-spacing: 0.24px;
    font-feature-settings: 'zero';
    display: flex;
    align-items: center;
    justify-content: center;
  }
  :global(body:has(.page)) { background: #000000; }

  .main { padding: 48px 24px; }
  .terminal { max-width: 640px; }

  .prompt { font-size: 16px; }
  .prompt .muted { color: var(--c-muted); }
  .prompt .cmd { color: var(--c-fg); margin-left: 8px; }
  .caret { margin-left: 2px; animation: blink 1s steps(1) infinite; }
  @keyframes blink { 50% { opacity: 0; } }

  .error-line { margin: 26px 0 8px; font-size: 16px; color: var(--c-fg); }
  .error-line .muted { color: var(--c-muted); }

  .hint { margin: 0 0 32px; font-size: 16px; color: var(--c-muted); line-height: 1.5; }

  .actions { display: flex; gap: 12px; flex-wrap: wrap; }

  .btn-pill, .btn-ghost-pill {
    height: 36px;
    box-sizing: border-box;
    display: inline-flex;
    align-items: center;
    border-radius: var(--r);
    font-family: inherit;
    letter-spacing: 0.24px;
    text-decoration: none;
    line-height: 1;
    padding: 0 16px;
    font-size: 14px;
    transition: background 150ms, border-color 150ms;
  }
  .btn-pill {
    background: var(--c-fg);
    color: var(--c-bg);
    border: 1px solid var(--c-fg);
  }
  .btn-pill:hover { background: var(--c-muted); border-color: var(--c-muted); }
  .btn-ghost-pill {
    background: transparent;
    color: var(--c-fg);
    border: 1px solid var(--c-border);
    padding: 0 12px;
  }
  .btn-ghost-pill:hover { border-color: var(--c-fg); background: var(--c-surface); }

  .muted { color: var(--c-muted); }
</style>
