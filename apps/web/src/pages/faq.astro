---
// faq.astro — Redirect page that bounces visitors to /#faq.
import Base from '../layouts/Base.astro';
import Container from '../components/Container.astro';
import Button from '../components/Button.astro';
---

<Base
  title="FAQ — Komercia MCP"
  description="Preguntas frecuentes sobre Komercia MCP."
>
  <main style="min-height: 100vh; display: flex; align-items: center; justify-content: center;">
    <Container size="narrow">
      <p
        style="text-align: center; font-family: var(--font-sans); font-size: 14px; color: var(--color-slate-text); margin-bottom: 16px;"
      >
        Redirigiendo a las preguntas frecuentes…
      </p>
      <div style="text-align: center;">
        <Button variant="primary" href="/#faq">Ir a FAQ</Button>
      </div>
    </Container>
  </main>
  <script>window.location.replace('/#faq');</script>
</Base>
