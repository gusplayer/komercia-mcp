---
import Base from '../layouts/Base.astro';

const rawEmail = Astro.url.searchParams.get('email') ?? '';

// Sanitize: only show the email if it looks like a valid email address (basic check)
// This prevents reflected XSS from the query param — Astro escapes in template,
// but we also constrain what's displayed.
const EMAIL_REGEX = /^[^\s@]{1,64}@[^\s@]{1,253}$/;
const displayEmail = EMAIL_REGEX.test(rawEmail) ? rawEmail : '';
---

<Base title="Check your email — Komercia Export">
  <main class="page-container text-center">
    <!-- Icon -->
    <div class="w-14 h-14 rounded-2xl bg-indigo-50 border border-indigo-100 flex items-center justify-center mx-auto mb-6">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#6366f1" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <rect width="20" height="16" x="2" y="4" rx="2"/>
        <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
      </svg>
    </div>

    <h1 class="text-2xl font-bold text-slate-900 mb-3">Check your email</h1>

    {displayEmail ? (
      <p class="text-slate-500 text-base mb-6">
        We sent a login link to{' '}
        <span class="inline-flex items-center px-2.5 py-0.5 rounded-md bg-slate-100 text-slate-700 font-mono text-sm font-medium">
          {displayEmail}
        </span>
        .
      </p>
    ) : (
      <p class="text-slate-500 text-base mb-6">
        If the email address you entered is associated with a store, you&rsquo;ll receive a link shortly.
      </p>
    )}

    <p class="text-sm text-slate-400 mb-10">
      The link expires in <strong class="text-slate-600">15 minutes</strong>.
      Check your spam folder if you don&rsquo;t see it.
    </p>

    <div class="card text-left space-y-3 text-sm text-slate-600">
      <p class="font-medium text-slate-700">What happens next?</p>
      <ol class="list-decimal list-inside space-y-2">
        <li>Click the link in the email to get your JWT token.</li>
        <li>Copy the token — it will only be shown once.</li>
        <li>Paste it into Claude.ai as the MCP auth token for the Komercia server.</li>
      </ol>
    </div>

    <p class="mt-8 text-xs text-slate-400">
      Didn&rsquo;t get it?{' '}
      <a href="/" class="underline hover:text-slate-600 transition-colors">Request a new link</a>
    </p>
  </main>
</Base>
