---
// sign-in-v2.astro — Terminal aesthetic auth + token issuance.
// Bilingual ES (default) / EN. Same backend flow as /sign-in.
import Base from '../layouts/Base.astro';
import { generateCsrfToken } from '../lib/csrf.js';

const csrfToken = generateCsrfToken();
Astro.cookies.set('csrf_token', csrfToken, {
  path: '/',
  sameSite: 'strict',
  httpOnly: false,
  secure: import.meta.env.PROD,
  maxAge: 3600,
});
---

<Base
  title="komercia/mcp — auth"
  description="Acceso al servidor MCP de Komercia. Variante terminal."
  noindex={true}
>
  <div class="page">
    <header class="topbar">
      <a href="/v2" class="brand" aria-label="komercia mcp home">[komercia/mcp]</a>

      <div class="topbar-actions">
        <button id="lang-toggle" class="btn-lang" aria-label="Cambiar idioma" title="Cambiar idioma / Toggle language">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="10"/>
            <path d="M2 12h20"/>
            <path d="M12 2a15 15 0 0 1 4 10 15 15 0 0 1-4 10 15 15 0 0 1-4-10 15 15 0 0 1 4-10z"/>
          </svg>
          <span id="lang-label">eng</span>
        </button>
        <a href="/v2" class="link-muted" data-t-es="← volver" data-t-en="← back">← volver</a>
      </div>
    </header>

    <main class="main">
      <div class="terminal">
        <div class="prompt">
          <span class="muted">user@komercia ~$</span>
          <span class="cmd" id="prompt-cmd">authenticate</span><span class="caret">_</span>
        </div>

        <div class="divider"></div>

        <!-- ── Login section ──────────────────────────────────── -->
        <section id="login-section">
          <h1 class="title" data-t-es="acceder a los datos de la tienda" data-t-en="access store data">acceder a los datos de la tienda</h1>
          <p class="subtitle" data-t-es="inicia sesión con tus credenciales de komercia para emitir un token mcp de solo lectura." data-t-en="log in with your komercia credentials to issue a read-only mcp token.">
            inicia sesión con tus credenciales de komercia para emitir un token mcp de solo lectura.
          </p>

          <form id="login-form" novalidate>
            <div class="field">
              <label for="email" data-t-es="&gt; correo" data-t-en="&gt; email">&gt; correo</label>
              <input
                id="email"
                name="email"
                type="email"
                autocomplete="email"
                required
                placeholder="you@email.com"
                spellcheck="false"
                autocapitalize="off"
              />
            </div>

            <div class="field">
              <label for="password" data-t-es="&gt; contraseña" data-t-en="&gt; password">&gt; contraseña</label>
              <input
                id="password"
                name="password"
                type="password"
                autocomplete="current-password"
                required
                placeholder="••••••••"
              />
            </div>

            <div id="form-error" class="alert hidden" role="alert" aria-live="polite"></div>

            <button type="submit" id="submit-btn" class="btn-primary">
              <span id="btn-label" data-t-es="autenticar →" data-t-en="authenticate →">autenticar →</span>
            </button>
          </form>

          <p class="footer-line">
            <span data-t-es="¿sin cuenta?" data-t-en="no account?">¿sin cuenta?</span>
            <a href="https://komercia.co" target="_blank" rel="noopener noreferrer" data-t-es="regístrate en komercia.co →" data-t-en="register at komercia.co →">regístrate en komercia.co →</a>
          </p>
        </section>

        <!-- ── Token section ──────────────────────────────────── -->
        <section id="token-section" class="hidden">
          <div class="status">
            <span class="ok">●</span> <span data-t-es="sesión_autenticada" data-t-en="session_authenticated">sesión_autenticada</span>
          </div>

          <div class="warn" data-t-es="! el token se muestra una sola vez. cópialo antes de salir." data-t-en="! token shown once. copy it before leaving this page.">
            ! el token se muestra una sola vez. cópialo antes de salir.
          </div>

          <div class="field">
            <label>
              <span data-t-es="&gt; token_jwt" data-t-en="&gt; jwt_token">&gt; token_jwt</span>
              <span class="badge" data-t-es="solo lectura · 6 meses" data-t-en="read-only · 6mo">solo lectura · 6 meses</span>
            </label>
            <div class="token-row">
              <code id="token-masked" class="token-display"></code>
              <button id="copy-btn" class="btn-copy" aria-label="copiar token">
                <span id="copy-label" data-t-es="[ copiar ]" data-t-en="[ copy ]">[ copiar ]</span>
                <span id="copy-success" class="hidden" data-t-es="[ ✓ copiado ]" data-t-en="[ ✓ copied ]">[ ✓ copiado ]</span>
              </button>
            </div>
          </div>

          <div class="divider divider-spaced"></div>

          <div class="prompt">
            <span class="muted">user@komercia ~$</span> <span class="cmd">connect</span>
          </div>

          <!-- Claude Code -->
          <div class="field">
            <label>&gt; claude_code</label>
            <p class="hint" data-t-es="terminal · un solo comando" data-t-en="terminal · single command">terminal · un solo comando</p>
            <div class="snippet">
              <code id="cmd-claude-code"></code>
              <button class="btn-mini snippet-copy" data-target="cmd-claude-code" data-t-es="[ copiar ]" data-t-en="[ copy ]" aria-label="copiar comando claude code">[ copiar ]</button>
            </div>
          </div>

          <!-- Claude.ai -->
          <div class="field">
            <label>&gt; claude.ai</label>
            <p class="hint" data-t-es="settings → integrations → add mcp server" data-t-en="settings → integrations → add mcp server">settings → integrations → add mcp server</p>
            <div class="kv">
              <span class="kv-k">server_url</span>
              <code id="cmd-claudeai-url" class="kv-v"></code>
              <button class="btn-mini snippet-copy" data-target="cmd-claudeai-url" data-t-es="[ copiar ]" data-t-en="[ copy ]" aria-label="copiar url">[ copiar ]</button>
            </div>
            <div class="kv">
              <span class="kv-k">authorization</span>
              <code id="cmd-claudeai-auth" class="kv-v"></code>
              <button class="btn-mini snippet-copy" data-target="cmd-claudeai-auth" data-t-es="[ copiar ]" data-t-en="[ copy ]" aria-label="copiar header">[ copiar ]</button>
            </div>
          </div>

          <!-- Claude Desktop -->
          <div class="field">
            <label>&gt; claude_desktop</label>
            <p class="hint" data-t-es="claude_desktop_config.json · puente mcp-remote" data-t-en="claude_desktop_config.json · mcp-remote bridge">claude_desktop_config.json · puente mcp-remote</p>
            <div class="snippet snippet-block">
              <code id="cmd-desktop"></code>
              <button class="btn-mini snippet-copy" data-target="cmd-desktop" data-t-es="[ copiar ]" data-t-en="[ copy ]" aria-label="copiar json">[ copiar ]</button>
            </div>
          </div>

          <div class="divider divider-spaced"></div>

          <div class="revoke-row">
            <button id="revoke-btn" type="button" class="btn-revoke" data-t-es="revocar token →" data-t-en="revoke token →">revocar token →</button>
            <p id="revoke-status" class="hint hidden"></p>
          </div>
        </section>
      </div>
    </main>

    <footer class="bottom-bar">
      <span class="muted">komercia/mcp v0.1</span>
      <span class="dot">·</span>
      <a href="/uso" class="link-muted">/uso</a>
      <span class="dot">·</span>
      <a href="https://github.com/gusplayer/komercia-mcp" target="_blank" rel="noopener noreferrer" class="link-muted">source</a>
      <span class="dot">·</span>
      <a href="/sign-in" class="link-muted" data-t-es="ui clásica" data-t-en="classic ui">ui clásica</a>
    </footer>
  </div>
</Base>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&display=swap');

  .page {
    --c-bg: #000000;
    --c-fg: #ffffff;
    --c-surface: #1d1d1d;
    --c-border: #383838;
    --c-muted: #888888;
    --r: 10px;

    min-height: 100vh;
    background: var(--c-bg);
    color: var(--c-fg);
    font-family: 'Space Mono', ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 16px;
    line-height: 1.4;
    letter-spacing: 0.24px;
    font-feature-settings: 'zero';
    display: flex;
    flex-direction: column;
  }
  :global(body:has(.page)) { background: #000000; }

  /* ── Top bar ─────────────────────────────────────────── */
  .topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 19px 32px;
    border-bottom: 1px solid var(--c-border);
  }
  .brand {
    color: var(--c-fg);
    text-decoration: none;
    font-size: 16px;
    flex-shrink: 0;
  }
  .brand:hover { color: var(--c-muted); }
  .topbar-actions {
    display: flex;
    align-items: center;
    gap: 19px;
    flex-shrink: 0;
  }
  .link-muted {
    color: var(--c-muted);
    text-decoration: none;
    font-size: 16px;
    transition: color 150ms;
  }
  .link-muted:hover { color: var(--c-fg); }

  /* ── Lang toggle ─────────────────────────────────────── */
  .btn-lang {
    background: transparent;
    color: var(--c-muted);
    border: none;
    padding: 0;
    font-family: inherit;
    font-size: 16px;
    letter-spacing: 0.24px;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    transition: color 150ms;
  }
  .btn-lang:hover { color: var(--c-fg); }
  .btn-lang svg { display: block; flex-shrink: 0; }

  /* ── Main ────────────────────────────────────────────── */
  .main {
    flex: 1;
    display: flex;
    justify-content: center;
    padding: 48px 32px;
  }
  .terminal {
    width: 100%;
    max-width: 640px;
    display: flex;
    flex-direction: column;
    gap: 26px;
  }

  /* ── Prompt line ─────────────────────────────────────── */
  .prompt {
    font-size: 16px;
    color: var(--c-fg);
  }
  .prompt .muted { color: var(--c-muted); }
  .prompt .cmd { color: var(--c-fg); margin-left: 8px; }
  .caret {
    color: var(--c-fg);
    margin-left: 2px;
    animation: blink 1s steps(1) infinite;
  }
  @keyframes blink { 50% { opacity: 0; } }

  /* ── Dividers ────────────────────────────────────────── */
  .divider {
    height: 1px;
    background: var(--c-border);
  }
  .divider-spaced { margin: 16px 0; }

  /* ── Title block ─────────────────────────────────────── */
  .title {
    font-size: 16px;
    font-weight: 400;
    color: var(--c-fg);
    margin: 0 0 8px;
  }
  .subtitle {
    font-size: 16px;
    color: var(--c-muted);
    margin: 0 0 26px;
    line-height: 1.4;
  }

  /* ── Form ────────────────────────────────────────────── */
  form { display: flex; flex-direction: column; gap: 19px; }
  .field { display: flex; flex-direction: column; gap: 6px; min-width: 0; }
  .field label {
    font-size: 16px;
    color: var(--c-muted);
  }
  .field input {
    background: var(--c-surface);
    border: 1px solid var(--c-surface);
    border-radius: var(--r);
    color: var(--c-fg);
    font-family: inherit;
    font-size: 16px;
    letter-spacing: 0.24px;
    padding: 16px 19px;
    transition: border-color 150ms;
    outline: none;
    width: 100%;
  }
  .field input::placeholder { color: var(--c-muted); }
  .field input:focus { border-color: var(--c-fg); }
  .field input.input-error { border-color: var(--c-fg); background: #1a0000; }

  /* ── Alerts ──────────────────────────────────────────── */
  .alert {
    background: var(--c-surface);
    border: 1px solid var(--c-border);
    border-radius: var(--r);
    padding: 16px 19px;
    color: var(--c-fg);
    font-size: 16px;
  }
  .alert::before { content: '! '; color: var(--c-muted); }
  .warn {
    font-size: 16px;
    color: var(--c-muted);
    border-left: 1px solid var(--c-border);
    padding-left: 16px;
    margin: 0 0 16px;
  }
  .status {
    font-size: 16px;
    color: var(--c-fg);
    margin: 0 0 16px;
  }
  .status .ok { color: var(--c-fg); margin-right: 8px; }
  .badge { color: var(--c-muted); font-size: 16px; margin-left: 8px; }

  /* ── Buttons ─────────────────────────────────────────── */
  .btn-primary {
    background: var(--c-fg);
    color: var(--c-bg);
    border: none;
    border-radius: var(--r);
    font-family: inherit;
    font-size: 16px;
    letter-spacing: 0.24px;
    padding: 19px 26px;
    cursor: pointer;
    transition: background 150ms, color 150ms;
    width: 100%;
  }
  .btn-primary:hover:not(:disabled) { background: var(--c-muted); color: var(--c-bg); }
  .btn-primary:disabled { opacity: 0.5; cursor: not-allowed; }

  .btn-copy {
    background: transparent;
    color: var(--c-fg);
    border: 1px solid var(--c-border);
    border-radius: var(--r);
    font-family: inherit;
    font-size: 16px;
    padding: 12px 19px;
    cursor: pointer;
    white-space: nowrap;
    transition: border-color 150ms, color 150ms;
  }
  .btn-copy:hover { border-color: var(--c-fg); }

  .btn-mini {
    background: transparent;
    color: var(--c-muted);
    border: 1px solid var(--c-border);
    border-radius: var(--r);
    font-family: inherit;
    font-size: 16px;
    padding: 6px 12px;
    cursor: pointer;
    white-space: nowrap;
    flex-shrink: 0;
    transition: color 150ms, border-color 150ms;
  }
  .btn-mini:hover { color: var(--c-fg); border-color: var(--c-fg); }
  .btn-mini.copied { color: var(--c-fg); border-color: var(--c-fg); }

  .btn-revoke {
    background: transparent;
    color: var(--c-muted);
    border: 1px solid var(--c-border);
    border-radius: var(--r);
    font-family: inherit;
    font-size: 16px;
    padding: 12px 19px;
    cursor: pointer;
    transition: color 150ms, border-color 150ms;
  }
  .btn-revoke:hover { color: var(--c-fg); border-color: var(--c-fg); }
  .btn-revoke:disabled { opacity: 0.5; cursor: not-allowed; }

  /* ── Token display ───────────────────────────────────── */
  .token-row {
    display: flex;
    align-items: stretch;
    gap: 8px;
  }
  .token-display {
    background: var(--c-surface);
    border-radius: var(--r);
    padding: 16px 19px;
    color: var(--c-fg);
    font-family: inherit;
    font-size: 16px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    flex: 1;
    min-width: 0;
    user-select: all;
  }

  /* ── Snippets ────────────────────────────────────────── */
  .hint {
    font-size: 16px;
    color: var(--c-muted);
    margin: 0;
  }
  .snippet {
    display: flex;
    align-items: center;
    gap: 8px;
    background: var(--c-surface);
    border-radius: var(--r);
    padding: 12px 16px;
  }
  .snippet code {
    flex: 1;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    color: var(--c-fg);
    font-family: inherit;
    font-size: 16px;
    user-select: all;
  }
  .snippet-block code {
    white-space: pre;
    overflow-x: auto;
    overflow-y: hidden;
    text-overflow: clip;
    -webkit-overflow-scrolling: touch;
  }
  .snippet-block { align-items: flex-start; }
  .snippet-block .btn-mini { margin-top: 2px; }

  /* ── Key/value rows ──────────────────────────────────── */
  .kv {
    display: grid;
    grid-template-columns: 140px 1fr auto;
    align-items: center;
    gap: 12px;
    background: var(--c-surface);
    border-radius: var(--r);
    padding: 12px 16px;
    margin-top: 8px;
  }
  .kv-k {
    color: var(--c-muted);
    font-size: 16px;
  }
  .kv-v {
    color: var(--c-fg);
    font-size: 16px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    min-width: 0;
    user-select: all;
  }

  /* ── Footer line ─────────────────────────────────────── */
  .footer-line {
    font-size: 16px;
    color: var(--c-muted);
    margin: 26px 0 0;
  }
  .footer-line a {
    color: var(--c-fg);
    text-decoration: underline;
    text-underline-offset: 3px;
    margin-left: 6px;
  }
  .footer-line a:hover { color: var(--c-muted); }

  .revoke-row {
    display: flex;
    flex-direction: column;
    gap: 8px;
    align-items: flex-start;
  }

  /* ── Bottom bar ──────────────────────────────────────── */
  .bottom-bar {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 19px 32px;
    border-top: 1px solid var(--c-border);
    font-size: 16px;
    flex-wrap: wrap;
  }
  .bottom-bar .dot { color: var(--c-border); }

  /* ── Helpers ─────────────────────────────────────────── */
  .muted { color: var(--c-muted); }
  .hidden { display: none !important; }

  /* ── Responsive ──────────────────────────────────────── */
  @media (max-width: 640px) {
    .topbar { padding: 14px 16px; gap: 12px; }
    .topbar-actions { gap: 14px; }
    .bottom-bar { padding: 14px 16px; }
    .main { padding: 32px 16px; }
    .kv { grid-template-columns: 1fr; gap: 6px; }
    .kv .btn-mini { justify-self: flex-end; }
  }

  @media (max-width: 480px) {
    .topbar { padding: 12px 14px; }
    .brand { font-size: 14px; }
    .topbar-actions { gap: 10px; }
    .btn-lang { font-size: 14px; }
    .link-muted { font-size: 14px; }
    .main { padding: 24px 14px; }
    .token-row { flex-direction: column; }
    .token-row .btn-copy { width: 100%; }
    .bottom-bar { padding: 14px; row-gap: 8px; }
  }
</style>

<script>
  // ── i18n ────────────────────────────────────────────────────
  let currentLang: 'es' | 'en' = 'es';

  function applyLang(lang: 'es' | 'en'): void {
    currentLang = lang;
    document.documentElement.lang = lang;
    document.querySelectorAll<HTMLElement>('[data-t-es]').forEach((el) => {
      const text = lang === 'en' ? el.getAttribute('data-t-en') : el.getAttribute('data-t-es');
      if (text !== null) el.textContent = text;
    });
    const label = document.getElementById('lang-label');
    if (label) label.textContent = lang === 'en' ? 'esp' : 'eng';
  }

  function t(es: string, en: string): string {
    return currentLang === 'en' ? en : es;
  }

  const savedLang = localStorage.getItem('lang');
  applyLang(savedLang === 'en' ? 'en' : 'es');

  const langToggle = document.getElementById('lang-toggle');
  if (langToggle) {
    langToggle.addEventListener('click', () => {
      const next = currentLang === 'es' ? 'en' : 'es';
      try { localStorage.setItem('lang', next); } catch { /* noop */ }
      applyLang(next);
    });
  }

  // ── CSRF helper ─────────────────────────────────────────────
  function getCsrfToken(): string {
    return (
      document.cookie
        .split(';')
        .map((c) => c.trim())
        .find((c) => c.startsWith('csrf_token='))
        ?.split('=')[1] ?? ''
    );
  }

  function maskToken(token: string): string {
    if (token.length <= 35) return token;
    return `${token.slice(0, 20)}${'·'.repeat(10)}${token.slice(-10)}`;
  }

  // ── DOM refs ────────────────────────────────────────────────
  const form         = document.getElementById('login-form')    as HTMLFormElement;
  const submitBtn    = document.getElementById('submit-btn')    as HTMLButtonElement;
  const btnLabel     = document.getElementById('btn-label')     as HTMLSpanElement;
  const formError    = document.getElementById('form-error')    as HTMLDivElement;
  const loginSection = document.getElementById('login-section') as HTMLElement;
  const tokenSection = document.getElementById('token-section') as HTMLElement;
  const tokenMasked  = document.getElementById('token-masked')  as HTMLElement;
  const copyBtn      = document.getElementById('copy-btn')      as HTMLButtonElement;
  const copyLabel    = document.getElementById('copy-label')    as HTMLSpanElement;
  const copySuccess  = document.getElementById('copy-success')  as HTMLSpanElement;
  const emailInput   = document.getElementById('email')         as HTMLInputElement;
  const passwordInput = document.getElementById('password')    as HTMLInputElement;
  const promptCmd    = document.getElementById('prompt-cmd')    as HTMLSpanElement | null;

  let storedToken = '';

  function setInputError(input: HTMLInputElement, hasError: boolean): void {
    if (hasError) input.classList.add('input-error');
    else input.classList.remove('input-error');
  }

  // ── Login submission ───────────────────────────────────────
  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    const email    = emailInput.value.trim();
    const password = passwordInput.value;

    let hasError = false;
    if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) { setInputError(emailInput, true); hasError = true; }
    else { setInputError(emailInput, false); }
    if (!password) { setInputError(passwordInput, true); hasError = true; }
    else { setInputError(passwordInput, false); }

    if (hasError) {
      formError.textContent = t('entrada inválida. revisa los campos.', 'invalid input. check the fields.');
      formError.classList.remove('hidden');
      return;
    }

    formError.classList.add('hidden');
    submitBtn.disabled = true;
    btnLabel.textContent = t('autenticando...', 'authenticating...');

    try {
      const res = await fetch('/api/login', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'X-CSRF-Token': getCsrfToken(),
        },
        body: JSON.stringify({ email, password }),
      });

      const data = (await res.json()) as { token?: string; error?: string };

      if (res.ok && data.token) {
        storedToken = data.token;
        tokenMasked.textContent = maskToken(storedToken);

        const mcpUrl = 'https://api-mcp.komercia.co/sse';
        function setSnippet(id: string, val: string) {
          const el = document.getElementById(id);
          if (el) el.textContent = val;
        }
        setSnippet('cmd-claude-code', `claude mcp add --transport sse komercia ${mcpUrl} --header "Authorization: Bearer ${storedToken}"`);
        setSnippet('cmd-claudeai-url', mcpUrl);
        setSnippet('cmd-claudeai-auth', `Bearer ${storedToken}`);
        setSnippet('cmd-desktop', JSON.stringify({
          mcpServers: {
            komercia: {
              command: 'mcp-remote',
              args: [mcpUrl, '--header', `Authorization: Bearer ${storedToken}`],
            },
          },
        }, null, 2));

        loginSection.classList.add('hidden');
        tokenSection.classList.remove('hidden');
        if (promptCmd) promptCmd.textContent = 'session_active';
      } else {
        const msg = data.error ?? t('error inesperado. inténtalo de nuevo.', 'unexpected error. try again.');
        formError.textContent = msg.toLowerCase();
        formError.classList.remove('hidden');
        setInputError(passwordInput, true);
      }
    } catch {
      formError.textContent = t('error de red. revisa tu conexión.', 'network error. check your connection.');
      formError.classList.remove('hidden');
    } finally {
      submitBtn.disabled = false;
      btnLabel.textContent = t('autenticar →', 'authenticate →');
    }
  });

  emailInput.addEventListener('input', () => setInputError(emailInput, false));
  passwordInput.addEventListener('input', () => setInputError(passwordInput, false));

  // ── Copy token ──────────────────────────────────────────────
  copyBtn.addEventListener('click', async () => {
    if (!storedToken) return;
    await copyText(storedToken);
    copyLabel.classList.add('hidden');
    copySuccess.classList.remove('hidden');
    setTimeout(() => {
      copyLabel.classList.remove('hidden');
      copySuccess.classList.add('hidden');
    }, 2500);
  });

  // ── Snippet copy buttons ───────────────────────────────────
  document.querySelectorAll<HTMLButtonElement>('.snippet-copy').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const targetId = btn.getAttribute('data-target');
      if (!targetId) return;
      const el = document.getElementById(targetId);
      if (!el) return;
      const text = el.textContent ?? '';
      await copyText(text);
      const orig = btn.textContent;
      btn.textContent = '[ ✓ ]';
      btn.classList.add('copied');
      setTimeout(() => {
        btn.textContent = orig;
        btn.classList.remove('copied');
      }, 1800);
    });
  });

  async function copyText(text: string): Promise<void> {
    try {
      await navigator.clipboard.writeText(text);
    } catch {
      const ta = document.createElement('textarea');
      ta.value = text;
      ta.style.position = 'fixed';
      ta.style.opacity = '0';
      document.body.appendChild(ta);
      ta.select();
      document.execCommand('copy');
      document.body.removeChild(ta);
    }
  }

  // ── Revoke ─────────────────────────────────────────────────
  const revokeBtn    = document.getElementById('revoke-btn')    as HTMLButtonElement | null;
  const revokeStatus = document.getElementById('revoke-status') as HTMLElement | null;

  if (revokeBtn && revokeStatus) {
    revokeBtn.addEventListener('click', async () => {
      if (!storedToken) return;
      if (!window.confirm(t('¿revocar este token? cualquiera que lo esté usando perderá acceso de inmediato.', 'revoke this token? anyone using it will lose access immediately.'))) return;

      revokeBtn.disabled = true;
      revokeStatus.textContent = t('revocando...', 'revoking...');
      revokeStatus.classList.remove('hidden');

      try {
        const res = await fetch('/api/sessions/revoke', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'X-CSRF-Token': getCsrfToken(),
          },
          body: JSON.stringify({ token: storedToken }),
        });

        const data = (await res.json()) as { revoked?: boolean; error?: string };

        if (res.ok && data.revoked) {
          revokeStatus.textContent = t('token revocado. redirigiendo...', 'token revoked. redirecting...');
          setTimeout(() => { window.location.href = '/v2'; }, 1500);
        } else {
          revokeStatus.textContent = (data.error ?? t('error al revocar.', 'revocation failed.')).toLowerCase();
          revokeBtn.disabled = false;
        }
      } catch {
        revokeStatus.textContent = t('error de red.', 'network error.');
        revokeBtn.disabled = false;
      }
    });
  }
</script>
