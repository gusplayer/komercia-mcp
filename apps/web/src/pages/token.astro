---
import Base from '../layouts/Base.astro';
import TokenDisplay from '../components/TokenDisplay.astro';
import { getConfig } from '../lib/env.js';

const code = Astro.url.searchParams.get('code') ?? '';

// Validate code format before making the API call
const HEX_CODE_REGEX = /^[0-9a-f]{64}$/;

type RedeemResult =
  | { ok: true; token: string }
  | { ok: false; status: number; errorCode: string };

let result: RedeemResult;

if (!HEX_CODE_REGEX.test(code)) {
  result = { ok: false, status: 400, errorCode: 'invalid' };
} else {
  try {
    const config = getConfig();
    const redeemUrl = `${config.WEB_BASE_URL}/api/redeem?code=${encodeURIComponent(code)}`;
    const res = await fetch(redeemUrl);
    const data = (await res.json()) as { token?: string; error?: string };

    if (res.ok && data.token) {
      result = { ok: true, token: data.token };
    } else {
      result = {
        ok: false,
        status: res.status,
        errorCode: data.error ?? 'unknown',
      };
    }
  } catch (err) {
    console.error('[token page] fetch error:', err);
    result = { ok: false, status: 500, errorCode: 'internal_error' };
  }
}

const errorMessages: Record<string, { heading: string; body: string }> = {
  expired: {
    heading: 'This link has expired',
    body: 'Magic links are valid for 15 minutes. Please request a new one.',
  },
  used: {
    heading: 'This link has already been used',
    body: 'Each link can only be used once. If you need a new token, request another link.',
  },
  blocked: {
    heading: 'Too many attempts',
    body: 'This link has been blocked after too many failed attempts. Please request a new one.',
  },
  not_found: {
    heading: 'Link not found',
    body: "We couldn't find this link. It may have been mistyped or already deleted.",
  },
  invalid: {
    heading: 'Invalid link',
    body: 'This link appears to be malformed. Please check the URL and try again.',
  },
  internal_error: {
    heading: 'Something went wrong',
    body: 'An unexpected error occurred. Please try again or request a new link.',
  },
};

const errorInfo = !result.ok
  ? (errorMessages[result.errorCode] ?? errorMessages['internal_error']!)
  : null;
---

<Base title={result.ok ? 'Your export token — Komercia' : 'Link error — Komercia Export'}>
  <main class="page-container">
    {result.ok ? (
      <div class="space-y-8">
        <!-- Header -->
        <div>
          <div class="flex items-center gap-2 mb-4">
            <div class="w-8 h-8 rounded-lg bg-green-50 border border-green-200 flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
            </div>
            <span class="text-sm font-medium text-green-700">Token ready</span>
          </div>
          <h1 class="text-2xl font-bold text-slate-900 mb-2">Your export token</h1>
          <div class="flex items-start gap-2 rounded-lg border border-amber-200 bg-amber-50 px-4 py-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#d97706" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="flex-shrink-0 mt-0.5">
              <path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/>
              <path d="M12 9v4M12 17h.01"/>
            </svg>
            <p class="text-sm text-amber-800 font-medium">
              This token will only be shown once. Copy it now.
            </p>
          </div>
        </div>

        <!-- Token -->
        <div class="card">
          <p class="text-xs font-medium text-slate-500 mb-3 uppercase tracking-wide">JWT Token</p>
          <TokenDisplay token={result.token} />
        </div>

        <!-- Instructions -->
        <div class="card space-y-5">
          <h2 class="text-sm font-semibold text-slate-700">How to use this token in Claude.ai</h2>

          <ol class="space-y-4">
            <li class="flex items-start gap-3">
              <span class="flex-shrink-0 w-6 h-6 rounded-full bg-indigo-50 border border-indigo-100 flex items-center justify-center text-xs font-semibold text-accent">1</span>
              <div class="text-sm text-slate-600">
                <p class="font-medium text-slate-800 mb-0.5">Open Claude.ai Settings</p>
                <p>Go to <strong>Settings → Integrations</strong> (or Connectors) and click <strong>Add integration</strong>.</p>
              </div>
            </li>

            <li class="flex items-start gap-3">
              <span class="flex-shrink-0 w-6 h-6 rounded-full bg-indigo-50 border border-indigo-100 flex items-center justify-center text-xs font-semibold text-accent">2</span>
              <div class="text-sm text-slate-600">
                <p class="font-medium text-slate-800 mb-0.5">Enter the MCP server URL</p>
                <p>Use the Komercia MCP server URL provided separately, and paste your token as the auth credential.</p>
              </div>
            </li>

            <li class="flex items-start gap-3">
              <span class="flex-shrink-0 w-6 h-6 rounded-full bg-indigo-50 border border-indigo-100 flex items-center justify-center text-xs font-semibold text-accent">3</span>
              <div class="text-sm text-slate-600">
                <p class="font-medium text-slate-800 mb-0.5">Start a new conversation</p>
                <p>Say something like: <em>"Export all my products as a CSV file"</em> or <em>"Show me my order history from the last 90 days."</em></p>
              </div>
            </li>
          </ol>

          <div class="pt-2 border-t border-slate-100">
            <p class="text-xs text-slate-400">
              Your token is valid for 6 months. If it expires,{' '}
              <a href="/" class="underline hover:text-slate-600">request a new one</a>.
              See <a href="/tools" class="underline hover:text-slate-600">all available export tools</a>.
            </p>
          </div>
        </div>
      </div>
    ) : (
      <div class="text-center">
        <!-- Error icon -->
        <div class="w-14 h-14 rounded-2xl bg-red-50 border border-red-100 flex items-center justify-center mx-auto mb-6">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#dc2626" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/>
            <path d="m15 9-6 6M9 9l6 6"/>
          </svg>
        </div>

        <h1 class="text-2xl font-bold text-slate-900 mb-3">{errorInfo!.heading}</h1>
        <p class="text-slate-500 text-base mb-8">{errorInfo!.body}</p>

        <a href="/" class="btn-primary inline-flex">Request a new link</a>
      </div>
    )}
  </main>
</Base>
