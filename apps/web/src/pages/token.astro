---
// token.astro — Confirmation page after successful token generation.
import Base from '../layouts/Base.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Button from '../components/Button.astro';
import Container from '../components/Container.astro';
import Section from '../components/Section.astro';
---

<Base
  title="Token de exportación — Komercia MCP"
  description="Tu token de exportación de Komercia. Úsalo para conectar Claude.ai a tu tienda."
  noindex={true}
>
  <Navbar />
  <main>
    <Section padding="default">
      <Container size="narrow">
        <p class="section-eyebrow">Token de exportación</p>
        <h1
          style="font-family: var(--font-display); font-weight: 600; font-size: 40px; line-height: 1.1; letter-spacing: -0.8px; color: var(--color-ink-blue); margin: 12px 0 16px;"
        >
          Tu token está listo.
        </h1>
        <p
          style="font-family: var(--font-sans); font-size: 16px; color: var(--color-slate-text); line-height: 1.5; margin-bottom: 32px;"
        >
          Úsalo para conectar Claude.ai a tu tienda Komercia. Válido por 6 meses.
        </p>
        <div style="display: flex; gap: 12px; flex-wrap: wrap;">
          <Button variant="primary" size="md" href="/">Volver al inicio</Button>
          <Button variant="secondary" size="md" href="/uso">Ver guía de instalación →</Button>
        </div>
      </Container>
    </Section>
  </main>
  <Footer />
</Base>
