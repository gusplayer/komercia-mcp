---
import Base from '../layouts/Base.astro';
import LoginForm from '../components/LoginForm.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
import { generateCsrfToken } from '../lib/csrf.js';

const csrfToken = generateCsrfToken();
Astro.cookies.set('csrf_token', csrfToken, {
  path: '/',
  sameSite: 'strict',
  httpOnly: false,
  secure: import.meta.env.PROD,
  maxAge: 3600,
});
---

<Base
  title="Iniciar sesión — Komercia Exit MCP"
  description="Inicia sesión con tu cuenta Komercia para obtener tu token de exportación personal."
  noindex={true}
>
  <div class="min-h-screen flex flex-col">

    <!-- Minimal header -->
    <header class="h-14 flex items-center px-6 lg:px-8 border-b border-subtle">
      <a href="/" class="font-semibold text-sm" style="color:var(--text-primary)">
        komercia<span class="text-accent-color"> exit</span>
      </a>
      <div class="ml-auto"><ThemeToggle /></div>
    </header>

    <!-- Main split -->
    <main class="flex-1 grid lg:grid-cols-2">

      <!-- LEFT: form area -->
      <div class="flex items-center justify-center px-6 py-12 lg:py-0">
        <div class="w-full max-w-sm">
          <!-- Back link -->
          <a href="/" class="link inline-flex items-center gap-1 text-xs mb-10">← Volver al inicio</a>

          <!-- Heading -->
          <h1 class="text-3xl font-semibold tracking-tight mb-2" style="letter-spacing:-0.02em">Inicia sesión</h1>
          <p class="text-sm text-muted mb-8">Con tu cuenta de Komercia</p>

          <!-- Form -->
          <LoginForm />

          <!-- Footer note -->
          <p class="text-[11px] text-faint text-center mt-8 leading-relaxed">
            Tus credenciales se usan solo para autenticarte y nunca se almacenan.<br>
            <a href="/#seguridad" class="link-accent">Lee nuestro modelo de seguridad →</a>
          </p>
        </div>
      </div>

      <!-- RIGHT: decorative panel -->
      <div
        class="hidden lg:flex relative overflow-hidden items-center justify-center"
        style="background-color: var(--bg-secondary); border-left: 1px solid var(--border);"
      >
        <!-- Particle field background -->
        <div class="particle-field"></div>
        <div class="particle-accent"></div>
        <!-- Centered content -->
        <div class="relative z-10 max-w-sm px-12 text-center">
          <h2 class="text-4xl font-semibold tracking-tight mb-4" style="letter-spacing:-0.02em; line-height:1.1">
            Tus datos,<br>
            <span style="color: var(--accent)">siempre contigo.</span>
          </h2>
          <p class="text-sm text-muted leading-relaxed">
            Exporta todo de tu tienda Komercia conversando con Claude.ai.
          </p>
        </div>
      </div>
    </main>
  </div>
</Base>
</content>
</invoke>