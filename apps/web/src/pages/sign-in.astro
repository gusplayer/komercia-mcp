---
// sign-in.astro — Auth + token issuance. 099 / terminal aesthetic, bilingual.
import Base from '../layouts/Base.astro';
import RecetasModal from '../components/RecetasModal.astro';
import { generateCsrfToken } from '../lib/csrf.js';

const csrfToken = generateCsrfToken();
Astro.cookies.set('csrf_token', csrfToken, {
  path: '/',
  sameSite: 'strict',
  httpOnly: false,
  secure: import.meta.env.PROD,
  maxAge: 3600,
});
---

<Base
  title="komercia/mcp — auth"
  description="Acceso al servidor MCP de Komercia. Variante terminal."
  noindex={true}
>
  <div class="page">
    <header class="topbar">
      <a href="/" class="brand" aria-label="komercia mcp home">[komercia/mcp]</a>

      <div class="topbar-actions">
        <a href="/" class="link-muted" data-t-es="← volver" data-t-en="← back">← volver</a>
        <button id="lang-toggle" class="btn-ghost-pill" aria-label="Cambiar idioma" title="Cambiar idioma / Toggle language">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="10"/>
            <path d="M2 12h20"/>
            <path d="M12 2a15 15 0 0 1 4 10 15 15 0 0 1-4 10 15 15 0 0 1-4-10 15 15 0 0 1 4-10z"/>
          </svg>
          <span id="lang-current">ES</span>
        </button>
        <a href="https://github.com/gusplayer/komercia-mcp" target="_blank" rel="noopener noreferrer" class="btn-ghost-pill btn-icon-only" aria-label="Ver repositorio en GitHub" title="Ver repositorio en GitHub">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
          </svg>
        </a>
      </div>
    </header>

    <main class="main">
      <div class="terminal">
        <div class="prompt">
          <span class="muted">user@komercia ~$</span>
          <span class="cmd" id="prompt-cmd">authenticate</span><span class="caret">_</span>
        </div>

        <div class="divider"></div>

        <!-- ── Login section ──────────────────────────────────── -->
        <section id="login-section">
          <h1 class="title" data-scramble data-t-es="Acceder a los datos de tu tienda" data-t-en="Access your store data">Acceder a los datos de tu tienda</h1>
          <p class="subtitle" data-scramble data-t-es="Inicia sesión con tus credenciales de Komercia para emitir un token MCP de solo lectura." data-t-en="Log in with your Komercia credentials to issue a read-only MCP token.">
            Inicia sesión con tus credenciales de Komercia para emitir un token MCP de solo lectura.
          </p>

          <form id="login-form" novalidate>
            <div class="field">
              <label for="email" data-t-es="&gt; correo" data-t-en="&gt; email">&gt; correo</label>
              <input
                id="email"
                name="email"
                type="email"
                autocomplete="email"
                required
                placeholder="you@email.com"
                spellcheck="false"
                autocapitalize="off"
              />
            </div>

            <div class="field">
              <label for="password" data-t-es="&gt; contraseña" data-t-en="&gt; password">&gt; contraseña</label>
              <input
                id="password"
                name="password"
                type="password"
                autocomplete="current-password"
                required
                placeholder="••••••••"
              />
            </div>

            <div id="form-error" class="alert hidden" role="alert" aria-live="polite"></div>

            <button type="submit" id="submit-btn" class="btn-primary">
              <span id="btn-label" data-t-es="autenticar →" data-t-en="authenticate →">autenticar →</span>
            </button>
          </form>

          <p class="footer-line">
            <span data-t-es="¿Sin cuenta?" data-t-en="No account?">¿Sin cuenta?</span>
            <a href="https://komercia.co" target="_blank" rel="noopener noreferrer" data-t-es="Regístrate en komercia.co →" data-t-en="Register at komercia.co →">Regístrate en komercia.co →</a>
          </p>

          <div class="login-note" role="note">
            <span class="login-note-label">[ importante ]</span>
            <span data-t-es="Necesitas tener una tienda activa en Komercia con datos. El token solo da acceso de lectura a tu tienda existente — no crea ni modifica nada." data-t-en="You must have an active Komercia store with data. The token only grants read access to your existing store — it never creates or modifies anything.">Necesitas tener una tienda activa en Komercia con datos. El token solo da acceso de lectura a tu tienda existente — no crea ni modifica nada.</span>
          </div>
        </section>

        <!-- ── Token section ──────────────────────────────────── -->
        <section id="token-section" class="hidden">
          <div class="status">
            <span class="ok">●</span> <span data-t-es="sesión_autenticada" data-t-en="session_authenticated">sesión_autenticada</span>
          </div>

          <div class="warn" data-t-es="! el token se muestra una sola vez. cópialo antes de salir." data-t-en="! token shown once. copy it before leaving this page.">
            ! el token se muestra una sola vez. cópialo antes de salir.
          </div>

          <div class="field">
            <label>
              <span data-t-es="&gt; token_jwt" data-t-en="&gt; jwt_token">&gt; token_jwt</span>
              <span class="badge" data-t-es="solo lectura · 6 meses" data-t-en="read-only · 6mo">solo lectura · 6 meses</span>
            </label>
            <div class="token-row">
              <code id="token-masked" class="token-display"></code>
              <button id="copy-btn" class="btn-copy" aria-label="copiar token">
                <span id="copy-label" data-t-es="[ copiar ]" data-t-en="[ copy ]">[ copiar ]</span>
                <span id="copy-success" class="hidden" data-t-es="[ ✓ copiado ]" data-t-en="[ ✓ copied ]">[ ✓ copiado ]</span>
              </button>
            </div>
          </div>

          <div class="divider divider-spaced"></div>

          <div class="prompt">
            <span class="muted">user@komercia ~$</span> <span class="cmd">./connect.mcp</span>
          </div>

          <p class="connect-intro" data-t-es="Tres formas de usarlo — todas funcionan con el mismo token. Elige una." data-t-en="Three ways to use it — all work with the same token. Pick one.">
            Tres formas de usarlo — todas funcionan con el mismo token. Elige una.
          </p>

          <!-- Opción A · Claude Code (simplest — single command) -->
          <article class="option-card">
            <header class="option-header">
              <span class="option-label">A</span>
              <div class="option-meta">
                <h3 class="option-name">Claude Code</h3>
                <span class="option-tag" data-t-es="terminal · el más simple" data-t-en="terminal · the simplest">terminal · el más simple</span>
              </div>
            </header>
            <p class="option-desc" data-t-es="Copia este comando, pégalo en tu terminal con Claude Code y empieza a usarlo. Listo en 5 segundos." data-t-en="Copy this command, paste it in your terminal with Claude Code, and start using it. Done in 5 seconds.">
              Copia este comando, pégalo en tu terminal con Claude Code y empieza a usarlo. Listo en 5 segundos.
            </p>
            <div class="snippet-block-wrap">
              <pre class="snippet-pre"><code id="cmd-claude-code"></code></pre>
              <button class="btn-mini snippet-copy" data-target="cmd-claude-code" data-t-es="[ copiar ]" data-t-en="[ copy ]" aria-label="copiar comando claude code">[ copiar ]</button>
            </div>
          </article>

          <!-- Opción B · Claude.ai -->
          <article class="option-card">
            <header class="option-header">
              <span class="option-label">B</span>
              <div class="option-meta">
                <h3 class="option-name">Claude.ai</h3>
                <span class="option-tag" data-t-es="web · sin instalación" data-t-en="web · no install">web · sin instalación</span>
              </div>
            </header>
            <p class="option-desc" data-t-es="En claude.ai abre Settings → Integrations → Add MCP Server, y pega estos dos valores." data-t-en="In claude.ai open Settings → Integrations → Add MCP Server, then paste these two values.">
              En claude.ai abre Settings → Integrations → Add MCP Server, y pega estos dos valores.
            </p>

            <div class="snippet-block-wrap">
              <p class="snippet-field-label">server_url</p>
              <pre class="snippet-pre"><code id="cmd-claudeai-url"></code></pre>
              <button class="btn-mini snippet-copy" data-target="cmd-claudeai-url" data-t-es="[ copiar ]" data-t-en="[ copy ]" aria-label="copiar url">[ copiar ]</button>
            </div>

            <div class="snippet-block-wrap">
              <p class="snippet-field-label">authorization</p>
              <pre class="snippet-pre"><code id="cmd-claudeai-auth"></code></pre>
              <button class="btn-mini snippet-copy" data-target="cmd-claudeai-auth" data-t-es="[ copiar ]" data-t-en="[ copy ]" aria-label="copiar header">[ copiar ]</button>
            </div>
          </article>

          <!-- Opción C · Claude Desktop -->
          <article class="option-card">
            <header class="option-header">
              <span class="option-label">C</span>
              <div class="option-meta">
                <h3 class="option-name">Claude Desktop</h3>
                <span class="option-tag" data-t-es="app · puente mcp-remote" data-t-en="app · mcp-remote bridge">app · puente mcp-remote</span>
              </div>
            </header>
            <p class="option-desc" data-t-es="Pega este JSON dentro de claude_desktop_config.json y reinicia la app." data-t-en="Paste this JSON into claude_desktop_config.json and restart the app.">
              Pega este JSON dentro de claude_desktop_config.json y reinicia la app.
            </p>
            <div class="snippet-block-wrap">
              <pre class="snippet-pre snippet-pre-block"><code id="cmd-desktop"></code></pre>
              <button class="btn-mini snippet-copy" data-target="cmd-desktop" data-t-es="[ copiar ]" data-t-en="[ copy ]" aria-label="copiar json">[ copiar ]</button>
            </div>
          </article>

          <div class="divider divider-spaced"></div>

          <!-- See usage examples (opens shared modal) -->
          <div class="examples-row">
            <p class="muted small" data-t-es="¿No sabes qué preguntarle a Claude?" data-t-en="Not sure what to ask Claude?">¿No sabes qué preguntarle a Claude?</p>
            <button type="button" data-open-recetas class="btn-examples" data-t-es="Ver 18 ejemplos de uso →" data-t-en="See 18 usage examples →">Ver 18 ejemplos de uso →</button>
          </div>

          <div class="divider divider-spaced"></div>

          <!-- Token lifecycle FAQ -->
          <div class="token-faq" role="note">
            <p class="faq-q" data-t-es="¿Perdiste el token?" data-t-en="Lost the token?">¿Perdiste el token?</p>
            <p class="faq-a" data-t-es="Vuelve a iniciar sesión para generar uno nuevo. El anterior sigue funcionando hasta que lo revoques o caduque (6 meses)." data-t-en="Log in again to generate a new one. The previous token keeps working until you revoke it or until it expires (6 months).">
              Vuelve a iniciar sesión para generar uno nuevo. El anterior sigue funcionando hasta que lo revoques o caduque (6 meses).
            </p>

            <p class="faq-q" data-t-es="¿Revocas el token?" data-t-en="Revoking the token?">¿Revocas el token?</p>
            <p class="faq-a" data-t-es="El acceso se corta de inmediato en todos los clientes donde lo hayas pegado. Genera uno nuevo con una sesión nueva si lo necesitas otra vez." data-t-en="Access stops immediately on every client where you pasted it. Generate a new one with a fresh login if you need to use it again.">
              El acceso se corta de inmediato en todos los clientes donde lo hayas pegado. Genera uno nuevo con una sesión nueva si lo necesitas otra vez.
            </p>
          </div>

          <div class="revoke-row">
            <button id="revoke-btn" type="button" class="btn-revoke" data-t-es="Revocar token →" data-t-en="Revoke token →">Revocar token →</button>
            <p id="revoke-status" class="hint hidden"></p>
          </div>
        </section>
      </div>
    </main>

    <RecetasModal />

    <footer class="bottom-bar">
      <span class="muted">komercia/mcp v0.1</span>
      <span class="dot">·</span>
      <a href="https://github.com/gusplayer/komercia-mcp" target="_blank" rel="noopener noreferrer" class="link-muted">source</a>
    </footer>
  </div>
</Base>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&display=swap');

  .page {
    --c-bg: #000000;
    --c-fg: #ffffff;
    --c-surface: #1d1d1d;
    --c-border: #383838;
    --c-muted: #888888;
    --r: 10px;

    /* Type scale — keep in sync with index.astro + docs/brand.md */
    --fs-xs:   12px;
    --fs-sm:   13px;
    --fs-base: 14px;
    --fs-md:   16px;
    --fs-xl:   24px;
    --fs-2xl:  32px;

    min-height: 100vh;
    background: var(--c-bg);
    color: var(--c-fg);
    font-family: 'Space Mono', ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: var(--fs-md);
    line-height: 1.4;
    letter-spacing: 0.24px;
    font-feature-settings: 'zero';
    display: flex;
    flex-direction: column;
  }
  :global(body:has(.page)) { background: #000000; }

  /* ── Top bar ─────────────────────────────────────────── */
  .topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 19px 32px;
    border-bottom: 1px solid var(--c-border);
  }
  .brand {
    color: var(--c-fg);
    text-decoration: none;
    font-size: var(--fs-md);
    flex-shrink: 0;
  }
  .brand:hover { color: var(--c-muted); }
  .topbar-actions {
    display: flex;
    align-items: center;
    gap: 19px;
    flex-shrink: 0;
  }
  .link-muted {
    color: var(--c-muted);
    text-decoration: none;
    font-size: var(--fs-md);
    transition: color 150ms;
  }
  .link-muted:hover { color: var(--c-fg); }

  /* Ghost pill — transparent + 1px border (099 spec). Fixed 36px height. */
  .btn-ghost-pill {
    background: transparent;
    color: var(--c-fg);
    border: 1px solid var(--c-border);
    border-radius: var(--r);
    height: 36px;
    box-sizing: border-box;
    padding: 0 12px;
    font-family: inherit;
    font-size: var(--fs-base);
    letter-spacing: 0.24px;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    white-space: nowrap;
    line-height: 1;
    text-decoration: none;
    transition: border-color 150ms, color 150ms, background 150ms;
  }
  .btn-ghost-pill:hover {
    border-color: var(--c-fg);
    background: var(--c-surface);
  }
  .btn-ghost-pill svg { display: block; flex-shrink: 0; }
  .btn-ghost-pill.btn-icon-only {
    padding: 0;
    width: 36px;
    justify-content: center;
  }

  /* ── Main ────────────────────────────────────────────── */
  .main {
    flex: 1;
    display: flex;
    justify-content: center;
    padding: 48px 32px;
  }
  .terminal {
    width: 100%;
    max-width: 640px;
    display: flex;
    flex-direction: column;
    gap: 26px;
  }

  /* ── Prompt line ─────────────────────────────────────── */
  .prompt {
    font-size: var(--fs-md);
    color: var(--c-fg);
  }
  .prompt .muted { color: var(--c-muted); }
  .prompt .cmd { color: var(--c-fg); margin-left: 8px; }
  .caret {
    color: var(--c-fg);
    margin-left: 2px;
    animation: blink 1s steps(1) infinite;
  }
  @keyframes blink { 50% { opacity: 0; } }

  /* Text-scramble (terminal decryption) — hide target text until JS animates it */
  .scramble-dud {
    color: var(--c-muted);
    opacity: 0.65;
  }
  :global(html.js-enabled) [data-scramble]:not(.scramble-active) {
    visibility: hidden;
  }
  @media (prefers-reduced-motion: reduce) {
    :global(html.js-enabled) [data-scramble]:not(.scramble-active) {
      visibility: visible;
    }
  }

  /* ── Dividers ────────────────────────────────────────── */
  .divider {
    height: 1px;
    background: var(--c-border);
  }
  .divider-spaced { margin: 16px 0; }

  /* ── Title block ─────────────────────────────────────── */
  .title {
    font-size: var(--fs-md);
    font-weight: 400;
    color: var(--c-fg);
    margin: 0 0 8px;
  }
  .subtitle {
    font-size: var(--fs-md);
    color: var(--c-fg);
    margin: 0 0 26px;
    line-height: 1.5;
  }

  /* ── Form ────────────────────────────────────────────── */
  form { display: flex; flex-direction: column; gap: 19px; }
  .field { display: flex; flex-direction: column; gap: 6px; min-width: 0; }
  .field label {
    font-size: var(--fs-md);
    color: var(--c-muted);
  }
  .field input {
    background: var(--c-surface);
    border: 1px solid var(--c-surface);
    border-radius: var(--r);
    color: var(--c-fg);
    font-family: inherit;
    font-size: var(--fs-md);
    letter-spacing: 0.24px;
    padding: 16px 19px;
    transition: border-color 150ms;
    outline: none;
    width: 100%;
  }
  .field input::placeholder { color: var(--c-muted); }
  .field input:focus { border-color: var(--c-fg); }
  .field input.input-error { border-color: var(--c-fg); background: #1a0000; }

  /* ── Alerts ──────────────────────────────────────────── */
  .alert {
    background: var(--c-surface);
    border: 1px solid var(--c-border);
    border-radius: var(--r);
    padding: 16px 19px;
    color: var(--c-fg);
    font-size: var(--fs-md);
  }
  .alert::before { content: '! '; color: var(--c-muted); }
  .warn {
    font-size: var(--fs-md);
    color: var(--c-muted);
    border-left: 1px solid var(--c-border);
    padding-left: 16px;
    margin: 0 0 16px;
  }
  .status {
    font-size: var(--fs-md);
    color: var(--c-fg);
    margin: 0 0 16px;
  }
  .status .ok { color: var(--c-fg); margin-right: 8px; }
  .badge { color: var(--c-muted); font-size: var(--fs-md); margin-left: 8px; }

  /* ── Buttons ─────────────────────────────────────────── */
  .btn-primary {
    background: var(--c-fg);
    color: var(--c-bg);
    border: none;
    border-radius: var(--r);
    font-family: inherit;
    font-size: var(--fs-md);
    letter-spacing: 0.24px;
    padding: 19px 26px;
    cursor: pointer;
    transition: background 150ms, color 150ms;
    width: 100%;
  }
  .btn-primary:hover:not(:disabled) { background: var(--c-muted); color: var(--c-bg); }
  .btn-primary:disabled { opacity: 0.5; cursor: not-allowed; }

  .btn-copy {
    background: transparent;
    color: var(--c-fg);
    border: 1px solid var(--c-border);
    border-radius: var(--r);
    font-family: inherit;
    font-size: var(--fs-md);
    padding: 12px 19px;
    cursor: pointer;
    white-space: nowrap;
    transition: border-color 150ms, color 150ms;
  }
  .btn-copy:hover { border-color: var(--c-fg); }

  .btn-mini {
    background: transparent;
    color: var(--c-muted);
    border: 1px solid var(--c-border);
    border-radius: var(--r);
    font-family: inherit;
    font-size: var(--fs-md);
    padding: 6px 12px;
    cursor: pointer;
    white-space: nowrap;
    flex-shrink: 0;
    transition: color 150ms, border-color 150ms;
  }
  .btn-mini:hover { color: var(--c-fg); border-color: var(--c-fg); }
  .btn-mini.copied { color: var(--c-fg); border-color: var(--c-fg); }

  .btn-revoke {
    background: transparent;
    color: var(--c-muted);
    border: 1px solid var(--c-border);
    border-radius: var(--r);
    font-family: inherit;
    font-size: var(--fs-md);
    padding: 12px 19px;
    cursor: pointer;
    transition: color 150ms, border-color 150ms;
  }
  .btn-revoke:hover { color: var(--c-fg); border-color: var(--c-fg); }
  .btn-revoke:disabled { opacity: 0.5; cursor: not-allowed; }

  /* ── Token display ───────────────────────────────────── */
  .token-row {
    display: flex;
    align-items: stretch;
    gap: 8px;
  }
  .token-display {
    background: var(--c-surface);
    border-radius: var(--r);
    padding: 16px 19px;
    color: var(--c-fg);
    font-family: inherit;
    font-size: var(--fs-md);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    flex: 1;
    min-width: 0;
    user-select: all;
  }

  /* ── Snippets ────────────────────────────────────────── */
  .hint {
    font-size: var(--fs-md);
    color: var(--c-muted);
    margin: 0;
  }
  /* ── Connection options (A · B · C) ──────────────────── */
  .connect-intro {
    margin: 0 0 8px;
    font-size: var(--fs-base);
    color: var(--c-fg);
    line-height: 1.5;
  }
  .option-card {
    background: var(--c-surface);
    border: 1px solid var(--c-border);
    border-radius: var(--r);
    padding: 19px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    margin-bottom: 5px;
  }
  .option-card:last-of-type { margin-bottom: 0; }
  .option-header {
    display: flex;
    align-items: flex-start;
    gap: 14px;
  }
  .option-label {
    width: 28px;
    height: 28px;
    border-radius: 6px;
    background: var(--c-fg);
    color: var(--c-bg);
    display: inline-flex;
    align-items: center;
