  /* ── Footer line ─────────────────────────────────────── */
  .footer-line {
    font-size: var(--fs-md);
    color: var(--c-muted);
    margin: 26px 0 0;
  }
  .footer-line a {
    color: var(--c-fg);
    text-decoration: underline;
    text-underline-offset: 3px;
    margin-left: 6px;
  }
  .footer-line a:hover { color: var(--c-muted); }

  /* Important note at the bottom of the login section */
  .login-note {
    margin-top: 32px;
    padding: 14px 16px;
    border: 1px solid var(--c-border);
    border-radius: var(--r);
    background: var(--c-surface);
    font-size: var(--fs-base);
    color: var(--c-fg);
    line-height: 1.5;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .login-note-label {
    color: var(--c-fg);
    font-size: var(--fs-sm);
    letter-spacing: 0.04em;
  }

  .revoke-row {
    display: flex;
    flex-direction: column;
    gap: 8px;
    align-items: flex-start;
  }

  /* ── Bottom bar ──────────────────────────────────────── */
  .bottom-bar {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 19px 32px;
    border-top: 1px solid var(--c-border);
    font-size: var(--fs-md);
    flex-wrap: wrap;
  }
  .bottom-bar .dot { color: var(--c-border); }

  /* ── Helpers ─────────────────────────────────────────── */
  .muted { color: var(--c-muted); }
  .hidden { display: none !important; }

  /* ── Responsive ──────────────────────────────────────── */
  @media (max-width: 640px) {
    .topbar { padding: 14px 16px; gap: 12px; }
    .topbar-actions { gap: 14px; }
    .bottom-bar { padding: 14px 16px; }
    .main { padding: 32px 16px; }
    .kv { grid-template-columns: 1fr; gap: 6px; }
    .kv .btn-mini { justify-self: flex-end; }
  }

  @media (max-width: 480px) {
    .topbar { padding: 12px 14px; }
    .brand { font-size: var(--fs-base); }
    .topbar-actions { gap: 10px; }
    .btn-ghost-pill { height: 32px; padding: 0 10px; font-size: var(--fs-sm); gap: 6px; }
    .btn-ghost-pill.btn-icon-only { width: 32px; padding: 0; }
    .link-muted { font-size: var(--fs-base); }
    .main { padding: 24px 14px; }
    .token-row { flex-direction: column; }
    .token-row .btn-copy { width: 100%; }
    .bottom-bar { padding: 14px; row-gap: 8px; }
  }
</style>

<script>
  // ── i18n ────────────────────────────────────────────────────
  let currentLang: 'es' | 'en' = 'es';

  function applyLang(lang: 'es' | 'en'): void {
    currentLang = lang;
    document.documentElement.lang = lang;
    document.querySelectorAll<HTMLElement>('[data-t-es]').forEach((el) => {
      const text = lang === 'en' ? el.getAttribute('data-t-en') : el.getAttribute('data-t-es');
      if (text === null) return;
      if (el.hasAttribute('data-scramble')) {
        const se = el as ScrambleEl;
        se._scrambleTarget = text;
        se._scrambling = false;
      }
      el.textContent = text;
    });
    const label = document.getElementById('lang-current');
    if (label) label.textContent = lang.toUpperCase();
  }

  function t(es: string, en: string): string {
    return currentLang === 'en' ? en : es;
  }

  // Detect initial language: saved preference wins, else infer from
  // the browser's preferred locales, else fall back to Spanish.
  function detectLang(): 'es' | 'en' {
    try {
      const saved = localStorage.getItem('lang');
      if (saved === 'en' || saved === 'es') return saved;
    } catch { /* localStorage unavailable */ }
    const navLangs = (navigator.languages && navigator.languages.length)
      ? navigator.languages
      : [navigator.language || ''];
    for (const raw of navLangs) {
      const l = (raw || '').toLowerCase();
      if (l.startsWith('en')) return 'en';
      if (l.startsWith('es')) return 'es';
    }
    return 'es';
  }
  applyLang(detectLang());

  const langToggle = document.getElementById('lang-toggle');
  if (langToggle) {
    langToggle.addEventListener('click', () => {
      const next = currentLang === 'es' ? 'en' : 'es';
      try { localStorage.setItem('lang', next); } catch { /* noop */ }
      applyLang(next);
    });
  }

  // ── Text scramble (terminal decryption effect) ──────────────
  const SCRAMBLE_CHARS = '!<>-_/[]{}—=+*^?#$%&0123456789ABCDEFGHIJKLMNOPQR';
  function escapeHtmlChar(c: string): string {
    return c === '<' ? '&lt;' : c === '>' ? '&gt;' : c === '&' ? '&amp;' : c;
  }

  interface ScrambleEl extends HTMLElement {
    _scrambleTarget?: string;
    _scrambling?: boolean;
  }
  interface ScrambleQ {
    to: string;
    start: number;
    end: number;
    char: string;
    locked: boolean;
  }

  function scrambleText(el: ScrambleEl): void {
    if (el._scrambling) return;
    const target = (el._scrambleTarget ?? el.textContent ?? '').trim();
    if (!target) {
      el.classList.add('scramble-active');
      return;
    }
    el._scrambleTarget = target;
    el._scrambling = true;
    el.classList.add('scramble-active');

    const queue: ScrambleQ[] = [];
    const chars = target.split('');
    for (let i = 0; i < chars.length; i++) {
      const to = chars[i] ?? '';
      const isSpace = to === ' ' || to === '\n';
      queue.push({
        to,
        locked: isSpace,
        start: isSpace ? 0 : i * 0.5,
        end: isSpace ? 0 : i * 0.5 + 14 + Math.random() * 22,
        char: SCRAMBLE_CHARS.charAt(Math.floor(Math.random() * SCRAMBLE_CHARS.length)),
      });
    }
    let frame = 0;
    const tick = (): void => {
      let html = '';
      let complete = 0;
      for (const q of queue) {
        if (q.locked || frame >= q.end) {
          html += escapeHtmlChar(q.to);
          complete++;
        } else {
          if (frame >= q.start && Math.random() < 0.4) {
            q.char = SCRAMBLE_CHARS.charAt(Math.floor(Math.random() * SCRAMBLE_CHARS.length));
          }
          html += '<span class="scramble-dud">' + escapeHtmlChar(q.char) + '</span>';
        }
      }
      el.innerHTML = html;
      if (complete === queue.length) {
        el.textContent = target;
        el._scrambling = false;
      } else {
        frame++;
        requestAnimationFrame(tick);
      }
    };
    tick();
  }

  const scrambleEls = document.querySelectorAll<ScrambleEl>('[data-scramble]');
  if (scrambleEls.length) {
    scrambleEls.forEach((el) => { el._scrambleTarget = el.textContent ?? ''; });
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reduceMotion) {
      scrambleEls.forEach((el) => el.classList.add('scramble-active'));
    } else {
      requestAnimationFrame(() => scrambleEls.forEach((el) => scrambleText(el)));
    }
  }

  // ── CSRF helper ─────────────────────────────────────────────
  function getCsrfToken(): string {
    return (
      document.cookie
        .split(';')
        .map((c) => c.trim())
        .find((c) => c.startsWith('csrf_token='))
        ?.split('=')[1] ?? ''
    );
  }

  function maskToken(token: string): string {
    if (token.length <= 35) return token;
    return `${token.slice(0, 20)}${'·'.repeat(10)}${token.slice(-10)}`;
  }

  // ── DOM refs ────────────────────────────────────────────────
  const form         = document.getElementById('login-form')    as HTMLFormElement;
  const submitBtn    = document.getElementById('submit-btn')    as HTMLButtonElement;
  const btnLabel     = document.getElementById('btn-label')     as HTMLSpanElement;
  const formError    = document.getElementById('form-error')    as HTMLDivElement;
  const loginSection = document.getElementById('login-section') as HTMLElement;
  const tokenSection = document.getElementById('token-section') as HTMLElement;
  const tokenMasked  = document.getElementById('token-masked')  as HTMLElement;
  const copyBtn      = document.getElementById('copy-btn')      as HTMLButtonElement;
  const copyLabel    = document.getElementById('copy-label')    as HTMLSpanElement;
  const copySuccess  = document.getElementById('copy-success')  as HTMLSpanElement;
  const emailInput   = document.getElementById('email')         as HTMLInputElement;
  const passwordInput = document.getElementById('password')    as HTMLInputElement;
  const promptCmd    = document.getElementById('prompt-cmd')    as HTMLSpanElement | null;

  let storedToken = '';

  function setInputError(input: HTMLInputElement, hasError: boolean): void {
    if (hasError) input.classList.add('input-error');
    else input.classList.remove('input-error');
  }

  // ── Login submission ───────────────────────────────────────
  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    const email    = emailInput.value.trim();
    const password = passwordInput.value;

    let hasError = false;
    if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) { setInputError(emailInput, true); hasError = true; }
    else { setInputError(emailInput, false); }
    if (!password) { setInputError(passwordInput, true); hasError = true; }
    else { setInputError(passwordInput, false); }

    if (hasError) {
      formError.textContent = t('entrada inválida. revisa los campos.', 'invalid input. check the fields.');
      formError.classList.remove('hidden');
      return;
    }

    formError.classList.add('hidden');
    submitBtn.disabled = true;
    btnLabel.textContent = t('autenticando...', 'authenticating...');

    try {
      const res = await fetch('/api/login', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'X-CSRF-Token': getCsrfToken(),
        },
        body: JSON.stringify({ email, password }),
      });

      const data = (await res.json()) as { token?: string; error?: string };

      if (res.ok && data.token) {
        storedToken = data.token;
        tokenMasked.textContent = maskToken(storedToken);

        const mcpUrl = 'https://api-mcp.komercia.co/sse';
        function setSnippet(id: string, val: string) {
          const el = document.getElementById(id);
          if (el) el.textContent = val;
        }
        setSnippet('cmd-claude-code', `claude mcp add --transport sse komercia ${mcpUrl} --header "Authorization: Bearer ${storedToken}"`);
        setSnippet('cmd-claudeai-url', mcpUrl);
        setSnippet('cmd-claudeai-auth', `Bearer ${storedToken}`);
        setSnippet('cmd-desktop', JSON.stringify({
          mcpServers: {
            komercia: {
              command: 'mcp-remote',
              args: [mcpUrl, '--header', `Authorization: Bearer ${storedToken}`],
            },
          },
        }, null, 2));

        loginSection.classList.add('hidden');
        tokenSection.classList.remove('hidden');
        if (promptCmd) promptCmd.textContent = 'session_active';
      } else {
        const msg = data.error ?? t('error inesperado. inténtalo de nuevo.', 'unexpected error. try again.');
        formError.textContent = msg.toLowerCase();
        formError.classList.remove('hidden');
        setInputError(passwordInput, true);
      }
    } catch {
      formError.textContent = t('error de red. revisa tu conexión.', 'network error. check your connection.');
      formError.classList.remove('hidden');
    } finally {
      submitBtn.disabled = false;
      btnLabel.textContent = t('autenticar →', 'authenticate →');
    }
  });

  emailInput.addEventListener('input', () => setInputError(emailInput, false));
  passwordInput.addEventListener('input', () => setInputError(passwordInput, false));

  // ── Copy token ──────────────────────────────────────────────
  copyBtn.addEventListener('click', async () => {
    if (!storedToken) return;
    await copyText(storedToken);
    copyLabel.classList.add('hidden');
    copySuccess.classList.remove('hidden');
    setTimeout(() => {
      copyLabel.classList.remove('hidden');
      copySuccess.classList.add('hidden');
    }, 2500);
  });

  // ── Snippet copy buttons ───────────────────────────────────
  document.querySelectorAll<HTMLButtonElement>('.snippet-copy').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const targetId = btn.getAttribute('data-target');
      if (!targetId) return;
      const el = document.getElementById(targetId);
      if (!el) return;
      const text = el.textContent ?? '';
      await copyText(text);
      const orig = btn.textContent;
      btn.textContent = '[ ✓ ]';
      btn.classList.add('copied');
      setTimeout(() => {
        btn.textContent = orig;
        btn.classList.remove('copied');
      }, 1800);
    });
  });

  async function copyText(text: string): Promise<void> {
    try {
      await navigator.clipboard.writeText(text);
    } catch {
      const ta = document.createElement('textarea');
      ta.value = text;
      ta.style.position = 'fixed';
      ta.style.opacity = '0';
      document.body.appendChild(ta);
      ta.select();
      document.execCommand('copy');
      document.body.removeChild(ta);
    }
  }

  // ── Revoke ─────────────────────────────────────────────────
  const revokeBtn    = document.getElementById('revoke-btn')    as HTMLButtonElement | null;
  const revokeStatus = document.getElementById('revoke-status') as HTMLElement | null;

  if (revokeBtn && revokeStatus) {
    revokeBtn.addEventListener('click', async () => {
      if (!storedToken) return;
      if (!window.confirm(t('¿revocar este token? cualquiera que lo esté usando perderá acceso de inmediato.', 'revoke this token? anyone using it will lose access immediately.'))) return;

      revokeBtn.disabled = true;
      revokeStatus.textContent = t('revocando...', 'revoking...');
      revokeStatus.classList.remove('hidden');

      try {
        const res = await fetch('/api/sessions/revoke', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'X-CSRF-Token': getCsrfToken(),
          },
          body: JSON.stringify({ token: storedToken }),
        });

        const data = (await res.json()) as { revoked?: boolean; error?: string };

        if (res.ok && data.revoked) {
          revokeStatus.textContent = t('token revocado. redirigiendo...', 'token revoked. redirecting...');
          setTimeout(() => { window.location.href = '/'; }, 1500);
        } else {
          revokeStatus.textContent = (data.error ?? t('error al revocar.', 'revocation failed.')).toLowerCase();
          revokeBtn.disabled = false;
        }
      } catch {
        revokeStatus.textContent = t('error de red.', 'network error.');
        revokeBtn.disabled = false;
      }
    });
  }
</script>
