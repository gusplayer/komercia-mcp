    gap: 12px;
    flex-wrap: wrap;
  }
  .examples-row .small { font-size: var(--fs-base); margin: 0; }
  .btn-examples {
    background: transparent;
    color: var(--c-fg);
    border: 1px solid var(--c-border);
    border-radius: var(--r);
    height: 36px;
    padding: 0 14px;
    font-family: inherit;
    font-size: var(--fs-base);
    letter-spacing: 0.24px;
    cursor: pointer;
    transition: border-color 150ms, background 150ms;
  }
  .btn-examples:hover { border-color: var(--c-fg); background: var(--c-surface); }

  /* Token-lifecycle FAQ */
  .token-faq {
    background: var(--c-surface);
    border: 1px solid var(--c-border);
    border-radius: var(--r);
    padding: 16px 19px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .faq-q {
    margin: 0;
    color: var(--c-fg);
    font-size: var(--fs-base);
  }
  .faq-q::before {
    content: '? ';
    color: var(--c-muted);
  }
  .faq-a {
    margin: 0 0 8px;
    color: var(--c-fg);
    font-size: var(--fs-sm);
    line-height: 1.5;
    opacity: 0.85;
  }
  .faq-a:last-of-type { margin-bottom: 0; }

  .snippet {
    display: flex;
    align-items: center;
    gap: 8px;
    background: var(--c-surface);
    border-radius: var(--r);
    padding: 12px 16px;
  }
  .snippet code {
    flex: 1;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    color: var(--c-fg);
    font-family: inherit;
    font-size: var(--fs-md);
    user-select: all;
  }
  .snippet-block code {
    white-space: pre;
    overflow-x: auto;
    overflow-y: hidden;
    text-overflow: clip;
    -webkit-overflow-scrolling: touch;
  }
  .snippet-block { align-items: flex-start; }
  .snippet-block .btn-mini { margin-top: 2px; }

  /* ── Key/value rows ──────────────────────────────────── */
  .kv {
    display: grid;
    grid-template-columns: 140px 1fr auto;
    align-items: center;
    gap: 12px;
    background: var(--c-surface);
