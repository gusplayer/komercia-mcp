    display: flex;
    gap: 24px;
    flex: 1;
  }
  .topbar-actions {
    display: flex;
    align-items: center;
    gap: 16px;
    flex-shrink: 0;
  }
  .link-muted {
    color: var(--c-muted);
    text-decoration: none;
    font-size: 16px;
    transition: color 150ms;
  }
  .link-muted:hover { color: var(--c-fg); }
  /* Shared sizing — every topbar button is exactly 36px tall, box-sized */
  .btn-pill,
  .btn-ghost-pill {
    height: 36px;
    box-sizing: border-box;
    display: inline-flex;
    align-items: center;
