    // ── Text scramble (terminal decryption effect) ────────
    var SCRAMBLE_CHARS = '!<>-_/[]{}—=+*^?#$%&0123456789ABCDEFGHIJKLMNOPQR';

    function escapeHtml(c) {
      return c === '<' ? '&lt;' : c === '>' ? '&gt;' : c === '&' ? '&amp;' : c;
    }

    function scrambleText(el) {
      if (!el || el._scrambling) return;
      var target = (el._scrambleTarget || el.textContent || '').trim();
      if (!target) { el.classList.add('scramble-active'); return; }
      el._scrambleTarget = target;
      el._scrambling = true;
      el.classList.add('scramble-active');

      var queue = [];
      for (var i = 0; i < target.length; i++) {
        var to = target[i];
        if (to === ' ' || to === '\n' || to === ' ') {
          queue.push({ to: to, locked: true });
        } else {
          var start = i * 0.5;
          var end = start + 14 + Math.random() * 22;
          queue.push({
            to: to,
            start: start,
            end: end,
            char: SCRAMBLE_CHARS.charAt(Math.floor(Math.random() * SCRAMBLE_CHARS.length)),
          });
        }
      }

      var frame = 0;
      function tick() {
        var html = '';
        var complete = 0;
        for (var i = 0; i < queue.length; i++) {
          var q = queue[i];
          if (q.locked || frame >= q.end) {
            html += escapeHtml(q.to);
            complete++;
          } else if (frame >= q.start) {
            if (Math.random() < 0.4) {
              q.char = SCRAMBLE_CHARS.charAt(Math.floor(Math.random() * SCRAMBLE_CHARS.length));
            }
            html += '<span class="scramble-dud">' + escapeHtml(q.char) + '</span>';
          } else {
            html += '<span class="scramble-dud">' + escapeHtml(q.char) + '</span>';
          }
        }
        el.innerHTML = html;
        if (complete === queue.length) {
          el.textContent = target;
          el._scrambling = false;
        } else {
          frame++;
          requestAnimationFrame(tick);
        }
      }
      tick();
    }

