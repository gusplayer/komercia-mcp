---
// index.astro — Landing page. 099 / terminal aesthetic, bilingual ES/EN.
import Base from '../layouts/Base.astro';

const tools = [
  { name: 'get_store_info',        descEs: 'nombre, plan, dominio',          descEn: 'store name, plan, domain' },
  { name: 'export_products',       descEs: 'csv · json · shopify · woo',     descEn: 'csv · json · shopify · woo' },
  { name: 'export_orders',         descEs: 'historial completo de ventas',   descEn: 'full sales history' },
  { name: 'export_customers',      descEs: 'contactos + direcciones',        descEn: 'contacts + addresses' },
  { name: 'export_categories',     descEs: 'árbol de jerarquía',             descEn: 'hierarchy tree' },
  { name: 'list_payment_gateways', descEs: 'métodos configurados',           descEn: 'configured methods' },
];

const examples = [
  { es: '¿cuántos productos activos tengo?',                       en: 'how many active products do i have?' },
  { es: 'muéstrame los ingresos del último mes con totales',       en: 'show me last month\'s revenue with totals' },
  { es: 'exporta toda mi lista de clientes en csv',                en: 'export my full customer list as csv' },
  { es: '¿qué productos tienen poco stock?',                       en: 'which products are running low on stock?' },
  { es: 'exporta mi catálogo en formato shopify',                  en: 'export my catalog in shopify format' },
  { es: '¿qué métodos de pago tengo configurados?',                en: 'what payment methods are configured?' },
];
---

<Base
  title="komercia/mcp — los datos de tu tienda, en lenguaje natural"
  description="Servidor MCP oficial de Komercia. Pregúntale a Claude sobre tu tienda — productos, ventas, clientes, inventario. Solo lectura, open source."
>
  <div class="page">

    <!-- ── Top bar ─────────────────────────────────────── -->
    <header class="topbar">
      <a href="/" class="brand" aria-label="komercia mcp home">[komercia/mcp]</a>

      <nav class="topnav">
        <a href="#features" class="link-muted" data-t-es="herramientas" data-t-en="features">herramientas</a>
        <a href="#install" class="link-muted" data-t-es="instalación" data-t-en="install">instalación</a>
        <a href="#examples" class="link-muted" data-t-es="ejemplos" data-t-en="examples">ejemplos</a>
      </nav>

      <div class="topbar-actions">
        <a href="/sign-in" class="btn-pill" data-t-es="obtener_token →" data-t-en="get_token →">obtener_token →</a>
        <button id="lang-toggle" class="btn-pill btn-lang" aria-label="Cambiar idioma" title="Cambiar idioma / Toggle language">
          <span class="lang-opt" data-lang="es">ES</span>
          <span class="lang-sep" aria-hidden="true">⇄</span>
          <span class="lang-opt" data-lang="en">EN</span>
        </button>
        <a href="https://github.com/gusplayer/komercia-mcp" target="_blank" rel="noopener noreferrer" class="btn-pill btn-icon" aria-label="Ver repositorio en GitHub" title="Ver repositorio en GitHub">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
          </svg>
        </a>
      </div>
    </header>

    <main class="main">

      <!-- ── Hero ──────────────────────────────────────── -->
      <section class="hero">
        <div class="prompt">
          <span class="muted">user@komercia ~$</span>
          <span class="cmd">./mcp.connect</span><span class="caret">_</span>
        </div>

        <h1 class="h1">
          <span data-t-es="los datos de tu tienda," data-t-en="your store data,">los datos de tu tienda,</span><br />
          <span class="muted" data-t-es="en lenguaje natural." data-t-en="in natural language.">en lenguaje natural.</span>
        </h1>

        <p class="lede" data-t-es="el servidor mcp oficial para komercia. pregúntale a claude lo que sea sobre tu tienda — productos, ventas, clientes, inventario — sin escribir una línea de código." data-t-en="the official mcp server for komercia. ask claude anything about your store — products, orders, customers, inventory — without writing a line of code.">
          el servidor mcp oficial para komercia. pregúntale a claude lo que sea sobre tu tienda — productos, ventas, clientes, inventario — sin escribir una línea de código.
        </p>

        <div class="cta-row">
          <a href="/sign-in" class="btn-primary" data-t-es="obtener_token →" data-t-en="get_token →">obtener_token →</a>
          <a href="#install" class="btn-ghost" data-t-es="cómo_funciona" data-t-en="how_it_works">cómo_funciona</a>
        </div>

        <ul class="trust">
          <li><span class="dot">●</span> <span data-t-es="11 herramientas" data-t-en="11 tools">11 herramientas</span></li>
          <li><span class="dot">●</span> <span data-t-es="solo lectura" data-t-en="read-only">solo lectura</span></li>
          <li><span class="dot">●</span> <span>open source</span></li>
          <li><span class="dot">●</span> <span data-t-es="sin tarjeta" data-t-en="no credit card">sin tarjeta</span></li>
        </ul>
      </section>

      <div class="divider"></div>

      <!-- ── Features ──────────────────────────────────── -->
      <section id="features" class="block">
        <div class="block-header">
          <h2 class="h2" data-t-es="&gt; herramientas" data-t-en="&gt; features">&gt; herramientas</h2>
          <p class="block-hint" data-t-es="6 de 11 herramientas mcp. todas de solo lectura." data-t-en="6 of 11 mcp tools shown. all read-only.">6 de 11 herramientas mcp. todas de solo lectura.</p>
        </div>

        <div class="grid">
          {tools.map((t) => (
            <article class="tool-card">
              <code class="tool-name">{t.name}</code>
              <p class="tool-desc" data-t-es={t.descEs} data-t-en={t.descEn}>{t.descEs}</p>
            </article>
          ))}
        </div>

        <a href="/#features" class="link-arrow" data-t-es="ver las 11 herramientas →" data-t-en="see all 11 tools →">ver las 11 herramientas →</a>
      </section>

      <div class="divider"></div>

      <!-- ── Install ───────────────────────────────────── -->
      <section id="install" class="block">
        <div class="block-header">
          <h2 class="h2" data-t-es="&gt; instalación" data-t-en="&gt; install">&gt; instalación</h2>
          <p class="block-hint" data-t-es="tres pasos. cinco minutos. sin código." data-t-en="three steps. five minutes. no code.">tres pasos. cinco minutos. sin código.</p>
        </div>

        <ol class="steps">
          <li class="step">
            <span class="step-num">[01]</span>
            <div class="step-body">
              <strong>get_token</strong>
              <p class="step-desc" data-t-es="inicia sesión con tus credenciales de komercia. token de solo lectura, válido 6 meses." data-t-en="log in with your komercia credentials. token is read-only, valid 6 months.">inicia sesión con tus credenciales de komercia. token de solo lectura, válido 6 meses.</p>
              <a href="/sign-in" class="link-arrow">/sign-in →</a>
            </div>
          </li>

          <li class="step">
            <span class="step-num">[02]</span>
            <div class="step-body">
              <strong>connect_client</strong>
              <p class="step-desc" data-t-es="elige uno. claude code es el más simple — un solo comando." data-t-en="pick one. claude code is the simplest — single command.">elige uno. claude code es el más simple — un solo comando.</p>
              <div class="code-line">
                <code>claude mcp add --transport sse komercia https://api-mcp.komercia.co/sse --header "Authorization: Bearer &lt;TOKEN&gt;"</code>
              </div>
              <p class="step-desc-sm" data-t-es="también funciona con claude.ai integrations, claude desktop, cursor." data-t-en="also works with claude.ai integrations, claude desktop, cursor.">también funciona con claude.ai integrations, claude desktop, cursor.</p>
            </div>
          </li>

          <li class="step">
            <span class="step-num">[03]</span>
            <div class="step-body">
              <strong>ask_anything</strong>
              <p class="step-desc" data-t-es="abre un chat de claude. pregunta en lenguaje natural. claude llama a las herramientas mcp y responde con tus datos reales." data-t-en="open a claude chat. ask in plain english. claude calls the mcp tools and answers with your real data.">abre un chat de claude. pregunta en lenguaje natural. claude llama a las herramientas mcp y responde con tus datos reales.</p>
            </div>
          </li>
        </ol>
      </section>

      <div class="divider"></div>

      <!-- ── Examples ──────────────────────────────────── -->
      <section id="examples" class="block">
        <div class="block-header">
          <h2 class="h2" data-t-es="&gt; ejemplos" data-t-en="&gt; examples">&gt; ejemplos</h2>
          <p class="block-hint" data-t-es="prompts que funcionan hoy. pega en claude." data-t-en="prompts that work today. paste into claude.">prompts que funcionan hoy. pega en claude.</p>
        </div>

        <ul class="examples">
          {examples.map((q) => (
            <li class="example">
              <span class="prompt-mark">&gt;</span>
              <span data-t-es={q.es} data-t-en={q.en}>{q.es}</span>
            </li>
          ))}
        </ul>

        <a href="/recetas" class="link-arrow" data-t-es="18 prompts más en /recetas →" data-t-en="18 more prompts at /recetas →">18 prompts más en /recetas →</a>
      </section>

      <div class="divider"></div>

      <!-- ── Final CTA ─────────────────────────────────── -->
      <section class="block final">
        <p class="ready" data-t-es="¿listo?" data-t-en="ready?">¿listo?</p>
        <a href="/sign-in" class="btn-primary btn-primary-lg" data-t-es="obtener_token →" data-t-en="get_token →">obtener_token →</a>
        <p class="muted small" data-t-es="es gratis. 30 segundos. tú guardas el token." data-t-en="it's free. 30 seconds. you keep the token.">es gratis. 30 segundos. tú guardas el token.</p>
      </section>

    </main>

    <!-- ── Footer ────────────────────────────────────── -->
    <footer class="bottom-bar">
      <span class="muted">komercia/mcp v0.1</span>
      <span class="dot-sep">·</span>
      <a href="/uso" class="link-muted">/uso</a>
      <span class="dot-sep">·</span>
      <a href="/recetas" class="link-muted">/recetas</a>
      <span class="dot-sep">·</span>
      <a href="https://github.com/gusplayer/komercia-mcp" target="_blank" rel="noopener noreferrer" class="link-muted">source</a>
    </footer>
  </div>
</Base>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&display=swap');

  .page {
    --c-bg: #000000;
    --c-fg: #ffffff;
    --c-surface: #1d1d1d;
    --c-border: #383838;
    --c-muted: #888888;
    --r: 10px;

    min-height: 100vh;
    background: var(--c-bg);
    color: var(--c-fg);
    font-family: 'Space Mono', ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 16px;
    line-height: 1.4;
    letter-spacing: 0.24px;
    font-feature-settings: 'zero';
    display: flex;
    flex-direction: column;
  }
  :global(body:has(.page)) { background: #000000; }

  /* ── Top bar ─────────────────────────────────────────── */
  .topbar {
    display: flex;
    align-items: center;
    gap: 24px;
    padding: 19px 32px;
    border-bottom: 1px solid var(--c-border);
    position: sticky;
    top: 0;
    background: rgba(0, 0, 0, 0.85);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    z-index: 10;
  }
  .brand {
    color: var(--c-fg);
    text-decoration: none;
    font-size: 16px;
    flex-shrink: 0;
  }
  .brand:hover { color: var(--c-muted); }
  .topnav {
    display: flex;
    gap: 24px;
    flex: 1;
  }
  .topbar-actions {
    display: flex;
    align-items: center;
    gap: 16px;
    flex-shrink: 0;
  }
  .link-muted {
    color: var(--c-muted);
    text-decoration: none;
    font-size: 16px;
    transition: color 150ms;
  }
  .link-muted:hover { color: var(--c-fg); }
  .btn-pill {
    background: var(--c-fg);
    color: var(--c-bg);
    text-decoration: none;
    border: none;
    border-radius: var(--r);
    padding: 8px 16px;
    font-size: 16px;
    transition: background 150ms;
    white-space: nowrap;
    cursor: pointer;
  }
  .btn-pill:hover { background: var(--c-muted); }

  /* Icon-only pill (GitHub, etc.) — square with centered SVG */
  .btn-pill.btn-icon {
    padding: 8px;
    line-height: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  .btn-pill.btn-icon svg { display: block; }

  /* ── Lang toggle — shares .btn-pill base, adds toggle state colors */
  .btn-lang {
    font-family: inherit;
    letter-spacing: 0.24px;
    cursor: pointer;
    display: inline-flex;
    flex-direction: row;
    align-items: center;
    gap: 8px;
    white-space: nowrap;
    line-height: 1;
  }
  .btn-lang .lang-opt {
    color: var(--c-muted);
    transition: color 150ms;
  }
  .btn-lang .lang-opt.active {
    color: var(--c-bg);
  }
  .btn-lang .lang-sep {
    color: var(--c-muted);
    font-size: 12px;
  }

  /* ── Main ────────────────────────────────────────────── */
  .main {
    flex: 1;
    width: 100%;
    max-width: 880px;
    margin: 0 auto;
    padding: 48px 32px;
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  /* ── Prompt + caret ──────────────────────────────────── */
  .prompt {
    font-size: 16px;
    color: var(--c-fg);
    margin: 0;
  }
  .prompt .muted { color: var(--c-muted); }
  .prompt .cmd { color: var(--c-fg); margin-left: 8px; }
  .caret {
    color: var(--c-fg);
    margin-left: 2px;
    animation: blink 1s steps(1) infinite;
  }
  @keyframes blink { 50% { opacity: 0; } }

  /* ── Hero ────────────────────────────────────────────── */
  .hero {
    display: flex;
    flex-direction: column;
    gap: 26px;
    padding: 32px 0;
  }
  .h1 {
    font-size: 32px;
    line-height: 1.2;
    font-weight: 400;
    letter-spacing: 0.24px;
    color: var(--c-fg);
    margin: 0;
  }
  .h1 .muted { color: var(--c-muted); }
  .lede {
    font-size: 16px;
    color: var(--c-muted);
    line-height: 1.5;
    margin: 0;
    max-width: 580px;
  }
  .cta-row {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }
  .trust {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 26px;
    font-size: 16px;
    color: var(--c-muted);
  }
  .trust li { display: flex; align-items: center; gap: 8px; }
  .trust .dot { color: var(--c-fg); }

  /* ── Buttons ─────────────────────────────────────────── */
  .btn-primary {
    background: var(--c-fg);
    color: var(--c-bg);
    border: none;
    border-radius: var(--r);
    font-family: inherit;
    font-size: 16px;
    padding: 16px 26px;
    cursor: pointer;
    text-decoration: none;
    display: inline-block;
    transition: background 150ms;
    white-space: nowrap;
  }
  .btn-primary:hover { background: var(--c-muted); }
  .btn-primary-lg { padding: 19px 32px; }

  .btn-ghost {
    background: transparent;
    color: var(--c-fg);
    border: 1px solid var(--c-border);
    border-radius: var(--r);
    font-family: inherit;
    font-size: 16px;
    padding: 16px 26px;
    cursor: pointer;
    text-decoration: none;
    display: inline-block;
    transition: border-color 150ms;
    white-space: nowrap;
  }
  .btn-ghost:hover { border-color: var(--c-fg); }

  /* ── Dividers ────────────────────────────────────────── */
  .divider {
    height: 1px;
    background: var(--c-border);
  }

  /* ── Block (section) ─────────────────────────────────── */
  .block {
    display: flex;
    flex-direction: column;
    gap: 26px;
  }
  /* Anchor-scroll offset so sticky topbar doesn't cover section titles */
  #features,
  #install,
  #examples {
    scroll-margin-top: 90px;
  }
  .block-header {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .h2 {
    font-size: 16px;
    font-weight: 400;
    color: var(--c-fg);
    margin: 0;
    letter-spacing: 0.24px;
  }
  .block-hint {
    font-size: 16px;
    color: var(--c-muted);
    margin: 0;
  }

  /* ── Tools grid ──────────────────────────────────────── */
  .grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 16px;
  }
  @media (min-width: 768px) {
    .grid { grid-template-columns: repeat(3, minmax(0, 1fr)); }
  }
  .tool-card {
    background: var(--c-surface);
    border-radius: var(--r);
    padding: 19px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    transition: outline-color 150ms;
    outline: 1px solid transparent;
  }
  .tool-card:hover { outline-color: var(--c-border); }
  .tool-name {
    color: var(--c-fg);
    font-size: 16px;
    font-family: inherit;
    overflow-wrap: anywhere;
  }
  .tool-desc {
    color: var(--c-muted);
    font-size: 16px;
    margin: 0;
    line-height: 1.4;
  }

  /* ── Steps (install) ─────────────────────────────────── */
  .steps {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 26px;
  }
  .step {
    display: grid;
    grid-template-columns: 48px 1fr;
    gap: 16px;
    align-items: flex-start;
  }
  .step-num {
    color: var(--c-muted);
    font-size: 16px;
    padding-top: 1px;
  }
  .step-body {
    display: flex;
    flex-direction: column;
    gap: 8px;
    min-width: 0;
  }
  .step-body strong {
    color: var(--c-fg);
    font-weight: 400;
    font-size: 16px;
  }
  .step-desc {
    color: var(--c-muted);
    font-size: 16px;
    margin: 0;
    line-height: 1.5;
  }
  .step-desc-sm {
    color: var(--c-muted);
    font-size: 16px;
    margin: 0;
  }
  .code-line {
    background: var(--c-surface);
    border-radius: var(--r);
    padding: 16px 19px;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }
  .code-line code {
    color: var(--c-fg);
    font-size: 16px;
    font-family: inherit;
    white-space: nowrap;
  }

  /* ── Examples list ───────────────────────────────────── */
  .examples {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
    background: var(--c-surface);
    border-radius: var(--r);
    padding: 19px;
  }
  .example {
    display: flex;
    gap: 12px;
    align-items: flex-start;
    color: var(--c-fg);
    font-size: 16px;
    line-height: 1.4;
  }
  .prompt-mark {
    color: var(--c-muted);
    flex-shrink: 0;
  }

  /* ── Final CTA ───────────────────────────────────────── */
  .final {
    align-items: flex-start;
    padding: 32px 0;
  }
  .ready {
    font-size: 16px;
    color: var(--c-muted);
    margin: 0;
  }
  .small { font-size: 16px; }

  /* ── Link with arrow ─────────────────────────────────── */
  .link-arrow {
    color: var(--c-fg);
    text-decoration: none;
    font-size: 16px;
    border-bottom: 1px solid var(--c-border);
    padding-bottom: 2px;
    align-self: flex-start;
    transition: border-color 150ms;
  }
  .link-arrow:hover { border-color: var(--c-fg); }

  /* ── Helpers ─────────────────────────────────────────── */
  .muted { color: var(--c-muted); }

  /* ── Bottom bar ──────────────────────────────────────── */
  .bottom-bar {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 19px 32px;
    border-top: 1px solid var(--c-border);
    font-size: 16px;
    flex-wrap: wrap;
  }
  .bottom-bar .dot-sep { color: var(--c-border); }

  /* ── Responsive ──────────────────────────────────────── */
  @media (max-width: 768px) {
    .topbar { padding: 14px 16px; gap: 12px; }
    .topnav { display: none; }
    .topbar-actions { gap: 12px; }
    .main { padding: 32px 16px; gap: 26px; }
    .hero { padding: 16px 0; gap: 19px; }
    .h1 { font-size: 26px; }
    .trust { gap: 16px; }
    .bottom-bar { padding: 14px 16px; }
    .step { grid-template-columns: 40px 1fr; gap: 12px; }
    #features, #install, #examples { scroll-margin-top: 80px; }
  }

  @media (max-width: 480px) {
    .topbar { padding: 12px 14px; gap: 8px; }
    .brand { font-size: 14px; }
    .btn-pill { padding: 8px 12px; font-size: 14px; }
    .btn-lang { gap: 6px; }
    .btn-lang .lang-sep { font-size: 10px; }
    .topbar-actions { gap: 8px; }
    .main { padding: 24px 14px; }
    .h1 { font-size: 22px; line-height: 1.25; }
    .lede { font-size: 15px; }
    .grid { grid-template-columns: 1fr; }
    .btn-primary, .btn-ghost { padding: 14px 22px; font-size: 15px; }
    .btn-primary-lg { padding: 16px 26px; }
    .cta-row { gap: 12px; }
    .cta-row .btn-primary, .cta-row .btn-ghost { flex: 1; text-align: center; min-width: 0; }
    .bottom-bar { padding: 14px; row-gap: 8px; }
  }
</style>

<script is:inline>
  (function () {
    function applyLang(lang) {
      document.documentElement.lang = lang;
      var els = document.querySelectorAll('[data-t-es]');
      for (var i = 0; i < els.length; i++) {
        var el = els[i];
        var text = lang === 'en' ? el.getAttribute('data-t-en') : el.getAttribute('data-t-es');
        if (text !== null) el.textContent = text;
      }
      var opts = document.querySelectorAll('.lang-opt');
      for (var j = 0; j < opts.length; j++) {
        var opt = opts[j];
        if (opt.getAttribute('data-lang') === lang) opt.classList.add('active');
        else opt.classList.remove('active');
      }
    }

    var saved = localStorage.getItem('lang');
    var current = saved === 'en' ? 'en' : 'es';
    applyLang(current);

    var btn = document.getElementById('lang-toggle');
    if (btn) {
      btn.addEventListener('click', function () {
        current = current === 'es' ? 'en' : 'es';
        try { localStorage.setItem('lang', current); } catch (e) {}
        applyLang(current);
      });
    }
  })();
</script>
