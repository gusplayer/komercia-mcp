---
import Base from '../layouts/Base.astro';
import AnnouncementBanner from '../components/AnnouncementBanner.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import ChatMock from '../components/ChatMock.astro';
import ScrollAnimate from '../components/ScrollAnimate.astro';
import Button from '../components/Button.astro';
import Card from '../components/Card.astro';
import Badge from '../components/Badge.astro';
import SectionHeading from '../components/SectionHeading.astro';
import Container from '../components/Container.astro';
import Section from '../components/Section.astro';
import GridPattern from '../components/GridPattern.astro';
import IconBox from '../components/IconBox.astro';

// Tools catalog data — keeps JSX clean and lets us stagger animations.
const tools = [
  { code: 'get_store_info',              desc: 'Info general: nombre, plan, dominio y estado de tu tienda',         prompt: '"¿Cuáles son los datos de mi tienda?"' },
  { code: 'validate_komercia_apis',      desc: 'Verifica que las APIs de Komercia estén disponibles',                prompt: '"¿Puedo conectarme a mi tienda?"' },
  { code: 'export_products',             desc: 'Catálogo en CSV, JSON, formato Shopify o WooCommerce',               prompt: '"Exporta mis productos a Shopify"' },
  { code: 'export_orders',               desc: 'Historial completo de ventas en CSV',                                prompt: '"Dame mis ventas del último año"' },
  { code: 'export_customers',            desc: 'Lista de clientes con direcciones e historial',                      prompt: '"Exporta todos mis clientes"' },
  { code: 'export_categories',           desc: 'Árbol de categorías de tu catálogo',                                 prompt: '"Muéstrame mis categorías"' },
  { code: 'export_inventory_movements',  desc: 'Historial de movimientos de stock',                                  prompt: '"¿Cómo cambió mi inventario este mes?"' },
  { code: 'export_theme_config',         desc: 'Configuración de diseño: colores, fuentes, tema',                    prompt: '"Guarda la config de mi tema"' },
  { code: 'list_payment_gateways',       desc: 'Pasarelas de pago activas y métodos configurados',                   prompt: '"¿Qué métodos de pago tengo?"' },
  { code: 'download_media_archive',      desc: 'ZIP con todas las imágenes de tu tienda',                            prompt: '"Descarga todas mis fotos de productos"' },
  { code: 'suggest_alternative_platforms', desc: 'Análisis de qué plataforma conviene para migrar',                  prompt: '"¿A qué plataforma me mudo?"' },
];

// FAQ data — same approach for staggered reveals.
// Updated: replaced the "Komercia closing" question and the programming-skill answer
// to reflect the new positioning (AI integration, not survival migration).
const faqs = [
  { q: '¿Qué es exactamente este MCP?',                       a: 'Es el conector oficial de Komercia para Claude.ai. Te permite exportar y consultar todos los datos de tu tienda conversando en lenguaje natural, sin escribir código.' },
  { q: '¿Es gratis?',                                          a: 'Sí, completamente gratis. Solo necesitas una cuenta activa de Komercia y una cuenta de Claude.ai.' },
  { q: '¿Es seguro? ¿Qué hacen con mi contraseña?',            a: 'Tu contraseña se usa una sola vez para autenticarte y nunca se almacena. Generamos un token JWT de solo lectura. El código es open source y auditable en GitHub.' },
  { q: '¿Qué datos puedo exportar?',                           a: 'Productos con variantes e imágenes, órdenes históricas, clientes con direcciones, categorías, configuración de tema, métodos de pago, movimientos de inventario y más.' },
  { q: '¿En qué formatos puedo exportar?',                     a: 'CSV genérico, JSON estructurado, formato Shopify y formato WooCommerce. Claude puede transformar los datos a cualquier otro formato que necesites.' },
  { q: '¿Puedo migrar a otra plataforma con esto?',            a: 'Sí, es uno de sus usos principales. Genera exports listos para Shopify, Tiendanube, WooCommerce, VTEX y otras plataformas.' },
  { q: '¿Necesito saber programar?',                           a: 'No. Si sabes hacer login y copiar/pegar un token, puedes usarlo. Toda la interacción con Claude es en español natural — no escribes queries, no usas formularios.' },
  { q: '¿Cuánto dura mi token de acceso?',                     a: '6 meses. Después puedes generar uno nuevo desde esta misma página.' },
  { q: '¿Komercia tiene acceso a mis datos cuando uso Claude?', a: 'No. Komercia MCP es un puente de solo lectura: cuando le pides algo a Claude, el MCP consulta los endpoints estándar de Komercia con tu token, y devuelve el resultado a Claude. No almacenamos copia de tus datos en ningún momento.' },
  { q: '¿Dónde reporto bugs o sugiero mejoras?',               a: 'En GitHub: abre un issue en el repositorio. Es open source y bienvenidas las contribuciones.' },
];

// Reusable left-label inline styles for the categorized "what you export" / tools sections.
const groupTitleStyle = 'font-family: var(--font-sans); font-size: 20px; font-weight: 600; color: var(--color-ink-blue); line-height: 1.3; letter-spacing: -0.36px; margin: 0;';
const groupDescStyle  = 'font-family: var(--font-sans); font-size: 14px; color: var(--color-slate-text); line-height: 1.5; margin-top: 8px;';
---

<Base
  title="Komercia MCP — Tu tienda Komercia, en lenguaje natural"
  description="El conector oficial de Komercia para Claude.ai. Consulta ventas, automatiza reportes y conversa con tus datos sin escribir código."
>
  <!-- ─── Section 1: Announcement Banner ─────────────────────────── -->
  <AnnouncementBanner />

  <!-- ─── Section 2: Navbar ──────────────────────────────────────── -->
  <Navbar />

  <!-- ─── Section 3: Hero (white + grid pattern, Column-faithful) ─ -->
  <section style="position: relative; padding: 96px 0 64px; background: var(--color-ghost-white); overflow: hidden;">
    <GridPattern variant="subtle" />

    <Container>
      <div class="grid lg:grid-cols-12 items-start" style="gap: 48px; position: relative; z-index: 1;">

        <!-- Left col-span-7 — copy + CTAs -->
        <div class="lg:col-span-7">
          <div class="eyebrow-badge" data-animate>
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
            MCP OFICIAL DE KOMERCIA
          </div>

          <h1 class="heading-bicolor lg" data-animate data-animate-delay="100" style="margin-top: 24px;">
            Tu tienda Komercia, <span class="muted">en lenguaje natural.</span>
          </h1>

          <p
            style="font-family: var(--font-sans); font-weight: 400; font-size: 18px; line-height: 1.5; color: var(--color-slate-text); max-width: 32rem; margin-top: 24px;"
            data-animate
            data-animate-delay="200"
          >
            El conector oficial de Komercia para Claude.ai. Consulta ventas, automatiza reportes y conversa con tus datos — sin escribir una línea de código.
          </p>

          <div class="flex flex-wrap" style="gap: 12px; margin-top: 32px;" data-animate data-animate-delay="300">
            <Button variant="primary" size="lg" href="/sign-in">Obtener mi token gratis</Button>
            <Button variant="secondary" size="lg" href="/uso">Ver cómo funciona →</Button>
          </div>

          <!-- Trust line under CTAs -->
          <div
            class="flex flex-wrap items-center"
            style="gap: 20px; margin-top: 32px;"
            data-animate
            data-animate-delay="400"
          >
            <div class="flex items-center" style="gap: 6px;">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" style="color: var(--color-success-moss); flex-shrink: 0;">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
              <span style="font-family: var(--font-sans); font-weight: 400; font-size: 13px; color: var(--color-slate-text);">Sin tarjeta de crédito</span>
            </div>
            <div class="flex items-center" style="gap: 6px;">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" style="color: var(--color-success-moss); flex-shrink: 0;">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
              <span style="font-family: var(--font-sans); font-weight: 400; font-size: 13px; color: var(--color-slate-text);">Solo lectura</span>
            </div>
            <div class="flex items-center" style="gap: 6px;">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" style="color: var(--color-success-moss); flex-shrink: 0;">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
              <span style="font-family: var(--font-sans); font-weight: 400; font-size: 13px; color: var(--color-slate-text);">Open source</span>
            </div>
          </div>
        </div>

        <!-- Right col-span-5 — chat preview -->
        <div class="lg:col-span-5 flex justify-center" data-animate data-animate-delay="400">
          <ChatMock />
        </div>

      </div>
    </Container>
  </section>

  <!-- ─── Section 4: Stats row (fog-gray, Column-style) ──────────── -->
  <section style="background: var(--color-fog-gray); border-top: 1px solid var(--color-steel-gray); border-bottom: 1px solid var(--color-steel-gray); padding: 64px 0;">
    <Container>
      <div class="grid grid-cols-2 md:grid-cols-4" style="gap: 32px;">
        <div data-animate>
          <p class="stat-number">11</p>
          <p class="stat-label">Herramientas MCP listas para usar con Claude</p>
        </div>
        <div data-animate data-animate-delay="100">
          <p class="stat-number">100%</p>
          <p class="stat-label">Código open source y auditable en GitHub</p>
        </div>
        <div data-animate data-animate-delay="200">
          <p class="stat-number">3 min</p>
          <p class="stat-label">Tiempo de instalación, sin código</p>
        </div>
        <div data-animate data-animate-delay="300">
          <p class="stat-number">0</p>
          <p class="stat-label">Credenciales almacenadas en texto plano</p>
        </div>
      </div>
    </Container>
  </section>

  <!-- ─── Section 5: Dark Plum Punch (full-width, raw section) ───── -->
  <section style="background: var(--color-deep-plum); padding: 96px 0;">
    <Container>
      <div class="grid lg:grid-cols-12" style="gap: 48px; align-items: center;">

        <!-- Left col: copy + mini-feature pills -->
        <div class="lg:col-span-5">
          <span
            class="eyebrow-badge"
            style="background: rgba(255,255,255,0.05); border-color: rgba(255,255,255,0.15); color: rgba(255,255,255,0.8);"
            data-animate
          >
            INTEGRACIÓN OFICIAL
          </span>

          <h2
            class="heading-bicolor"
            style="color: var(--color-ghost-white); margin-top: 16px;"
            data-animate
            data-animate-delay="100"
          >
            Una integración. <span style="color: rgba(255,255,255,0.6);">Todo el poder de Claude.</span>
          </h2>

          <p
            style="font-family: var(--font-sans); font-weight: 400; font-size: 16px; line-height: 1.5; color: rgba(248, 246, 240, 0.75); max-width: 28rem; margin-top: 16px;"
            data-animate
            data-animate-delay="200"
          >
            Conecta tu tienda Komercia a Claude.ai en 3 minutos. Desde ese momento, Claude tiene acceso de solo lectura a tus productos, órdenes, clientes e inventario — para responder, analizar y exportar lo que necesites.
          </p>

          <!-- Mini-feature pills 2x2 -->
          <div class="grid grid-cols-2" style="gap: 16px; margin-top: 24px;">
            <div data-animate data-animate-delay="300">
              <p style="font-family: var(--font-sans); font-weight: 600; font-size: 14px; color: var(--color-ghost-white);">11 herramientas</p>
              <p style="font-family: var(--font-sans); font-weight: 400; font-size: 12px; color: rgba(248, 246, 240, 0.6); margin-top: 4px;">Una para cada tipo de dato</p>
            </div>
            <div data-animate data-animate-delay="350">
              <p style="font-family: var(--font-sans); font-weight: 600; font-size: 14px; color: var(--color-ghost-white);">Solo lectura</p>
              <p style="font-family: var(--font-sans); font-weight: 400; font-size: 12px; color: rgba(248, 246, 240, 0.6); margin-top: 4px;">Cero riesgo de modificar</p>
            </div>
            <div data-animate data-animate-delay="400">
              <p style="font-family: var(--font-sans); font-weight: 600; font-size: 14px; color: var(--color-ghost-white);">Open source</p>
              <p style="font-family: var(--font-sans); font-weight: 400; font-size: 12px; color: rgba(248, 246, 240, 0.6); margin-top: 4px;">Auditable en GitHub</p>
            </div>
            <div data-animate data-animate-delay="450">
              <p style="font-family: var(--font-sans); font-weight: 600; font-size: 14px; color: var(--color-ghost-white);">Gratis</p>
              <p style="font-family: var(--font-sans); font-weight: 400; font-size: 12px; color: rgba(248, 246, 240, 0.6); margin-top: 4px;">Sin costos ocultos</p>
            </div>
          </div>
        </div>

        <!-- Right col: chat showcase -->
        <div class="lg:col-span-7" data-animate data-animate-delay="200">
          <div style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.1); border-radius: 8px; padding: 24px; box-shadow: var(--shadow-xl);">
            <!-- Window chrome row -->
            <div class="flex items-center" style="gap: 12px;">
              <div class="flex items-center" style="gap: 6px;">
                <span style="display: inline-block; width: 10px; height: 10px; border-radius: 50%; background: rgba(255,255,255,0.18);"></span>
                <span style="display: inline-block; width: 10px; height: 10px; border-radius: 50%; background: rgba(255,255,255,0.18);"></span>
                <span style="display: inline-block; width: 10px; height: 10px; border-radius: 50%; background: rgba(255,255,255,0.18);"></span>
              </div>
              <span style="font-family: var(--font-mono); font-size: 11px; color: rgba(248, 246, 240, 0.5);">claude.ai</span>
            </div>

            <!-- Chat content -->
            <div class="flex flex-col" style="gap: 16px; margin-top: 16px;">
              <!-- User message -->
              <div class="flex" style="justify-content: flex-end;">
                <div
                  style="background: rgba(248, 246, 240, 0.1); padding: 10px 14px; border-radius: 8px; font-family: var(--font-sans); font-weight: 400; font-size: 13px; line-height: 1.5; color: var(--color-ghost-white); max-width: 75%;"
                >
                  ¿Cuál fue mi producto más vendido el mes pasado?
                </div>
              </div>

              <!-- Tool call indicator -->
              <div class="flex" style="justify-content: flex-start;">
                <div
                  class="flex items-center"
                  style="gap: 6px; background: rgba(217, 119, 6, 0.08); border: 1px solid rgba(217, 119, 6, 0.3); border-radius: 4px; padding: 4px 10px; font-family: var(--font-mono); font-size: 11px; color: var(--color-action-orange); width: max-content;"
                >
                  <span style="display: inline-block; width: 6px; height: 6px; border-radius: 50%; background: var(--color-action-orange);"></span>
                  <span>→ Llamando export_orders…</span>
                </div>
              </div>

              <!-- Claude response -->
              <div class="flex" style="justify-content: flex-start;">
                <div
                  style="background: rgba(248, 246, 240, 0.08); border: 1px solid rgba(248, 246, 240, 0.12); padding: 12px 16px; border-radius: 8px; font-family: var(--font-sans); font-weight: 400; font-size: 13px; line-height: 1.5; color: var(--color-ghost-white); max-width: 80%;"
                >
                  El más vendido fue <strong>Sticker Pack Deluxe</strong> con 47 unidades vendidas en marzo, generando <strong>$1,840,000 COP</strong> en ingresos. Representa el 18% del total. ¿Quieres que lo compare con febrero?
                </div>
              </div>
            </div>
          </div>
        </div>

      </div>
    </Container>
  </section>

  <!-- ─── Section 6: Cómo funciona (white, 3 steps with IconBox) ── -->
  <Section background="white" id="como-funciona">
    <Container>
      <div style="text-align: center;">
        <div class="eyebrow-badge" style="margin-inline: auto;" data-animate>
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="20 6 9 17 4 12"/>
          </svg>
          CÓMO FUNCIONA
        </div>
        <h2 class="heading-bicolor" style="text-align: center; margin-top: 16px;" data-animate data-animate-delay="100">
          Listo en 3 minutos. <span class="muted">Sin instalar nada.</span>
        </h2>
      </div>

      <div class="grid md:grid-cols-3" style="gap: 24px; margin-top: 56px;">
        <!-- Step 1 -->
        <div data-animate data-animate-delay="100">
          <Card variant="default" padding="lg">
            <IconBox variant="orange" size="lg">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"/>
              </svg>
            </IconBox>
            <h3 style="font-family: var(--font-sans); font-weight: 500; font-size: 18px; color: var(--color-ink-blue); margin-top: 20px;">Genera tu token</h3>
            <p style="font-family: var(--font-sans); font-weight: 400; font-size: 14px; color: var(--color-slate-text); line-height: 1.5; margin-top: 8px;">
              Inicia sesión con tu cuenta Komercia y obtén tu token de exportación personal en segundos.
            </p>
          </Card>
        </div>

        <!-- Step 2 -->
        <div data-animate data-animate-delay="200">
          <Card variant="default" padding="lg">
            <IconBox variant="plum" size="lg">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/>
                <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
              </svg>
            </IconBox>
            <h3 style="font-family: var(--font-sans); font-weight: 500; font-size: 18px; color: var(--color-ink-blue); margin-top: 20px;">Conecta Claude</h3>
            <p style="font-family: var(--font-sans); font-weight: 400; font-size: 14px; color: var(--color-slate-text); line-height: 1.5; margin-top: 8px;">
              Pega el token en Claude.ai y agrega el conector MCP. Solo lo haces una vez.
            </p>
          </Card>
        </div>

        <!-- Step 3 -->
        <div data-animate data-animate-delay="300">
          <Card variant="default" padding="lg">
            <IconBox variant="green" size="lg">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
              </svg>
            </IconBox>
            <h3 style="font-family: var(--font-sans); font-weight: 500; font-size: 18px; color: var(--color-ink-blue); margin-top: 20px;">Pregúntale lo que sea</h3>
            <p style="font-family: var(--font-sans); font-weight: 400; font-size: 14px; color: var(--color-slate-text); line-height: 1.5; margin-top: 8px;">
              Habla con Claude en lenguaje natural. Él consulta tus datos y te responde.
            </p>
          </Card>
        </div>
      </div>
    </Container>
  </Section>

  <!-- ─── Section 7: Featured use cases (fog, asymmetric grid) ──── -->
  <Section background="fog" id="casos-uso">
    <Container>
      <div style="text-align: center;">
        <div class="eyebrow-badge" style="margin-inline: auto;" data-animate>
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="20 6 9 17 4 12"/>
          </svg>
          CASOS DE USO
        </div>
        <h2 class="heading-bicolor" style="text-align: center; margin-top: 16px;" data-animate data-animate-delay="100">
          Pregúntale a Claude <span class="muted">lo que necesites.</span>
        </h2>
        <p class="section-subheading" style="margin-inline: auto; text-align: center; margin-top: 16px;">
          Tu tienda en lenguaje natural. Sin queries, sin formularios, sin esperas.
        </p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-3" style="gap: 24px; margin-top: 48px;">

        <!-- Big card: col-span-2, callout-plum -->
        <div class="lg:col-span-2" data-animate data-animate-delay="100">
          <Card variant="callout-plum" padding="lg">
            <p style="font-family: var(--font-sans); font-weight: 500; font-size: 12px; color: rgba(248, 246, 240, 0.7); text-transform: uppercase; letter-spacing: 0.12em;">
              ANALÍTICA CONVERSACIONAL
            </p>
            <h3 style="font-family: var(--font-sans); font-weight: 600; font-size: 28px; line-height: 1.2; color: var(--color-ghost-white); margin-top: 12px;">
              Reportes en lenguaje natural
            </h3>
            <p style="font-family: var(--font-sans); font-weight: 400; font-size: 14px; line-height: 1.5; color: rgba(248, 246, 240, 0.75); max-width: 28rem; margin-top: 12px;">
              Pídele a Claude que analice tus ventas, identifique tendencias, compare períodos, detecte productos estancados, o arme cualquier reporte que normalmente toma horas en Excel.
            </p>
            <div
              style="display: inline-block; font-family: var(--font-mono); font-size: 12px; color: var(--color-ghost-white); background: rgba(248, 246, 240, 0.1); border: 1px solid rgba(248, 246, 240, 0.2); border-radius: 2px; padding: 8px 12px; margin-top: 20px; width: max-content;"
            >
              "¿Qué productos venden bien pero tienen poco stock?"
            </div>
          </Card>
        </div>

        <!-- Right column: stacked cards -->
        <div class="lg:col-span-1 flex flex-col" style="gap: 16px;">
          <!-- Top card: callout-orange -->
          <div data-animate data-animate-delay="200">
            <Card variant="callout-orange" padding="md">
              <h3 style="font-family: var(--font-sans); font-weight: 600; font-size: 20px; color: var(--color-ghost-white);">
                Reportes automáticos
              </h3>
              <p style="font-family: var(--font-sans); font-weight: 400; font-size: 13px; line-height: 1.5; color: rgba(248, 246, 240, 0.85); margin-top: 8px;">
                Genera CSVs, JSONs y dashboards conversando. Claude formatea como necesites.
              </p>
            </Card>
          </div>

          <!-- Bottom card: default -->
          <div data-animate data-animate-delay="300">
            <Card variant="default" padding="md">
              <h3 style="font-family: var(--font-sans); font-weight: 600; font-size: 20px; color: var(--color-ink-blue);">
                Asistente operativo
              </h3>
              <p style="font-family: var(--font-sans); font-weight: 400; font-size: 13px; line-height: 1.5; color: var(--color-slate-text); margin-top: 8px;">
                Identifica clientes recurrentes, detecta abandonos, optimiza inventario.
              </p>
            </Card>
          </div>
        </div>

      </div>
    </Container>
  </Section>

  <!-- ─── Section 8: Demo placeholder (white) ─────────────────────── -->
  <Section background="white" padding="tight" id="demo">
    <Container>
      <div style="text-align: center;">
