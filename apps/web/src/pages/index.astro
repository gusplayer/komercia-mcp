<script is:inline>
  (function () {
    function applyLang(lang) {
      document.documentElement.lang = lang;
      var els = document.querySelectorAll('[data-t-es]');
      for (var i = 0; i < els.length; i++) {
        var el = els[i];
        var text = lang === 'en' ? el.getAttribute('data-t-en') : el.getAttribute('data-t-es');
        if (text === null) continue;
        // Keep scramble target in sync; cancel any in-flight scramble.
        if (el.hasAttribute('data-scramble')) {
          el._scrambleTarget = text;
          el._scrambling = false;
        }
        el.textContent = text;
      }
      var label = document.getElementById('lang-current');
      if (label) label.textContent = lang.toUpperCase();
    }

    var saved = localStorage.getItem('lang');
    var current = saved === 'en' ? 'en' : 'es';
    applyLang(current);

    var btn = document.getElementById('lang-toggle');
    if (btn) {
      btn.addEventListener('click', function () {
        current = current === 'es' ? 'en' : 'es';
        try { localStorage.setItem('lang', current); } catch (e) {}
        applyLang(current);
      });
    }

    // Tools expand/collapse
    var toolsToggle = document.getElementById('toggle-tools');
    var toolsGrid = document.getElementById('tools-grid');
    if (toolsToggle && toolsGrid) {
      toolsToggle.addEventListener('click', function () {
        var expanded = toolsGrid.classList.toggle('expanded');
        toolsToggle.setAttribute('aria-expanded', expanded ? 'true' : 'false');
        var extras = toolsGrid.querySelectorAll('.tool-extra');
        for (var i = 0; i < extras.length; i++) {
          extras[i].setAttribute('aria-hidden', expanded ? 'false' : 'true');
        }
        if (expanded) {
          toolsToggle.setAttribute('data-t-es', 'ocultar herramientas ↑');
          toolsToggle.setAttribute('data-t-en', 'hide tools ↑');
        } else {
          toolsToggle.setAttribute('data-t-es', 'ver las 5 restantes →');
          toolsToggle.setAttribute('data-t-en', 'see the remaining 5 →');
        }
        applyLang(current);
      });
    }

    // ── Text scramble (terminal decryption effect) ────────
    var SCRAMBLE_CHARS = '!<>-_/[]{}—=+*^?#$%&0123456789ABCDEFGHIJKLMNOPQR';

    function escapeHtml(c) {
      return c === '<' ? '&lt;' : c === '>' ? '&gt;' : c === '&' ? '&amp;' : c;
    }

    function scrambleText(el) {
      if (!el || el._scrambling) return;
      var target = (el._scrambleTarget || el.textContent || '').trim();
      if (!target) { el.classList.add('scramble-active'); return; }
      el._scrambleTarget = target;
      el._scrambling = true;
      el.classList.add('scramble-active');

      var queue = [];
      for (var i = 0; i < target.length; i++) {
        var to = target[i];
        if (to === ' ' || to === '\n' || to === ' ') {
          queue.push({ to: to, locked: true });
        } else {
          var start = i * 0.5;
          var end = start + 14 + Math.random() * 22;
          queue.push({
            to: to,
            start: start,
            end: end,
            char: SCRAMBLE_CHARS.charAt(Math.floor(Math.random() * SCRAMBLE_CHARS.length)),
          });
        }
      }

      var frame = 0;
      function tick() {
        var html = '';
        var complete = 0;
        for (var i = 0; i < queue.length; i++) {
          var q = queue[i];
          if (q.locked || frame >= q.end) {
            html += escapeHtml(q.to);
            complete++;
          } else if (frame >= q.start) {
            if (Math.random() < 0.4) {
              q.char = SCRAMBLE_CHARS.charAt(Math.floor(Math.random() * SCRAMBLE_CHARS.length));
            }
            html += '<span class="scramble-dud">' + escapeHtml(q.char) + '</span>';
          } else {
            html += '<span class="scramble-dud">' + escapeHtml(q.char) + '</span>';
          }
        }
        el.innerHTML = html;
        if (complete === queue.length) {
          el.textContent = target;
          el._scrambling = false;
        } else {
          frame++;
          requestAnimationFrame(tick);
        }
      }
      tick();
    }

    // Trigger scramble on viewport entry (or immediately for hero)
    var scrambleEls = document.querySelectorAll('[data-scramble]');
    if (scrambleEls.length) {
      // Cache the initial target so applyLang doesn't break the source of truth
      for (var si = 0; si < scrambleEls.length; si++) {
