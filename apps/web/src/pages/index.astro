        '└────────────────────────────┘',
        // 3. top products by volume
        '┌─ top_products.q2 ─────────┐\n' +
        '│                            │\n' +
        '│ 1. cmst_negra_L            │\n' +
        '│    47 uds · $1.84M         │\n' +
        '│    ▤▤▤▤▤▤▤▤▤▤ 38%          │\n' +
