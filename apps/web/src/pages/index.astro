        '│ ▤▤▤▤▤▤▤▤▤▤ 62%             │\n' +
        '│                            │\n' +
        '├─ stock_alert ──────────────┤\n' +
        '│                            │\n' +
        '│ ⚠ bolso_lona      8u       │\n' +
        '│ ⚠ pin_edt_lim     4u       │\n' +
        '│ ⚠ stcks_pck      18u       │\n' +
        '│                            │\n' +
        '└────────────────────────────┘',
        // 2. monthly revenue trend
        '┌─ monthly_sales ───────────┐\n' +
        '│                            │\n' +
        '│ may    $12.4M ▤▤▤▤▤▤▤▤▤▤   │\n' +
        '│ apr    $10.5M ▤▤▤▤▤▤▤▤     │\n' +
        '│ mar    $8.9M  ▤▤▤▤▤▤▤      │\n' +
        '│ feb    $7.6M  ▤▤▤▤▤▤       │\n' +
        '│ jan    $6.2M  ▤▤▤▤▤        │\n' +
        '│                            │\n' +
        '├─ growth ───────────────────┤\n' +
