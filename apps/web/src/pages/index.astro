        '│                            │\n' +
        '│ 4. stkrs_pck               │\n' +
        '│    18 uds · $360K          │\n' +
        '│    ▤▤▤▤ 7%                 │\n' +
        '│                            │\n' +
        '│ 5. grra_snpbk · ▤▤ 12%     │\n' +
        '│                            │\n' +
        '└────────────────────────────┘',
        // 4. sales forecast (the AI / projection screen)
        '┌─ forecast.next_30d ───────┐\n' +
        '│                            │\n' +
        '│ projected    $14.2M ↑      │\n' +
        '│ confidence   92%           │\n' +
        '│                            │\n' +
