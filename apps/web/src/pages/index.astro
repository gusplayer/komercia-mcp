        </div>

        <nav class="modal-filters" aria-label="Filtrar por categoría">
          <button type="button" class="filter-btn active" data-cat="all">
            <span data-t-es="todos" data-t-en="all">todos</span>
            <span class="count">({recetas.length})</span>
          </button>
          {categories.map((c) => {
            const sample = recetas.find((r) => r.cat === c);
            return (
              <button type="button" class="filter-btn" data-cat={c}>
                <span data-t-es={sample?.catEs} data-t-en={sample?.catEn}>{sample?.catEs}</span>
                <span class="count">({catCounts[c]})</span>
              </button>
            );
          })}
        </nav>

        <div class="modal-body">
          {recetas.map((r, i) => (
            <article class="recipe" data-cat={r.cat}>
              <div class="recipe-meta">
                <span class="recipe-tag">
                  <span data-t-es={r.catEs} data-t-en={r.catEn}>{r.catEs}</span>
                  · {r.tools.length} {r.tools.length === 1 ? 'tool' : 'tools'}
