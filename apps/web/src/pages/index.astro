---
// index.astro — Landing page. 099 / terminal aesthetic, bilingual ES/EN.
import Base from '../layouts/Base.astro';
import RecetasModal from '../components/RecetasModal.astro';
import LogoKomercia from '../components/LogoKomercia.astro';

// Deploy fingerprint shown in the footer — lets us confirm at a glance
// which build is live. SHA comes from Vercel's automatic env at deploy
// time; on a local dev server both fall back to "dev". The date is
// snapshotted in astro.config.mjs at build time (NOT per-request).
const commitSha = (process.env.VERCEL_GIT_COMMIT_SHA ?? '').slice(0, 7) || 'dev';
const repoSlug =
  process.env.VERCEL_GIT_REPO_OWNER && process.env.VERCEL_GIT_REPO_SLUG
    ? `${process.env.VERCEL_GIT_REPO_OWNER}/${process.env.VERCEL_GIT_REPO_SLUG}`
    : 'gusplayer/komercia-mcp';
const commitUrl = commitSha === 'dev' ? null : `https://github.com/${repoSlug}/commit/${commitSha}`;
const buildIso = process.env.PUBLIC_BUILD_TIME ?? new Date().toISOString();
// Compact UTC date for the footer: "2026-05-14 12:36 UTC"
const buildLabel = (() => {
  const d = new Date(buildIso);
  const pad = (n: number) => String(n).padStart(2, '0');
  return `${d.getUTCFullYear()}-${pad(d.getUTCMonth() + 1)}-${pad(d.getUTCDate())} ${pad(d.getUTCHours())}:${pad(d.getUTCMinutes())} UTC`;
})();

// Pixel-style line icons (16x16 grid, sharp corners — retro terminal feel)
const icons: Record<string, string> = {
  get_store_info:                '<path d="M2 6h12v8H2z"/><path d="M2 6l2-3h8l2 3"/><path d="M6 9h4v5H6z"/>',
  export_products:               '<path d="M2 5l6-3 6 3v6l-6 3-6-3z"/><path d="M2 5l6 3 6-3M8 8v6"/>',
  export_orders:                 '<path d="M3 1h10v13l-2-1-2 1-2-1-2 1-2-1z"/><path d="M6 5h4M6 8h4M6 11h2"/>',
  export_customers:              '<circle cx="8" cy="5" r="2.5"/><path d="M3 14v-1c0-2 2-4 5-4s5 2 5 4v1"/>',
  export_categories:             '<path d="M2 4h4l1 2h7v8H2z"/><path d="M5 9h6M5 11h4"/>',
  list_payment_gateways:         '<path d="M2 3h12v10H2z"/><path d="M2 6h12M4 10h3"/>',
  export_inventory_movements:    '<path d="M2 14h12"/><path d="M4 10v4M8 6v8M12 3v11"/>',
  export_theme_config:           '<circle cx="8" cy="8" r="2"/><path d="M8 1v2M8 13v2M1 8h2M13 8h2M3 3l1.5 1.5M11.5 11.5L13 13M3 13l1.5-1.5M11.5 4.5L13 3"/>',
  download_media_archive:        '<path d="M8 2v8M5 7l3 3 3-3M3 12v2h10v-2"/>',
  suggest_alternative_platforms: '<circle cx="4" cy="3" r="1"/><circle cx="4" cy="13" r="1"/><circle cx="12" cy="8" r="1"/><path d="M4 4v8M5 13c4 0 7-2 7-5M5 3c4 0 7 2 7 5"/>',
  validate_komercia_apis:        '<path d="M1 8h3l1-4 2 8 2-6 1 2h5"/>',
};

const tools = [
  { name: 'get_store_info',                descEs: 'nombre, plan, dominio',         descEn: 'store name, plan, domain' },
  { name: 'export_products',               descEs: 'csv · json · shopify · woo',    descEn: 'csv · json · shopify · woo' },
  { name: 'export_orders',                 descEs: 'historial completo de ventas',  descEn: 'full sales history' },
  { name: 'export_customers',              descEs: 'contactos + direcciones',       descEn: 'contacts + addresses' },
  { name: 'export_categories',             descEs: 'árbol de jerarquía',            descEn: 'hierarchy tree' },
  { name: 'list_payment_gateways',         descEs: 'métodos configurados',          descEn: 'configured methods' },
  { name: 'export_inventory_movements',    descEs: 'movimientos de stock',          descEn: 'stock movements' },
  { name: 'export_theme_config',           descEs: 'colores, fuentes, tema',        descEn: 'colors, fonts, theme' },
  { name: 'download_media_archive',        descEs: 'zip de imágenes',               descEn: 'image zip archive' },
  { name: 'suggest_alternative_platforms', descEs: 'plataformas para migrar',       descEn: 'migration platforms' },
  { name: 'validate_komercia_apis',        descEs: 'health check de api',           descEn: 'api health check' },
];

const visibleCount = 6;


// ── Install methods (modal content). Each client has its own setup flow.
interface InstallStep { titleEs: string; titleEn: string; code?: string; }
interface InstallMethod {
  id: string;
  name: string;
  badgeEs: string;
  badgeEn: string;
  descEs: string;
  descEn: string;
  steps: InstallStep[];
  tipEs?: string;
  tipEn?: string;
}

const installMethods: InstallMethod[] = [
  {
    id: 'claude-code',
    name: 'Claude Code',
    badgeEs: 'cli · el más simple',
    badgeEn: 'cli · the simplest',
    descEs: 'Claude Code corre en tu terminal. Un solo comando registra el MCP y queda disponible en todas tus sesiones.',
    descEn: 'Claude Code runs in your terminal. A single command registers the MCP and it stays available in every session.',
    steps: [
      {
        titleEs: 'Instala Claude Code (si no lo tienes)',
        titleEn: "Install Claude Code (if you don't have it yet)",
        code: 'npm i -g @anthropic-ai/claude-code',
      },
      {
        titleEs: 'Registra el servidor MCP con tu token',
        titleEn: 'Register the MCP server with your token',
        code: 'claude mcp add --transport sse komercia \\\n  https://api-mcp.komercia.co/sse \\\n  --header "Authorization: Bearer TU_TOKEN"',
      },
      {
        titleEs: 'Verifica que quedó registrado',
        titleEn: 'Verify it was registered',
        code: 'claude mcp list',
      },
    ],
    tipEs: 'Agrega --scope project al final para limitarlo a un solo proyecto en lugar de globalmente.',
    tipEn: 'Add --scope project at the end to limit it to a single project instead of globally.',
  },
  {
    id: 'claude-ai',
    name: 'Claude.ai',
    badgeEs: 'web · sin instalación',
    badgeEn: 'web · no install',
    descEs: 'Funciona directamente en claude.ai. Sin instalar nada — solo pega la URL y tu token en la interfaz.',
    descEn: 'Works directly in claude.ai. No install — just paste URL and token in the interface.',
    steps: [
      {
        titleEs: 'Abre Claude.ai → Configuración → Integraciones',
        titleEn: 'Open Claude.ai → Settings → Integrations',
      },
      {
        titleEs: 'Click en "Add custom integration" → "MCP Server"',
        titleEn: 'Click "Add custom integration" → "MCP Server"',
      },
      {
        titleEs: 'Pega la URL del servidor',
        titleEn: 'Paste the server URL',
        code: 'https://api-mcp.komercia.co/sse',
      },
      {
        titleEs: 'En Authorization pega: Bearer TU_TOKEN',
        titleEn: 'In Authorization paste: Bearer YOUR_TOKEN',
      },
      {
        titleEs: 'Guarda y abre un chat nuevo',
        titleEn: 'Save and open a new chat',
      },
    ],
  },
  {
    id: 'claude-desktop',
    name: 'Claude Desktop',
    badgeEs: 'app · mac · windows',
    badgeEn: 'app · mac · windows',
    descEs: 'Claude Desktop usa stdio internamente. Necesitas el puente mcp-remote para conectarse a servidores http/sse.',
    descEn: 'Claude Desktop uses stdio internally. You need the mcp-remote bridge to connect to http/sse servers.',
    steps: [
      {
        titleEs: 'Instala el puente mcp-remote',
        titleEn: 'Install the mcp-remote bridge',
        code: 'npm install -g mcp-remote',
      },
      {
        titleEs: 'Abre el archivo de configuración',
        titleEn: 'Open the config file',
        code: '# macOS\n~/Library/Application Support/Claude/claude_desktop_config.json\n\n# Windows\n%APPDATA%\\Claude\\claude_desktop_config.json',
      },
      {
        titleEs: 'Agrega esta entrada dentro de "mcpServers"',
        titleEn: 'Add this entry inside "mcpServers"',
        code: '{\n  "mcpServers": {\n    "komercia": {\n      "command": "mcp-remote",\n      "args": [\n        "https://api-mcp.komercia.co/sse",\n        "--header",\n        "Authorization: Bearer TU_TOKEN"\n      ]\n    }\n  }\n}',
      },
      {
        titleEs: 'Reinicia Claude Desktop',
        titleEn: 'Restart Claude Desktop',
      },
    ],
  },
  {
    id: 'chatgpt',
    name: 'ChatGPT',
    badgeEs: 'plus · pro',
    badgeEn: 'plus · pro',
    descEs: 'ChatGPT soporta conectores MCP remotos en planes Plus y Pro. Se configuran desde Settings → Connectors.',
    descEn: 'ChatGPT supports remote MCP connectors on Plus and Pro plans. Configure from Settings → Connectors.',
    steps: [
      {
        titleEs: 'Abre ChatGPT → Settings → Connectors',
        titleEn: 'Open ChatGPT → Settings → Connectors',
      },
      {
        titleEs: 'Add custom connector → MCP Server',
        titleEn: 'Add custom connector → MCP Server',
      },
      {
        titleEs: 'Pega la URL del servidor',
        titleEn: 'Paste the server URL',
        code: 'https://api-mcp.komercia.co/sse',
      },
      {
        titleEs: 'Authentication: Bearer · pega tu token',
        titleEn: 'Authentication: Bearer · paste your token',
      },
      {
        titleEs: 'Habilita el conector en cada chat donde lo necesites',
        titleEn: 'Enable the connector in each chat where you need it',
      },
    ],
    tipEs: 'La interfaz puede variar — si no ves "Connectors", busca "Actions" o "Tools" dentro de Settings.',
    tipEn: 'The exact UI evolves — if you don\'t see "Connectors", look for "Actions" or "Tools" under Settings.',
  },
];

---

<Base
  title="Komercia MCP"
  description="Servidor MCP oficial de Komercia. Pregúntale a Claude sobre tu tienda — productos, ventas, clientes, inventario. Solo lectura, open source."
>
  <div class="page">

    <!-- ── Top bar ─────────────────────────────────────── -->
    <header class="topbar">
      <a href="/" class="brand" aria-label="Komercia MCP home">
        <LogoKomercia class="brand-mark" />
      </a>

      <nav class="topnav">
        <a href="#features" class="link-muted" data-t-es="herramientas" data-t-en="features">herramientas</a>
        <a href="#como-funciona" class="link-muted" data-t-es="cómo funciona" data-t-en="how it works">cómo funciona</a>
        <a href="#install" class="link-muted" data-t-es="instalación" data-t-en="install">instalación</a>
      </nav>

      <div class="topbar-actions">
        <a href="/sign-in" class="btn-ghost-pill btn-token" data-t-es="token →" data-t-en="token →">token →</a>
        <button id="lang-toggle" class="btn-ghost-pill" aria-label="Cambiar idioma" title="Cambiar idioma / Toggle language">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="10"/>
            <path d="M2 12h20"/>
            <path d="M12 2a15 15 0 0 1 4 10 15 15 0 0 1-4 10 15 15 0 0 1-4-10 15 15 0 0 1 4-10z"/>
          </svg>
          <span id="lang-current">ES</span>
        </button>
        <a href="https://github.com/gusplayer/komercia-mcp" target="_blank" rel="noopener noreferrer" class="btn-ghost-pill btn-icon-only" aria-label="Ver repositorio en GitHub" title="Ver repositorio en GitHub">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
          </svg>
        </a>
      </div>
    </header>

    <main class="main">

      <!-- ── Hero ──────────────────────────────────────── -->
      <section class="hero">
        <!-- Right-side ASCII store-data deco — decorative only, hidden on mobile -->
        <div class="hero-deco" aria-hidden="true">
          <pre class="deco-frame"><code id="deco-content">┌─ store.live ──────────────┐
│                            │
│ products      86           │
│ orders       247           │
│ customers    423           │
│ revenue   $12.4M           │
│                            │
│ ▌ ↑ +18% mom               │
│                            │
├─ top_seller ───────────────┤
│                            │
│ camiseta_negra_L           │
│ 47 uds · $1.84M            │
│ ▤▤▤▤▤▤▤▤▤▤ 62%             │
│                            │
├─ stock_alert ──────────────┤
│                            │
│ ⚠ bolso_lona      8u       │
│ ⚠ pin_edt_lim     4u       │
│ ⚠ stcks_pck      18u       │
│                            │
└────────────────────────────┘</code></pre>
        </div>

        <div class="prompt">
          <span class="muted">user@komercia ~$</span>
          <span class="cmd">./mcp.connect</span><span class="caret">_</span>
        </div>

        <h1 class="h1">
          <span id="h1-main" data-scramble data-t-es="Tu e-commerce" data-t-en="Your e-commerce">Tu e-commerce</span><br />
          <span id="h1-muted" class="muted" data-scramble data-t-es="conectado a un agente AI" data-t-en="connected to an AI agent">conectado a un agente AI</span>
        </h1>

        <p id="hero-lede" class="lede" data-scramble data-t-es="Conecta Komercia con Claude y conversa con tu tienda como si le preguntaras a tu mejor vendedor. Respuestas reales, en segundos." data-t-en="Connect Komercia with Claude and chat with your store like you would with your best salesperson. Real answers, in seconds.">
          Conecta Komercia con Claude y conversa con tu tienda como si le preguntaras a tu mejor vendedor. Respuestas reales, en segundos.
        </p>

        <div class="cta-row">
          <a href="/sign-in" class="btn-primary" data-t-es="obtener_token →" data-t-en="get_token →">obtener_token →</a>
          <a href="#como-funciona" class="btn-ghost" data-t-es="cómo_funciona" data-t-en="how_it_works">cómo_funciona</a>
        </div>

        <ul class="trust">
          <li><span class="dot">●</span> <span data-t-es="11 herramientas" data-t-en="11 tools">11 herramientas</span></li>
          <li><span class="dot">●</span> <span data-t-es="Solo lectura" data-t-en="Read-only">Solo lectura</span></li>
          <li><span class="dot">●</span> <span data-t-es="Open source" data-t-en="Open source">Open source</span></li>
        </ul>
      </section>

      <div class="divider"></div>

      <!-- ── Features ──────────────────────────────────── -->
      <section id="features" class="block">
        <div class="block-header">
          <h2 class="h2" data-t-es="&gt; herramientas" data-t-en="&gt; features">&gt; herramientas</h2>
          <p class="block-hint" data-scramble data-t-es="11 herramientas MCP. Todas de solo lectura." data-t-en="11 MCP tools. All read-only.">11 herramientas MCP. Todas de solo lectura.</p>
        </div>

        <div class="grid" id="tools-grid">
          {tools.map((t, i) => (
            <article class={i < visibleCount ? 'tool-card' : 'tool-card tool-extra'} aria-hidden={i < visibleCount ? 'false' : 'true'}>
              <svg class="tool-icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="square" stroke-linejoin="miter" aria-hidden="true" set:html={icons[t.name]} />
              <code class="tool-name">{t.name}</code>
              <p class="tool-desc" data-t-es={t.descEs} data-t-en={t.descEn}>{t.descEs}</p>
            </article>
          ))}
        </div>

        <button type="button" id="toggle-tools" class="link-arrow-btn" aria-expanded="false" aria-controls="tools-grid" data-t-es="ver las 5 restantes →" data-t-en="see the remaining 5 →">ver las 5 restantes →</button>
      </section>

      <div class="divider"></div>

      <!-- ── Examples ──────────────────────────────────── -->
      <section id="como-funciona" class="block">
        <div class="block-header">
          <h2 class="h2" data-t-es="&gt; cómo funciona" data-t-en="&gt; how it works">&gt; cómo funciona</h2>
          <p class="block-hint" data-scramble data-t-es="Así se ve en la práctica. 6 casos reales, datos reales." data-t-en="See it in action. 6 real use cases, real store data.">Así se ve en la práctica. 6 casos reales, datos reales.</p>
        </div>

        <div class="hiw-terminal" id="hiw-terminal">
          <div class="hiw-bar" aria-hidden="true">
            <span class="hiw-chrome-dots">● ● ●</span>
            <span class="hiw-bar-label">claude · komercia/mcp</span>
          </div>
          <div class="hiw-body">
            <div class="hiw-prompt-row">
              <span class="muted">user@komercia ~$</span>
              <span id="hiw-question" class="hiw-question"></span><span class="caret">_</span>
            </div>
            <div id="hiw-calling" class="hiw-calling" style="visibility:hidden">
              <span class="muted">→ calling</span>
              <code id="hiw-tool-name" class="hiw-tool-chip"></code>
            </div>
            <pre id="hiw-output" class="hiw-output"><code id="hiw-output-code"></code></pre>
          </div>
          <div class="hiw-footer">
            <div id="hiw-nav-dots" class="hiw-nav-dots" aria-label="Navigate examples"></div>
            <div class="hiw-progress-track" aria-hidden="true">
              <div id="hiw-pbar" class="hiw-pbar"></div>
            </div>
          </div>
        </div>

        <button type="button" data-open-recetas class="link-arrow-btn" data-t-es="Ver los 18 prompts curados →" data-t-en="See all 18 curated prompts →">Ver los 18 prompts curados →</button>
      </section>

      <div class="divider"></div>

      <!-- ── Install ───────────────────────────────────── -->
      <section id="install" class="block">
        <div class="block-header">
          <h2 class="h2" data-t-es="&gt; instalación" data-t-en="&gt; install">&gt; instalación</h2>
          <p class="block-hint" data-scramble data-t-es="Tres pasos. Cinco minutos. Sin código." data-t-en="Three steps. Five minutes. No code.">Tres pasos. Cinco minutos. Sin código.</p>
        </div>

        <ol class="steps">
          <li class="step">
            <span class="step-num">[01]</span>
            <div class="step-body">
              <strong>get_token</strong>
              <p class="step-desc" data-t-es="Inicia sesión con tus credenciales de Komercia. Token de solo lectura, válido 6 meses." data-t-en="Log in with your Komercia credentials. Token is read-only, valid for 6 months.">Inicia sesión con tus credenciales de Komercia. Token de solo lectura, válido 6 meses.</p>
              <a href="/sign-in" class="link-arrow">/sign-in →</a>
            </div>
          </li>

          <li class="step">
            <span class="step-num">[02]</span>
            <div class="step-body">
              <strong>connect_client</strong>
              <p class="step-desc" data-t-es="Elige uno. Claude Code es el más simple — un solo comando." data-t-en="Pick one. Claude Code is the simplest — single command.">Elige uno. Claude Code es el más simple — un solo comando.</p>
              <div class="install-code-shell">
                <pre class="install-cmd-text"><code>claude mcp add --transport sse komercia https://api-mcp.komercia.co/sse --header "Authorization: Bearer &lt;TOKEN&gt;"</code></pre>
              </div>
              <p class="step-desc-sm" data-t-es="También funciona con Claude.ai, Claude Desktop y ChatGPT." data-t-en="Also works with Claude.ai, Claude Desktop, and ChatGPT.">También funciona con Claude.ai, Claude Desktop y ChatGPT.</p>
            </div>
          </li>

          <li class="step">
            <span class="step-num">[03]</span>
            <div class="step-body">
              <strong>ask_anything</strong>
              <p class="step-desc" data-t-es="Abre un chat de Claude. Pregunta en lenguaje natural. Claude llama a las herramientas MCP y responde con tus datos reales." data-t-en="Open a Claude chat. Ask in plain English. Claude calls the MCP tools and answers with your real data.">Abre un chat de Claude. Pregunta en lenguaje natural. Claude llama a las herramientas MCP y responde con tus datos reales.</p>
            </div>
          </li>
        </ol>

        <div class="install-clients">
          <p class="clients-label" data-t-es="¿Usas otro cliente? MCP funciona en:" data-t-en="Using a different client? MCP works in:">¿Usas otro cliente? MCP funciona en:</p>
          <div class="clients-row">
            {installMethods.map((m) => (
              <button type="button" class="client-chip" data-install-target={m.id}>{m.name}</button>
            ))}
          </div>
        </div>
      </section>

      <div class="divider"></div>

      <!-- ── Final CTA ─────────────────────────────────── -->
      <section class="block final">
        <p class="ready" data-scramble data-t-es="¿Listo?" data-t-en="Ready?">¿Listo?</p>
        <a href="/sign-in" class="btn-primary btn-primary-lg" data-t-es="obtener_token →" data-t-en="get_token →">obtener_token →</a>
        <p class="muted small" data-scramble data-t-es="Es gratis. 30 segundos. Tú guardas el token." data-t-en="It's free. 30 seconds. You keep the token.">Es gratis. 30 segundos. Tú guardas el token.</p>
      </section>

    </main>

    <!-- ── Install methods modal ─────────────────────── -->
    <div id="install-modal" class="modal-overlay" aria-hidden="true" role="dialog" aria-modal="true" aria-labelledby="install-modal-title">
      <div class="modal-window" role="document">

        <header class="modal-header">
          <span class="modal-title" id="install-modal-title">./install.guide</span>
          <button type="button" class="modal-close" aria-label="Cerrar modal" title="Cerrar (esc)">[ × ]</button>
        </header>

        <div class="modal-info">
          <span data-t-es={`${installMethods.length} clientes soportados · selecciona uno`} data-t-en={`${installMethods.length} clients supported · select one`}>{installMethods.length} clientes soportados · selecciona uno</span>
        </div>

        <nav class="modal-filters" aria-label="Filtrar por cliente">
          {installMethods.map((m, mi) => (
            <button type="button" class={mi === 0 ? 'filter-btn install-filter active' : 'filter-btn install-filter'} data-cat={m.id}>{m.name}</button>
          ))}
        </nav>

        <div class="modal-body">
          {installMethods.map((m, mi) => (
            <article class={mi === 0 ? 'install-method' : 'install-method hidden'} data-cat={m.id}>
              <div class="method-header">
                <h3 class="method-name">{m.name}</h3>
                <span class="method-badge" data-t-es={m.badgeEs} data-t-en={m.badgeEn}>{m.badgeEs}</span>
              </div>
              <p class="method-desc" data-t-es={m.descEs} data-t-en={m.descEn}>{m.descEs}</p>

              <ol class="method-steps">
                {m.steps.map((step, si) => {
                  const codeId = `install-${m.id}-step-${si}`;
                  const stepNum = `[${String(si + 1).padStart(2, '0')}]`;
                  return (
                    <li class="method-step">
                      <span class="step-num">{stepNum}</span>
                      <div class="step-body">
                        <p class="step-title" data-t-es={step.titleEs} data-t-en={step.titleEn}>{step.titleEs}</p>
                        {step.code && (
                          <div class="code-block">
                            <pre class="code-block-content"><code id={codeId}>{step.code}</code></pre>
                            <button type="button" class="code-copy" data-copy-target={codeId} data-t-es="[ copiar ]" data-t-en="[ copy ]" aria-label="Copiar">[ copiar ]</button>
                          </div>
                        )}
                      </div>
                    </li>
                  );
                })}
              </ol>

              {m.tipEs && (
                <p class="method-tip">
                  <span class="muted">tip ·</span>
                  <span data-t-es={m.tipEs} data-t-en={m.tipEn ?? m.tipEs}>{m.tipEs}</span>
                </p>
              )}
            </article>
          ))}
        </div>

        <footer class="modal-footer">
          <span class="muted" data-t-es="[ esc ] cerrar · click fuera para cerrar" data-t-en="[ esc ] close · click outside to close">[ esc ] cerrar · click fuera para cerrar</span>
        </footer>
      </div>
    </div>

    <!-- Prompt library modal (shared component) -->
    <RecetasModal />

    <!-- ── Footer ────────────────────────────────────── -->
    <footer class="bottom-bar">
      <span class="muted">komercia/mcp v0.1</span>
      <span class="dot-sep">·</span>
      <a href="https://github.com/gusplayer/komercia-mcp" target="_blank" rel="noopener noreferrer" class="link-muted">source</a>
      <span class="dot-sep">·</span>
      <span class="build-info" title={`Last update · ${buildLabel}`}>
        {commitUrl
          ? <a href={commitUrl} target="_blank" rel="noopener noreferrer" class="link-muted">{commitSha}</a>
          : <span class="muted">{commitSha}</span>}
        <span class="build-date muted"> · {buildLabel}</span>
      </span>
    </footer>
  </div>
</Base>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&display=swap');

  .page {
    --c-bg: #000000;
    --c-fg: #ffffff;
    --c-surface: #1d1d1d;
    --c-border: #383838;
    --c-muted: #888888;
    --r: 10px;

    /* Type scale — terminal-tuned, 7 sizes.
       xs/sm: meta, captions, code · base: UI default · md: body
       lg: sub-display (page titles) · xl/2xl: hero h1. See docs/brand.md. */
    --fs-xs:   12px;
    --fs-sm:   13px;
    --fs-base: 14px;
    --fs-md:   16px;
    --fs-lg:   20px;
    --fs-xl:   24px;
    --fs-2xl:  32px;

    min-height: 100vh;
    background: var(--c-bg);
    color: var(--c-fg);
    font-family: 'Space Mono', ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: var(--fs-md);
    line-height: 1.4;
    letter-spacing: 0.24px;
    font-feature-settings: 'zero';
    display: flex;
    flex-direction: column;
  }
  :global(body:has(.page)) { background: #000000; overflow-x: clip; }

  /* ── Top bar ─────────────────────────────────────────── */
  .topbar {
    display: flex;
    align-items: center;
    gap: 24px;
    padding: 19px 32px;
    border-bottom: 1px solid var(--c-border);
    position: sticky;
    top: 0;
    background: rgba(0, 0, 0, 0.85);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    z-index: 10;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    color: var(--c-fg);
    text-decoration: none;
    font-size: var(--fs-md);
    flex-shrink: 0;
    transition: color 150ms;
  }
  .brand:hover { color: var(--c-muted); }
  /* :global so the rule reaches the SVG inside the LogoKomercia child
     component (Astro CSS scoping otherwise blocks it). */
  :global(.brand-mark) {
    height: 22px;
    width: 127px;
    display: block;
    flex-shrink: 0;
  }
  .topnav {
    display: flex;
    gap: 24px;
    flex: 1;
  }
  .topbar-actions {
    display: flex;
    align-items: center;
    gap: 16px;
    flex-shrink: 0;
  }
  .link-muted {
    position: relative;
    color: var(--c-muted);
    text-decoration: none;
    font-size: var(--fs-md);
    transition: color 150ms;
  }
  .link-muted:hover { color: var(--c-fg); }
  /* Scrollspy active state — current section's link turns white with
     a thin underline that matches the topbar's border underneath. */
  .link-muted.nav-active {
    color: var(--c-fg);
  }
  .link-muted.nav-active::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: -22px;
    height: 1px;
    background: var(--c-fg);
  }
  /* Shared sizing — every topbar button is exactly 36px tall, box-sized */
  .btn-pill,
  .btn-ghost-pill {
    height: 36px;
    box-sizing: border-box;
    display: inline-flex;
    align-items: center;
    border-radius: var(--r);
    font-family: inherit;
    letter-spacing: 0.24px;
    cursor: pointer;
    white-space: nowrap;
    text-decoration: none;
    line-height: 1;
  }

  /* Primary CTA — high-contrast filled (099 spec) */
  .btn-pill {
    background: var(--c-fg);
    color: var(--c-bg);
    border: 1px solid var(--c-fg);
    padding: 0 16px;
    font-size: var(--fs-md);
    transition: background 150ms, border-color 150ms;
  }
  .btn-pill:hover { background: var(--c-muted); border-color: var(--c-muted); }

  /* Ghost pill — transparent + 1px border, used for utility actions (099 spec) */
  .btn-ghost-pill {
    background: transparent;
    color: var(--c-fg);
    border: 1px solid var(--c-border);
    padding: 0 12px;
    font-size: var(--fs-base);
    gap: 8px;
    transition: border-color 150ms, color 150ms, background 150ms;
  }
  .btn-ghost-pill:hover {
    border-color: var(--c-fg);
    background: var(--c-surface);
  }
  .btn-ghost-pill svg { display: block; flex-shrink: 0; }
  .btn-ghost-pill.btn-icon-only {
    padding: 0;
    width: 36px;
    justify-content: center;
  }

  /* ── Main ────────────────────────────────────────────── */
  .main {
    flex: 1;
    width: 100%;
    max-width: 880px;
    margin: 0 auto;
    padding: 48px 32px;
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  /* ── Prompt + caret ──────────────────────────────────── */
  .prompt {
    font-size: var(--fs-md);
    color: var(--c-fg);
    margin: 0;
  }
  .prompt .muted { color: var(--c-muted); }
  .prompt .cmd { color: var(--c-fg); margin-left: 8px; }
  .caret {
    color: var(--c-fg);
    margin-left: 2px;
    animation: blink 1s steps(1) infinite;
  }
  @keyframes blink { 50% { opacity: 0; } }

  /* Text-scramble decryption effect — random glyphs shown during the
     "loading" phase before each character locks to its final form. */
  .scramble-dud {
    color: var(--c-muted);
    opacity: 0.65;
  }
  /* When JS is enabled, hide scramble elements until the observer kicks
     in. They become visible the moment their scramble animation starts,
     so there is no flash of the final text. */
  :global(html.js-enabled) [data-scramble]:not(.scramble-active) {
    visibility: hidden;
  }
  /* Respect users who prefer reduced motion — show text immediately. */
  @media (prefers-reduced-motion: reduce) {
    :global(html.js-enabled) [data-scramble]:not(.scramble-active) {
      visibility: visible;
    }
  }

  /* ── Hero ────────────────────────────────────────────── */
  .hero {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 26px;
    padding: 32px 0;
  }
  /* Make sure hero content sits above the decorative panel */
  .hero > :not(.hero-deco) {
    position: relative;
    z-index: 1;
  }

  /* Right-side decorative store-data panel (retro terminal) */
  .hero-deco {
    position: absolute;
    top: 32px;
    bottom: 32px;
    right: 0;
    width: 52%;
    pointer-events: none;
    user-select: none;
    z-index: 0;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    opacity: 0.55;
  }
  .deco-frame {
    margin: 0;
    padding: 0;
  }
  .deco-frame code {
    font-family: 'Space Mono', ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 11px;
    line-height: 1.5;
    white-space: pre;
    display: block;
    /* Ambient gradient: starts already-muted on the left and fades into
       the background on the right. Reads as part of the bg, not a panel. */
    background: linear-gradient(90deg,
      #5a5a5a 0%,
      #3d3d3d 28%,
      #232323 58%,
      #0f0f0f 84%,
      #050505 100%);
    background-clip: text;
    -webkit-background-clip: text;
    color: transparent;
    -webkit-text-fill-color: transparent;
  }

  @media (max-width: 1024px) {
    .hero-deco { display: none; }
  }
  .h1 {
    font-size: var(--fs-2xl);
    line-height: 1.2;
    font-weight: 400;
    letter-spacing: 0.24px;
    color: var(--c-fg);
    margin: 0;
  }
  .h1 .muted { color: var(--c-muted); }
  .lede {
    font-size: var(--fs-md);
    color: var(--c-fg);
    line-height: 1.5;
    margin: 0;
    max-width: 580px;
  }
  .cta-row {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }
  .trust {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 26px;
    font-size: var(--fs-md);
    color: var(--c-fg);
  }
  .trust li { display: flex; align-items: center; gap: 8px; }
  .trust .dot { color: var(--c-fg); }

  /* ── Buttons ─────────────────────────────────────────── */
  .btn-primary {
    background: var(--c-fg);
    color: var(--c-bg);
    border: none;
    border-radius: var(--r);
    font-family: inherit;
    font-size: var(--fs-md);
    padding: 16px 26px;
    cursor: pointer;
    text-decoration: none;
    display: inline-block;
    transition: background 150ms;
    white-space: nowrap;
  }
  .btn-primary:hover { background: var(--c-muted); }
  .btn-primary-lg { padding: 19px 32px; }

  .btn-ghost {
    background: transparent;
    color: var(--c-fg);
    border: 1px solid var(--c-border);
    border-radius: var(--r);
    font-family: inherit;
    font-size: var(--fs-md);
    padding: 16px 26px;
    cursor: pointer;
    text-decoration: none;
    display: inline-block;
    transition: border-color 150ms;
    white-space: nowrap;
  }
  .btn-ghost:hover { border-color: var(--c-fg); }

  /* ── Dividers ────────────────────────────────────────── */
  .divider {
    height: 1px;
    background: var(--c-border);
  }

  /* ── Block (section) ─────────────────────────────────── */
  .block {
    display: flex;
    flex-direction: column;
    gap: 26px;
  }
  /* Anchor-scroll offset so sticky topbar doesn't cover section titles */
  #features,
  #como-funciona,
  #install {
    scroll-margin-top: 90px;
  }
  .block-header {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .h2 {
    font-size: var(--fs-md);
    font-weight: 400;
    color: var(--c-fg);
    margin: 0;
    letter-spacing: 0.24px;
  }
  .block-hint {
    font-size: var(--fs-md);
    color: var(--c-fg);
    margin: 0;
  }

  /* ── Tools grid ──────────────────────────────────────── */
  .grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 16px;
  }
  @media (min-width: 768px) {
    .grid { grid-template-columns: repeat(3, minmax(0, 1fr)); }
  }
  .tool-card {
    background: var(--c-surface);
    border-radius: var(--r);
    padding: 19px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    transition: outline-color 150ms;
    outline: 1px solid transparent;
  }
  .tool-card:hover { outline-color: var(--c-border); }
  .tool-icon {
    width: 18px;
    height: 18px;
    display: block;
    color: var(--c-fg);
    margin-bottom: 6px;
    shape-rendering: crispEdges;
  }
  .tool-name {
    color: var(--c-fg);
    font-size: var(--fs-md);
    font-family: inherit;
    overflow-wrap: anywhere;
  }
  .tool-desc {
    color: var(--c-fg);
    font-size: var(--fs-base);
    margin: 0;
    line-height: 1.4;
  }

  /* Extra tools hidden by default; revealed when grid.expanded */
  .tool-extra { display: none; }
  .grid.expanded .tool-extra { display: flex; }

  /* Toggle button styled like .link-arrow */
  .link-arrow-btn {
    background: transparent;
    border: none;
    border-bottom: 1px solid var(--c-border);
    border-radius: 0;
    color: var(--c-fg);
    font-family: inherit;
    font-size: var(--fs-md);
    letter-spacing: 0.24px;
    padding: 0 0 2px;
    cursor: pointer;
    align-self: flex-start;
    transition: border-color 150ms;
  }
  .link-arrow-btn:hover { border-bottom-color: var(--c-fg); }

  /* ── Steps (install) ─────────────────────────────────── */
  .steps {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 26px;
  }
  .step {
    display: grid;
    grid-template-columns: 48px 1fr;
    gap: 16px;
    align-items: flex-start;
  }
  .step-num {
    color: var(--c-muted);
    font-size: var(--fs-md);
    padding-top: 1px;
  }
  .step-body {
    display: flex;
    flex-direction: column;
    gap: 8px;
    min-width: 0;
  }
  .step-body strong {
    color: var(--c-fg);
    font-weight: 400;
    font-size: var(--fs-md);
  }
  .step-desc {
    color: var(--c-fg);
    font-size: var(--fs-md);
    margin: 0;
    line-height: 1.5;
  }
  .step-desc-sm {
    color: var(--c-muted);
    font-size: var(--fs-base);
    margin: 0;
  }
  /* Example command panel — Steel Gray surface only, no border, no
     copy button (the command is illustrative; the real one with the
     user's token comes from /sign-in). Wraps long content naturally. */
  .install-code-shell {
    background: var(--c-surface);
    border-radius: var(--r);
    padding: 14px 18px;
  }
  .install-cmd-text {
    margin: 0;
  }
  .install-cmd-text code {
    color: var(--c-fg);
    font-family: inherit;
    font-size: var(--fs-sm);
    line-height: 1.6;
    display: block;
    white-space: pre-wrap;
    overflow-wrap: anywhere;
    user-select: all;
  }

  /* Inner terminal panel — black with thin border, corner copy button. */
  .code-block {
    position: relative;
    background: var(--c-bg);
    border: 1px solid var(--c-border);
    border-radius: 8px;
    overflow: hidden;
  }
  .code-block-content {
    margin: 0;
    padding: 14px 80px 14px 16px;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }
  .code-block-content code {
    color: var(--c-fg);
    font-size: var(--fs-sm);
    font-family: inherit;
    line-height: 1.6;
    display: block;
    white-space: pre-wrap;
    overflow-wrap: anywhere;
  }
  /* Text-based copy chip — same `[ copiar ]` look as /sign-in. */
  .code-copy {
    position: absolute;
    top: 8px;
    right: 8px;
    background: transparent;
    border: 1px solid var(--c-border);
    border-radius: 6px;
    color: var(--c-muted);
    cursor: pointer;
    padding: 4px 10px;
    font-family: inherit;
    font-size: var(--fs-sm);
    letter-spacing: 0.24px;
    line-height: 1;
    white-space: nowrap;
    transition: color 150ms, border-color 150ms;
  }
  .code-copy:hover { color: var(--c-fg); border-color: var(--c-fg); }
  .code-copy.copied { color: var(--c-fg); border-color: var(--c-fg); }

  /* ── How-it-works terminal demo ─────────────────────────── */
  .hiw-terminal {
    background: var(--c-surface);
    border: 1px solid var(--c-border);
    border-radius: var(--r);
    overflow: hidden;
  }
  .hiw-bar {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 9px 19px;
    background: var(--c-bg);
    border-bottom: 1px solid var(--c-border);
  }
  .hiw-chrome-dots {
    color: var(--c-border);
    font-size: 8px;
    letter-spacing: 3px;
    flex-shrink: 0;
  }
  .hiw-bar-label {
    font-size: var(--fs-sm);
    color: var(--c-muted);
  }
  .hiw-body {
    padding: 22px 22px 18px;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .hiw-prompt-row {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: var(--fs-md);
    flex-wrap: wrap;
    min-height: 22px;
  }
  .hiw-question {
    color: var(--c-fg);
  }
  .hiw-calling {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: var(--fs-sm);
    color: var(--c-muted);
  }
  .hiw-tool-chip {
    font-family: inherit;
    font-size: var(--fs-xs);
    color: var(--c-fg);
    background: var(--c-bg);
    border: 1px solid var(--c-border);
    border-radius: 4px;
    padding: 1px 7px;
    letter-spacing: 0;
  }
  .hiw-output {
    margin: 0;
    padding: 14px 16px;
    background: var(--c-bg);
    border: 1px solid var(--c-border);
    border-radius: 8px;
    min-height: 185px;
  }
  .hiw-output code {
    font-family: inherit;
    font-size: var(--fs-sm);
    line-height: 1.65;
    color: var(--c-fg);
    display: block;
    white-space: pre-wrap;
    overflow-wrap: anywhere;
  }
  .hiw-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 10px 19px 12px;
    border-top: 1px solid var(--c-border);
  }
  .hiw-nav-dots {
    display: flex;
    gap: 6px;
    align-items: center;
  }
  .hiw-nav-dot {
    width: 20px;
    height: 4px;
    border-radius: 2px;
    background: var(--c-border);
    border: none;
    padding: 0;
    cursor: pointer;
    transition: background 200ms, width 200ms;
    flex-shrink: 0;
  }
  .hiw-nav-dot.active {
    background: var(--c-fg);
    width: 28px;
  }
  .hiw-nav-dot:hover:not(.active) {
    background: var(--c-muted);
  }
  .hiw-progress-track {
    flex: 1;
    height: 1px;
    background: var(--c-border);
    overflow: hidden;
    max-width: 180px;
  }
  .hiw-pbar {
    height: 100%;
    background: var(--c-fg);
    width: 0%;
  }

  /* ── Final CTA ───────────────────────────────────────── */
  .final {
    align-items: flex-start;
    padding: 32px 0;
  }
  .ready {
    font-size: var(--fs-md);
    color: var(--c-muted);
    margin: 0;
  }
  .small { font-size: var(--fs-md); }

  /* ── Link with arrow ─────────────────────────────────── */
  .link-arrow {
    color: var(--c-fg);
    text-decoration: none;
    font-size: var(--fs-md);
    border-bottom: 1px solid var(--c-border);
    padding-bottom: 2px;
    align-self: flex-start;
    transition: border-color 150ms;
  }
  .link-arrow:hover { border-color: var(--c-fg); }

  /* ── Helpers ─────────────────────────────────────────── */
  .muted { color: var(--c-muted); }

  /* ── Bottom bar ──────────────────────────────────────── */
  .bottom-bar {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 19px 32px;
    border-top: 1px solid var(--c-border);
    font-size: var(--fs-md);
    flex-wrap: wrap;
  }
  .bottom-bar .dot-sep { color: var(--c-border); }
  /* Build fingerprint: deliberately quiet — short SHA + UTC date in the
     same muted gray as the rest of the footer. Useful to confirm at a
     glance which deploy is live without competing for attention. */
  .build-info {
    font-size: var(--fs-sm);
    color: var(--c-muted);
    letter-spacing: 0.04em;
  }
  .build-info .link-muted { font-size: inherit; }

  /* ── Responsive ──────────────────────────────────────── */
  @media (max-width: 768px) {
    .topbar { padding: 14px 16px; gap: 12px; }
    .topnav { display: none; }
    /* Push actions to the right edge — the hidden .topnav can't do it. */
    .topbar-actions { gap: 12px; margin-left: auto; }
    :global(.brand-mark) { height: 19px; width: 110px; }
    .main { padding: 32px 16px; gap: 26px; }
    .hero { padding: 16px 0; gap: 19px; }
    .h1 { font-size: var(--fs-xl); }
    /* Demote secondary copy on mobile so the H1 + tool-card names + CTAs
