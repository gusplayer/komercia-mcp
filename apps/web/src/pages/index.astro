        </button>
        <a href="https://github.com/gusplayer/komercia-mcp" target="_blank" rel="noopener noreferrer" class="btn-ghost-pill btn-icon-only" aria-label="Ver repositorio en GitHub" title="Ver repositorio en GitHub">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
          </svg>
        </a>
      </div>
    </header>

    <main class="main">

      <!-- ── Hero ──────────────────────────────────────── -->
      <section class="hero">
        <div class="prompt">
          <span class="muted">user@komercia ~$</span>
          <span class="cmd">./mcp.connect</span><span class="caret">_</span>
        </div>

        <h1 class="h1">
          <span id="h1-main" data-scramble data-t-es="Los datos de tu tienda," data-t-en="Your store data,">Los datos de tu tienda,</span><br />
          <span id="h1-muted" class="muted" data-scramble data-t-es="en lenguaje natural." data-t-en="in natural language.">en lenguaje natural.</span>
        </h1>

        <p id="hero-lede" class="lede" data-scramble data-t-es="El servidor MCP oficial para Komercia. Pregúntale a Claude lo que sea sobre tu tienda — productos, ventas, clientes, inventario — sin escribir una línea de código." data-t-en="The official MCP server for Komercia. Ask Claude anything about your store — products, orders, customers, inventory — without writing a line of code.">
          El servidor MCP oficial para Komercia. Pregúntale a Claude lo que sea sobre tu tienda — productos, ventas, clientes, inventario — sin escribir una línea de código.
        </p>

        <div class="cta-row">
          <a href="/sign-in" class="btn-primary" data-t-es="obtener_token →" data-t-en="get_token →">obtener_token →</a>
          <a href="#install" class="btn-ghost" data-t-es="cómo_funciona" data-t-en="how_it_works">cómo_funciona</a>
        </div>

        <ul class="trust">
          <li><span class="dot">●</span> <span data-t-es="11 herramientas" data-t-en="11 tools">11 herramientas</span></li>
          <li><span class="dot">●</span> <span data-t-es="Solo lectura" data-t-en="Read-only">Solo lectura</span></li>
          <li><span class="dot">●</span> <span data-t-es="Open source" data-t-en="Open source">Open source</span></li>
        </ul>
      </section>

      <div class="divider"></div>

      <!-- ── Features ──────────────────────────────────── -->
      <section id="features" class="block">
        <div class="block-header">
          <h2 class="h2" data-t-es="&gt; herramientas" data-t-en="&gt; features">&gt; herramientas</h2>
          <p class="block-hint" data-scramble data-t-es="11 herramientas MCP. Todas de solo lectura." data-t-en="11 MCP tools. All read-only.">11 herramientas MCP. Todas de solo lectura.</p>
        </div>

        <div class="grid" id="tools-grid">
          {tools.map((t, i) => (
            <article class={i < visibleCount ? 'tool-card' : 'tool-card tool-extra'} aria-hidden={i < visibleCount ? 'false' : 'true'}>
              <svg class="tool-icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="square" stroke-linejoin="miter" aria-hidden="true" set:html={icons[t.name]} />
              <code class="tool-name">{t.name}</code>
              <p class="tool-desc" data-t-es={t.descEs} data-t-en={t.descEn}>{t.descEs}</p>
            </article>
          ))}
        </div>

        <button type="button" id="toggle-tools" class="link-arrow-btn" aria-expanded="false" aria-controls="tools-grid" data-t-es="ver las 5 restantes →" data-t-en="see the remaining 5 →">ver las 5 restantes →</button>
      </section>

      <div class="divider"></div>

      <!-- ── Install ───────────────────────────────────── -->
      <section id="install" class="block">
        <div class="block-header">
          <h2 class="h2" data-t-es="&gt; instalación" data-t-en="&gt; install">&gt; instalación</h2>
          <p class="block-hint" data-scramble data-t-es="Tres pasos. Cinco minutos. Sin código." data-t-en="Three steps. Five minutes. No code.">Tres pasos. Cinco minutos. Sin código.</p>
        </div>

        <ol class="steps">
          <li class="step">
            <span class="step-num">[01]</span>
            <div class="step-body">
              <strong>get_token</strong>
              <p class="step-desc" data-t-es="Inicia sesión con tus credenciales de Komercia. Token de solo lectura, válido 6 meses." data-t-en="Log in with your Komercia credentials. Token is read-only, valid for 6 months.">Inicia sesión con tus credenciales de Komercia. Token de solo lectura, válido 6 meses.</p>
              <a href="/sign-in" class="link-arrow">/sign-in →</a>
            </div>
          </li>

          <li class="step">
            <span class="step-num">[02]</span>
            <div class="step-body">
              <strong>connect_client</strong>
              <p class="step-desc" data-t-es="Elige uno. Claude Code es el más simple — un solo comando." data-t-en="Pick one. Claude Code is the simplest — single command.">Elige uno. Claude Code es el más simple — un solo comando.</p>
              <div class="code-block">
                <pre class="code-block-content"><code id="install-cmd">claude mcp add --transport sse komercia \
  https://api-mcp.komercia.co/sse \
  --header "Authorization: Bearer &lt;TOKEN&gt;"</code></pre>
                <button type="button" class="code-copy" data-copy-target="install-cmd" aria-label="Copiar comando" title="Copiar comando">
                  <svg class="copy-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="square" stroke-linejoin="miter" aria-hidden="true">
                    <rect x="9" y="9" width="13" height="13" rx="1" ry="1"/>
                    <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
                  </svg>
                  <svg class="copy-check" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="square" stroke-linejoin="miter" aria-hidden="true" style="display:none;">
                    <polyline points="20 6 9 17 4 12"/>
                  </svg>
                </button>
              </div>
              <p class="step-desc-sm" data-t-es="También funciona con Claude.ai, Claude Desktop, Cursor y ChatGPT." data-t-en="Also works with Claude.ai, Claude Desktop, Cursor, and ChatGPT.">También funciona con Claude.ai, Claude Desktop, Cursor y ChatGPT.</p>
            </div>
          </li>

          <li class="step">
            <span class="step-num">[03]</span>
            <div class="step-body">
              <strong>ask_anything</strong>
              <p class="step-desc" data-t-es="Abre un chat de Claude. Pregunta en lenguaje natural. Claude llama a las herramientas MCP y responde con tus datos reales." data-t-en="Open a Claude chat. Ask in plain English. Claude calls the MCP tools and answers with your real data.">Abre un chat de Claude. Pregunta en lenguaje natural. Claude llama a las herramientas MCP y responde con tus datos reales.</p>
            </div>
          </li>
        </ol>

        <div class="install-clients">
          <p class="clients-label" data-t-es="¿Usas otro cliente? MCP funciona en:" data-t-en="Using a different client? MCP works in:">¿Usas otro cliente? MCP funciona en:</p>
          <div class="clients-row">
            {installMethods.map((m) => (
              <button type="button" class="client-chip" data-install-target={m.id}>{m.name}</button>
            ))}
          </div>
          <button type="button" id="open-install-modal" class="link-arrow-btn" data-install-target="all" data-t-es={`Ver guía para los ${installMethods.length} clientes →`} data-t-en={`See setup guide for all ${installMethods.length} clients →`}>{`Ver guía para los ${installMethods.length} clientes →`}</button>
        </div>
      </section>

      <div class="divider"></div>

      <!-- ── Examples ──────────────────────────────────── -->
      <section id="examples" class="block">
        <div class="block-header">
          <h2 class="h2" data-t-es="&gt; ejemplos" data-t-en="&gt; examples">&gt; ejemplos</h2>
          <p class="block-hint" data-scramble data-t-es="Prompts que funcionan hoy. Pega en Claude." data-t-en="Prompts that work today. Paste into Claude.">Prompts que funcionan hoy. Pega en Claude.</p>
        </div>

        <ul class="examples">
          {examples.map((q) => (
            <li class="example">
              <span class="prompt-mark">&gt;</span>
              <span data-t-es={q.es} data-t-en={q.en}>{q.es}</span>
            </li>
          ))}
        </ul>

        <button type="button" id="open-recetas" class="link-arrow-btn" data-t-es="Ver los 18 prompts curados →" data-t-en="See all 18 curated prompts →">Ver los 18 prompts curados →</button>
      </section>

      <div class="divider"></div>

      <!-- ── Final CTA ─────────────────────────────────── -->
      <section class="block final">
        <p class="ready" data-scramble data-t-es="¿Listo?" data-t-en="Ready?">¿Listo?</p>
        <a href="/sign-in" class="btn-primary btn-primary-lg" data-t-es="obtener_token →" data-t-en="get_token →">obtener_token →</a>
        <p class="muted small" data-scramble data-t-es="Es gratis. 30 segundos. Tú guardas el token." data-t-en="It's free. 30 seconds. You keep the token.">Es gratis. 30 segundos. Tú guardas el token.</p>
      </section>

    </main>

    <!-- ── Install methods modal ─────────────────────── -->
    <div id="install-modal" class="modal-overlay" aria-hidden="true" role="dialog" aria-modal="true" aria-labelledby="install-modal-title">
      <div class="modal-window" role="document">

        <header class="modal-header">
          <span class="modal-title" id="install-modal-title">
            <span class="muted">user@komercia ~$</span> ./install.guide<span class="caret">_</span>
          </span>
          <button type="button" class="modal-close" aria-label="Cerrar modal" title="Cerrar (esc)">[ × ]</button>
        </header>

        <div class="modal-info">
          <span data-t-es={`${installMethods.length} clientes soportados · click para filtrar`} data-t-en={`${installMethods.length} clients supported · click to filter`}>{installMethods.length} clientes soportados · click para filtrar</span>
        </div>

        <nav class="modal-filters" aria-label="Filtrar por cliente">
          <button type="button" class="filter-btn install-filter active" data-cat="all">
            <span data-t-es="todos" data-t-en="all">todos</span>
            <span class="count">({installMethods.length})</span>
          </button>
          {installMethods.map((m) => (
            <button type="button" class="filter-btn install-filter" data-cat={m.id}>{m.name}</button>
          ))}
        </nav>

        <div class="modal-body">
          {installMethods.map((m) => (
            <article class="install-method" data-cat={m.id}>
              <div class="method-header">
                <h3 class="method-name">{m.name}</h3>
                <span class="method-badge" data-t-es={m.badgeEs} data-t-en={m.badgeEn}>{m.badgeEs}</span>
              </div>
              <p class="method-desc" data-t-es={m.descEs} data-t-en={m.descEn}>{m.descEs}</p>

              <ol class="method-steps">
                {m.steps.map((step, si) => {
                  const codeId = `install-${m.id}-step-${si}`;
                  const stepNum = `[${String(si + 1).padStart(2, '0')}]`;
                  return (
                    <li class="method-step">
                      <span class="step-num">{stepNum}</span>
                      <div class="step-body">
                        <p class="step-title" data-t-es={step.titleEs} data-t-en={step.titleEn}>{step.titleEs}</p>
                        {step.code && (
                          <div class="code-block">
                            <pre class="code-block-content"><code id={codeId}>{step.code}</code></pre>
                            <button type="button" class="code-copy" data-copy-target={codeId} aria-label="Copiar" title="Copiar">
                              <svg class="copy-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="square" stroke-linejoin="miter" aria-hidden="true">
                                <rect x="9" y="9" width="13" height="13" rx="1" ry="1"/>
                                <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
                              </svg>
                              <svg class="copy-check" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="square" stroke-linejoin="miter" aria-hidden="true" style="display:none;">
                                <polyline points="20 6 9 17 4 12"/>
                              </svg>
                            </button>
                          </div>
                        )}
                      </div>
                    </li>
                  );
                })}
              </ol>

              {m.tipEs && (
                <p class="method-tip">
                  <span class="muted">tip ·</span>
                  <span data-t-es={m.tipEs} data-t-en={m.tipEn ?? m.tipEs}>{m.tipEs}</span>
                </p>
              )}
            </article>
          ))}
        </div>

        <footer class="modal-footer">
          <span class="muted" data-t-es="[ esc ] cerrar · click fuera para cerrar" data-t-en="[ esc ] close · click outside to close">[ esc ] cerrar · click fuera para cerrar</span>
        </footer>
      </div>
    </div>

    <!-- ── Prompt library modal ──────────────────────── -->
    <div id="recetas-modal" class="modal-overlay" aria-hidden="true" role="dialog" aria-modal="true" aria-labelledby="modal-title">
      <div class="modal-window" role="document">

        <header class="modal-header">
          <span class="modal-title" id="modal-title">
            <span class="muted">user@komercia ~$</span> ./prompts.library<span class="caret">_</span>
          </span>
          <button type="button" class="modal-close" aria-label="Cerrar modal" title="Cerrar (esc)">[ × ]</button>
        </header>

        <div class="modal-info">
          <span data-t-es="18 prompts curados · 4 categorías · click para copiar" data-t-en="18 curated prompts · 4 categories · click to copy">18 prompts curados · 4 categorías · click para copiar</span>
        </div>

        <nav class="modal-filters" aria-label="Filtrar por categoría">
          <button type="button" class="filter-btn active" data-cat="all">
            <span data-t-es="todos" data-t-en="all">todos</span>
            <span class="count">({recetas.length})</span>
          </button>
          {categories.map((c) => {
            const sample = recetas.find((r) => r.cat === c);
            return (
              <button type="button" class="filter-btn" data-cat={c}>
                <span data-t-es={sample?.catEs} data-t-en={sample?.catEn}>{sample?.catEs}</span>
                <span class="count">({catCounts[c]})</span>
              </button>
            );
          })}
        </nav>

        <div class="modal-body">
          {recetas.map((r, i) => (
            <article class="recipe" data-cat={r.cat}>
              <div class="recipe-meta">
                <span class="recipe-tag">
                  <span data-t-es={r.catEs} data-t-en={r.catEn}>{r.catEs}</span>
                  · {r.tools.length} {r.tools.length === 1 ? 'tool' : 'tools'}
                </span>
                <button type="button" class="recipe-copy" data-prompt-es={r.promptEs} data-prompt-en={r.promptEn} aria-label="Copiar prompt">
                  <span data-t-es="[ copiar ]" data-t-en="[ copy ]">[ copiar ]</span>
                </button>
              </div>
              <p class="recipe-prompt">
                <span class="muted">&gt;</span> <span class="recipe-prompt-text" data-t-es={r.promptEs} data-t-en={r.promptEn}>{r.promptEs}</span>
              </p>
              <div class="recipe-response">
                <div class="recipe-response-label muted">claude:</div>
                {r.response.map((line) => <div>{line || ' '}</div>)}
              </div>
              <div class="recipe-tools">
                {r.tools.map((t) => <code>{t}</code>)}
              </div>
            </article>
          ))}
        </div>

        <footer class="modal-footer">
          <span class="muted" data-t-es="[ esc ] cerrar · click fuera para cerrar" data-t-en="[ esc ] close · click outside to close">[ esc ] cerrar · click fuera para cerrar</span>
        </footer>
      </div>
    </div>

    <!-- ── Footer ────────────────────────────────────── -->
    <footer class="bottom-bar">
      <span class="muted">komercia/mcp v0.1</span>
      <span class="dot-sep">·</span>
      <a href="https://github.com/gusplayer/komercia-mcp" target="_blank" rel="noopener noreferrer" class="link-muted">source</a>
    </footer>
  </div>
</Base>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&display=swap');

  .page {
    --c-bg: #000000;
    --c-fg: #ffffff;
    --c-surface: #1d1d1d;
    --c-border: #383838;
    --c-muted: #888888;
    --r: 10px;

    min-height: 100vh;
    background: var(--c-bg);
    color: var(--c-fg);
    font-family: 'Space Mono', ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 16px;
    line-height: 1.4;
    letter-spacing: 0.24px;
    font-feature-settings: 'zero';
    display: flex;
    flex-direction: column;
  }
  :global(body:has(.page)) { background: #000000; }

  /* ── Top bar ─────────────────────────────────────────── */
  .topbar {
    display: flex;
    align-items: center;
    gap: 24px;
    padding: 19px 32px;
    border-bottom: 1px solid var(--c-border);
    position: sticky;
    top: 0;
    background: rgba(0, 0, 0, 0.85);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    z-index: 10;
  }
  .brand {
    color: var(--c-fg);
    text-decoration: none;
    font-size: 16px;
    flex-shrink: 0;
  }
  .brand:hover { color: var(--c-muted); }
  .topnav {
    display: flex;
    gap: 24px;
    flex: 1;
  }
  .topbar-actions {
    display: flex;
    align-items: center;
    gap: 16px;
    flex-shrink: 0;
  }
  .link-muted {
    color: var(--c-muted);
    text-decoration: none;
    font-size: 16px;
    transition: color 150ms;
  }
  .link-muted:hover { color: var(--c-fg); }
  /* Shared sizing — every topbar button is exactly 36px tall, box-sized */
  .btn-pill,
  .btn-ghost-pill {
    height: 36px;
    box-sizing: border-box;
    display: inline-flex;
    align-items: center;
    border-radius: var(--r);
    font-family: inherit;
    letter-spacing: 0.24px;
    cursor: pointer;
    white-space: nowrap;
    text-decoration: none;
    line-height: 1;
  }

  /* Primary CTA — high-contrast filled (099 spec) */
  .btn-pill {
    background: var(--c-fg);
    color: var(--c-bg);
    border: 1px solid var(--c-fg);
    padding: 0 16px;
    font-size: 16px;
    transition: background 150ms, border-color 150ms;
  }
  .btn-pill:hover { background: var(--c-muted); border-color: var(--c-muted); }

  /* Ghost pill — transparent + 1px border, used for utility actions (099 spec) */
  .btn-ghost-pill {
    background: transparent;
    color: var(--c-fg);
    border: 1px solid var(--c-border);
    padding: 0 12px;
    font-size: 14px;
    gap: 8px;
    transition: border-color 150ms, color 150ms, background 150ms;
  }
  .btn-ghost-pill:hover {
    border-color: var(--c-fg);
    background: var(--c-surface);
  }
  .btn-ghost-pill svg { display: block; flex-shrink: 0; }
  .btn-ghost-pill.btn-icon-only {
    padding: 0;
    width: 36px;
    justify-content: center;
  }

  /* ── Main ────────────────────────────────────────────── */
  .main {
    flex: 1;
    width: 100%;
    max-width: 880px;
    margin: 0 auto;
    padding: 48px 32px;
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  /* ── Prompt + caret ──────────────────────────────────── */
  .prompt {
    font-size: 16px;
    color: var(--c-fg);
    margin: 0;
  }
  .prompt .muted { color: var(--c-muted); }
  .prompt .cmd { color: var(--c-fg); margin-left: 8px; }
  .caret {
    color: var(--c-fg);
    margin-left: 2px;
    animation: blink 1s steps(1) infinite;
  }
  @keyframes blink { 50% { opacity: 0; } }

  /* Text-scramble decryption effect — random glyphs shown during the
     "loading" phase before each character locks to its final form. */
  .scramble-dud {
    color: var(--c-muted);
    opacity: 0.65;
  }
  /* When JS is enabled, hide scramble elements until the observer kicks
     in. They become visible the moment their scramble animation starts,
     so there is no flash of the final text. */
  :global(html.js-enabled) [data-scramble]:not(.scramble-active) {
    visibility: hidden;
  }
  /* Respect users who prefer reduced motion — show text immediately. */
  @media (prefers-reduced-motion: reduce) {
    :global(html.js-enabled) [data-scramble]:not(.scramble-active) {
      visibility: visible;
    }
  }

  /* ── Hero ────────────────────────────────────────────── */
  .hero {
    display: flex;
    flex-direction: column;
    gap: 26px;
    padding: 32px 0;
  }
  .h1 {
    font-size: 32px;
    line-height: 1.2;
    font-weight: 400;
    letter-spacing: 0.24px;
    color: var(--c-fg);
    margin: 0;
  }
  .h1 .muted { color: var(--c-muted); }
  .lede {
    font-size: 16px;
    color: var(--c-fg);
    line-height: 1.5;
    margin: 0;
    max-width: 580px;
  }
  .cta-row {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }
  .trust {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 26px;
    font-size: 16px;
    color: var(--c-fg);
  }
  .trust li { display: flex; align-items: center; gap: 8px; }
  .trust .dot { color: var(--c-fg); }

  /* ── Buttons ─────────────────────────────────────────── */
  .btn-primary {
    background: var(--c-fg);
