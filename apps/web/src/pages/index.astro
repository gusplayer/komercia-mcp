        '│                            │\n' +
        '│ +15% projected if          │\n' +
        '│ inventory holds steady     │\n' +
        '└────────────────────────────┘',
        // 5. top customers / retention
        '┌─ customers.top ───────────┐\n' +
        '│                            │\n' +
        '│ 1. m.gomez@...             │\n' +
        '│    $890K · 8 órdenes       │\n' +
        '│    ★★★★★ loyal             │\n' +
        '│                            │\n' +
        '│ 2. l.rivera@...            │\n' +
        '│    $670K · 5 órdenes       │\n' +
        '│    ★★★★ vip                │\n' +
        '│                            │\n' +
        '│ 3. p.castro@...            │\n' +
        '│    $540K · 6 órdenes       │\n' +
        '│    ★★★★ vip                │\n' +
        '│                            │\n' +
        '├─ retention ────────────────┤\n' +
        '│                            │\n' +
        '│ return_rate     60% ↑      │\n' +
        '│ avg_orders      4.2        │\n' +
        '│ avg_lifetime    $2.4K      │\n' +
        '│                            │\n' +
        '│                            │\n' +
        '└────────────────────────────┘',
      ];

      var scrambleChars = '!<>-/[]{}=+*^?#0123456789';
      function isStructural(ch) {
        if (ch === ' ' || ch === '\n' || ch === '\t' || ch === '.') return true;
        return /[│┌┐└┘├┤┬┴┼─━┃═║▌▤▥▦▒▓⚠★↑↓↗↘•—]/.test(ch);
      }

      function scrambleTo(target) {
        // Slower, more "thinking/typing" feel: chars resolve mostly
        // in reading order (~85% left-to-right, ~15% random jitter)
        // and the whole transition takes ~2200ms so the change is
        // noticeable.
        var queue = [];
        for (var i = 0; i < target.length; i++) {
          var ch = target.charAt(i);
          queue.push({
            ch: ch,
            passThrough: isStructural(ch),
            resolveAt: (i / target.length) * 0.85 + Math.random() * 0.12,
          });
        }
        var duration = 2800;
        var start = performance.now();
        function tick() {
          var elapsed = performance.now() - start;
          var progress = elapsed / duration;
          if (progress > 1) progress = 1;
          var out = '';
          for (var k = 0; k < queue.length; k++) {
            var q = queue[k];
            if (q.passThrough || progress >= q.resolveAt) {
              out += q.ch;
            } else {
              out += scrambleChars.charAt(Math.floor(Math.random() * scrambleChars.length));
            }
          }
          el.textContent = out;
          if (progress < 1) requestAnimationFrame(tick);
        }
        tick();
      }

      var idx = 0;
      setInterval(function () {
        idx = (idx + 1) % states.length;
        scrambleTo(states[idx]);
      }, 8000);
    })();
  })();
</script>
