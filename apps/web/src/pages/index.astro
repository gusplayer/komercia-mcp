          out: '✓ customers.csv  ready · 38.2 KB\n  423 contacts exported\n\n→ m.gomez@...  Bogotá\n→ l.rivera@... Medellín\n→ p.castro@... Cali\n  + 420 more rows',
        },
        {
          es: '¿qué productos tienen poco stock?',
          en: 'which products are running low on stock?',
          tool: 'export_inventory_movements',
          out: '⚠ stock_alert · 3 products\n\n→ bolso_lona       8u  restock soon\n→ pin_edt_lim      4u  ← critical\n→ stcks_pck       18u  low',
        },
        {
          es: 'exporta mi catálogo en formato shopify',
          en: 'export my catalog in shopify format',
          tool: 'export_products',
          out: '✓ catalog.shopify.csv  ready\n  86 products · 124 variants\n\n→ camiseta-negra-l  $38.900  sku_001\n→ pin-edicion-lim   $12.500  sku_022\n  + 83 more items',
        },
        {
          es: '¿qué métodos de pago tengo configurados?',
          en: 'what payment methods are configured?',
          tool: 'list_payment_gateways',
          out: 'configured · 3 active gateways\n\n✓ Wompi           active\n✓ PayU Colombia   active\n✓ Contra-entrega  active\n  PayPal          inactive',
        },
      ];

      // Build nav dots. Plain buttons with aria-current — using role="tab"
      // without a paired tabpanel would mislead assistive tech.
      useCases.forEach(function (_, i) {
        var btn = document.createElement('button');
        btn.className = 'hiw-nav-dot';
        btn.type = 'button';
        btn.setAttribute('aria-label', 'Show example ' + (i + 1) + ' of ' + useCases.length);
        btn.setAttribute('data-hiw-i', String(i));
        navDotsEl.appendChild(btn);
      });
      var navDots = navDotsEl.querySelectorAll('.hiw-nav-dot');

      function setDots(idx) {
        for (var i = 0; i < navDots.length; i++) {
          navDots[i].classList.toggle('active', i === idx);
          if (i === idx) navDots[i].setAttribute('aria-current', 'true');
          else navDots[i].removeAttribute('aria-current');
        }
      }

      function startPbar() {
        if (!pbarEl) return;
        pbarEl.style.transition = 'none';
        pbarEl.style.width = '0%';
        void pbarEl.offsetWidth;
        pbarEl.style.transition = 'width ' + CYCLE_MS + 'ms linear';
        pbarEl.style.width = '100%';
      }

      function typeQuestion(text, gen, done) {
        questionEl.textContent = '';
        var i = 0;
        function step() {
          if (gen !== hiwGen) return; // a newer case took over
          if (i < text.length) {
            questionEl.textContent += text.charAt(i);
            i++;
            typingTimer = setTimeout(step, 28 + Math.random() * 22);
          } else {
            done();
          }
        }
        step();
      }

      function revealOutput(text, gen) {
        var CHARS = '!<>-_[]{}=+*?#$0123456789';
        var passRe = /[✓⚠→←↑↓·\s]/;
        var total = 0;
        for (var ci = 0; ci < text.length; ci++) {
          if (text.charAt(ci) !== '\n') total++;
        }
        var chars = [];
        var pos = 0;
        for (var i = 0; i < text.length; i++) {
          var ch = text.charAt(i);
          chars.push({
            ch: ch,
            pass: passRe.test(ch),
            at: ch === '\n' ? 0 : pos / total,
          });
          if (ch !== '\n') pos++;
        }
        var duration = 1300;
        var start = performance.now();
        function tick() {
          if (gen !== hiwGen) return; // a newer case took over
          var p = Math.min((performance.now() - start) / duration, 1);
          var out = '';
          for (var k = 0; k < chars.length; k++) {
            var c = chars[k];
            if (c.pass || p >= c.at) {
              out += c.ch;
            } else {
              out += CHARS.charAt(Math.floor(Math.random() * CHARS.length));
            }
          }
          outputCode.textContent = out;
          if (p < 1) requestAnimationFrame(tick);
        }
        tick();
      }

      function showCase(idx) {
        hiwIdx = idx;
        var gen = ++hiwGen;
        setDots(idx);
        var uc = useCases[idx];
        var q = current === 'en' ? uc.en : uc.es;

        clearTimeout(typingTimer);
        questionEl.textContent = '';
        callingEl.style.visibility = 'hidden';
        outputCode.textContent = '';
        startPbar();

        if (reduceMotion) {
          questionEl.textContent = q;
          if (toolNameEl) toolNameEl.textContent = uc.tool;
          callingEl.style.visibility = 'visible';
          outputCode.textContent = uc.out;
          return;
        }

        typeQuestion(q, gen, function () {
          if (gen !== hiwGen) return;
          if (toolNameEl) toolNameEl.textContent = uc.tool;
          callingEl.style.visibility = 'visible';
          setTimeout(function () {
            if (gen !== hiwGen) return;
            revealOutput(uc.out, gen);
          }, 380);
        });
      }

      function scheduleNext() {
        clearTimeout(hiwTimer);
        hiwTimer = setTimeout(function () {
          showCase((hiwIdx + 1) % useCases.length);
          scheduleNext();
        }, CYCLE_MS);
      }

      // Manual dot navigation
      for (var di = 0; di < navDots.length; di++) {
        (function (dot) {
          dot.addEventListener('click', function () {
            var idx = parseInt(dot.getAttribute('data-hiw-i'), 10);
            clearTimeout(typingTimer);
            clearTimeout(hiwTimer);
            showCase(idx);
            scheduleNext();
          });
        })(navDots[di]);
      }

      // Pause on hover
      if (terminal) {
        terminal.addEventListener('mouseenter', function () {
          clearTimeout(hiwTimer);
          if (pbarEl) {
            var w = window.getComputedStyle(pbarEl).width;
            pbarEl.style.transition = 'none';
            pbarEl.style.width = w;
          }
        });
        terminal.addEventListener('mouseleave', function () {
          scheduleNext();
          startPbar();
        });
      }

      // Re-render the active case when the user toggles language so the
      // typed question matches the new locale instead of waiting for the
      // next cycle to swap it in.
      var langBtn = document.getElementById('lang-toggle');
      if (langBtn) {
        langBtn.addEventListener('click', function () {
          // applyLang runs synchronously on click — re-show on the next
          // microtask so `current` is already updated.
          setTimeout(function () {
            clearTimeout(typingTimer);
            clearTimeout(hiwTimer);
            showCase(hiwIdx);
            scheduleNext();
          }, 0);
        });
      }

      showCase(0);
      scheduleNext();
    })();

    // ── Hero deco: cycle through different data "screens" ────
    (function () {
      var el = document.getElementById('deco-content');
      if (!el) return;
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

      // All states are normalised to the same height (22 lines · 30
       // cols) so the box never grows or shrinks between transitions.
      var states = [
        // 1. live store snapshot (matches initial HTML)
        '┌─ store.live ──────────────┐\n' +
