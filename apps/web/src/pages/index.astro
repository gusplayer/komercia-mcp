                <span class="muted">&gt;</span> <span class="recipe-prompt-text" data-t-es={r.promptEs} data-t-en={r.promptEn}>{r.promptEs}</span>
              </p>
              <div class="recipe-response">
                <div class="recipe-response-label muted">claude:</div>
                {r.response.map((line) => <div>{line || ' '}</div>)}
              </div>
              <div class="recipe-tools">
                {r.tools.map((t) => <code>{t}</code>)}
              </div>
            </article>
          ))}
        </div>

        <footer class="modal-footer">
          <span class="muted" data-t-es="[ esc ] cerrar · click fuera para cerrar" data-t-en="[ esc ] close · click outside to close">[ esc ] cerrar · click fuera para cerrar</span>
