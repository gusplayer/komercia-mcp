    padding: 14px 24px;
    border-bottom: 1px solid var(--c-border);
    flex-shrink: 0;
  }
  .modal-title {
    font-family: inherit;
    font-size: 16px;
    color: var(--c-fg);
  }
  .modal-close {
    background: transparent;
    border: none;
    color: var(--c-muted);
    font-family: inherit;
    font-size: 16px;
    cursor: pointer;
    padding: 4px 8px;
    transition: color 150ms;
  }
  .modal-close:hover { color: var(--c-fg); }

  .modal-info {
    padding: 12px 24px;
    border-bottom: 1px solid var(--c-border);
    color: var(--c-muted);
    font-size: 14px;
    flex-shrink: 0;
  }

  .modal-filters {
    display: flex;
    gap: 8px;
    padding: 12px 24px;
    border-bottom: 1px solid var(--c-border);
    overflow-x: auto;
    flex-shrink: 0;
    -webkit-overflow-scrolling: touch;
  }
  .filter-btn {
    background: transparent;
    color: var(--c-muted);
    border: 1px solid var(--c-border);
    border-radius: var(--r);
    font-family: inherit;
    font-size: 14px;
    padding: 5px 12px;
    cursor: pointer;
    white-space: nowrap;
    transition: color 150ms, border-color 150ms, background 150ms;
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  .filter-btn:hover { color: var(--c-fg); border-color: var(--c-fg); }
  .filter-btn.active {
    background: var(--c-fg);
    color: var(--c-bg);
    border-color: var(--c-fg);
  }
  .filter-btn .count { opacity: 0.7; font-size: 13px; }

  .modal-body {
    flex: 1;
    overflow-y: auto;
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 28px;
    -webkit-overflow-scrolling: touch;
  }

  .recipe {
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding-bottom: 24px;
    border-bottom: 1px dashed var(--c-border);
  }
  .recipe:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }
  .recipe.hidden { display: none; }

  .recipe-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    font-size: 13px;
  }
  .recipe-tag {
    color: var(--c-muted);
    text-transform: lowercase;
    letter-spacing: 0.04em;
  }
  .recipe-copy {
    background: transparent;
    color: var(--c-muted);
    border: 1px solid var(--c-border);
    border-radius: var(--r);
    font-family: inherit;
    font-size: 13px;
    padding: 4px 10px;
    cursor: pointer;
    white-space: nowrap;
    transition: color 150ms, border-color 150ms;
  }
  .recipe-copy:hover { color: var(--c-fg); border-color: var(--c-fg); }
  .recipe-copy.copied { color: var(--c-fg); border-color: var(--c-fg); }

  .recipe-prompt {
    font-size: 16px;
    color: var(--c-fg);
    margin: 0;
    line-height: 1.4;
  }

  .recipe-response {
    background: var(--c-surface);
    border-radius: var(--r);
    padding: 16px 19px;
    display: flex;
    flex-direction: column;
    font-size: 14px;
    color: var(--c-fg);
    line-height: 1.5;
  }
  .recipe-response-label {
    margin-bottom: 8px;
  }
  .recipe-response > div { white-space: pre; min-height: 1em; }

  .recipe-tools {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }
  .recipe-tools code {
    font-family: inherit;
    font-size: 12px;
    color: var(--c-muted);
    background: var(--c-surface);
    border: 1px solid var(--c-border);
    border-radius: 4px;
    padding: 2px 8px;
    line-height: 1.4;
  }

  .modal-footer {
    padding: 12px 24px;
    border-top: 1px solid var(--c-border);
    font-size: 13px;
    flex-shrink: 0;
  }

  /* Lock body scroll when modal is open */
  :global(html.modal-open) :global(body) {
    overflow: hidden;
  }

  @media (max-width: 640px) {
    .modal-overlay { padding: 16px 12px; }
    .modal-header { padding: 12px 16px; }
    .modal-info, .modal-filters, .modal-body, .modal-footer { padding-left: 16px; padding-right: 16px; }
    .modal-title { font-size: 14px; }
    .recipe-response { padding: 12px 14px; font-size: 13px; }
    .recipe-prompt { font-size: 15px; }
  }
</style>

<script is:inline>
  (function () {
    function applyLang(lang) {
      document.documentElement.lang = lang;
      var els = document.querySelectorAll('[data-t-es]');
      for (var i = 0; i < els.length; i++) {
        var el = els[i];
        var text = lang === 'en' ? el.getAttribute('data-t-en') : el.getAttribute('data-t-es');
        if (text !== null) el.textContent = text;
      }
      var label = document.getElementById('lang-current');
      if (label) label.textContent = lang.toUpperCase();
    }

    var saved = localStorage.getItem('lang');
    var current = saved === 'en' ? 'en' : 'es';
    applyLang(current);

    var btn = document.getElementById('lang-toggle');
    if (btn) {
      btn.addEventListener('click', function () {
        current = current === 'es' ? 'en' : 'es';
        try { localStorage.setItem('lang', current); } catch (e) {}
        applyLang(current);
      });
    }

    // Tools expand/collapse
    var toolsToggle = document.getElementById('toggle-tools');
    var toolsExtra = document.getElementById('tools-extra');
    if (toolsToggle && toolsExtra) {
      toolsToggle.addEventListener('click', function () {
        var expanded = toolsExtra.classList.toggle('expanded');
        toolsToggle.setAttribute('aria-expanded', expanded ? 'true' : 'false');
        toolsExtra.setAttribute('aria-hidden', expanded ? 'false' : 'true');
        if (expanded) {
          toolsToggle.setAttribute('data-t-es', 'ocultar herramientas ↑');
          toolsToggle.setAttribute('data-t-en', 'hide tools ↑');
        } else {
          toolsToggle.setAttribute('data-t-es', 'ver las 5 restantes →');
          toolsToggle.setAttribute('data-t-en', 'see the remaining 5 →');
        }
        applyLang(current);
      });
    }

    // ── Typewriter intro animation ────────────────────────
    function typeText(el, text, speed) {
      return new Promise(function (resolve) {
        el.classList.add('is-typing');
        var i = 0;
        el.textContent = '';
        function tick() {
          if (i >= text.length) {
            el.classList.remove('is-typing');
            resolve();
            return;
          }
          el.textContent += text.charAt(i);
          i++;
          setTimeout(tick, speed);
        }
        tick();
      });
    }

    function runIntro() {
      if (!document.documentElement.classList.contains('intro-pending')) return;
      var ids = ['h1-main', 'h1-muted', 'hero-lede'];
      var els = [];
      for (var i = 0; i < ids.length; i++) {
        var e = document.getElementById(ids[i]);
        if (!e) { document.documentElement.classList.remove('intro-pending'); return; }
        els.push(e);
      }
      var texts = els.map(function (e) { return e.textContent; });
      els.forEach(function (e) { e.textContent = ''; });
      document.documentElement.classList.remove('intro-pending');

      setTimeout(function () {
        typeText(els[0], texts[0], 25)
          .then(function () { return new Promise(function (r) { setTimeout(r, 120); }); })
          .then(function () { return typeText(els[1], texts[1], 25); })
          .then(function () { return new Promise(function (r) { setTimeout(r, 200); }); })
          .then(function () { return typeText(els[2], texts[2], 12); })
          .then(function () {
            try { sessionStorage.setItem('intro-seen', '1'); } catch (e) {}
          });
      }, 250);
    }

    runIntro();

    // ── Code block copy buttons ───────────────────────────
    var codeCopyBtns = document.querySelectorAll('.code-copy');
    for (var ki = 0; ki < codeCopyBtns.length; ki++) {
      (function (btn) {
        btn.addEventListener('click', function () {
          var targetId = btn.getAttribute('data-copy-target');
          if (!targetId) return;
          var el = document.getElementById(targetId);
          if (!el) return;
          var text = el.textContent || '';
          var doCopy = navigator.clipboard
            ? navigator.clipboard.writeText(text)
            : Promise.resolve().then(function () {
                var ta = document.createElement('textarea');
                ta.value = text;
                ta.style.position = 'fixed';
                ta.style.opacity = '0';
                document.body.appendChild(ta);
                ta.select();
                document.execCommand('copy');
                document.body.removeChild(ta);
              });
          doCopy.then(function () {
            btn.classList.add('copied');
            setTimeout(function () { btn.classList.remove('copied'); }, 1800);
          });
        });
      })(codeCopyBtns[ki]);
    }

    // ── Prompt library modal ──────────────────────────────
    var modal = document.getElementById('recetas-modal');
    var openModalBtn = document.getElementById('open-recetas');
    if (modal && openModalBtn) {
      var modalCloseBtn = modal.querySelector('.modal-close');
      var filterBtns = modal.querySelectorAll('.filter-btn');
      var recipes = modal.querySelectorAll('.recipe');

      function openModal() {
        modal.setAttribute('aria-hidden', 'false');
        modal.classList.add('open');
        document.documentElement.classList.add('modal-open');
      }
      function closeModal() {
        modal.setAttribute('aria-hidden', 'true');
        modal.classList.remove('open');
        document.documentElement.classList.remove('modal-open');
      }

      openModalBtn.addEventListener('click', openModal);
      if (modalCloseBtn) modalCloseBtn.addEventListener('click', closeModal);

      modal.addEventListener('click', function (e) {
        if (e.target === modal) closeModal();
      });

      document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape' && modal.classList.contains('open')) closeModal();
      });

      // Category filter
      for (var fi = 0; fi < filterBtns.length; fi++) {
        (function (btn) {
          btn.addEventListener('click', function () {
            var cat = btn.getAttribute('data-cat');
            for (var i = 0; i < filterBtns.length; i++) filterBtns[i].classList.remove('active');
            btn.classList.add('active');
            for (var j = 0; j < recipes.length; j++) {
              var r = recipes[j];
              if (cat === 'all' || r.getAttribute('data-cat') === cat) r.classList.remove('hidden');
              else r.classList.add('hidden');
            }
          });
        })(filterBtns[fi]);
      }

      // Copy prompt (bilingual-aware)
      var copyBtns = modal.querySelectorAll('.recipe-copy');
      for (var ci = 0; ci < copyBtns.length; ci++) {
        (function (btn) {
          btn.addEventListener('click', function () {
            var text = current === 'en'
              ? btn.getAttribute('data-prompt-en')
              : btn.getAttribute('data-prompt-es');
            if (!text) return;
            var doCopy = navigator.clipboard
              ? navigator.clipboard.writeText(text)
              : Promise.resolve().then(function () {
                  var ta = document.createElement('textarea');
                  ta.value = text;
                  ta.style.position = 'fixed';
                  ta.style.opacity = '0';
                  document.body.appendChild(ta);
                  ta.select();
                  document.execCommand('copy');
                  document.body.removeChild(ta);
                });
            doCopy.then(function () {
              var span = btn.querySelector('span');
              if (!span) return;
              var orig = span.textContent;
              span.textContent = current === 'en' ? '[ ✓ copied ]' : '[ ✓ copiado ]';
              btn.classList.add('copied');
              setTimeout(function () {
                span.textContent = orig;
                btn.classList.remove('copied');
              }, 1500);
            });
          });
        })(copyBtns[ci]);
      }
    }
  })();
</script>
