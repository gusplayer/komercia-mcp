<Base
  title="komercia/mcp — los datos de tu tienda, en lenguaje natural"
  description="Servidor MCP oficial de Komercia. Pregúntale a Claude sobre tu tienda — productos, ventas, clientes, inventario. Solo lectura, open source."
>
  <div class="page">

    <!-- ── Top bar ─────────────────────────────────────── -->
    <header class="topbar">
      <a href="/" class="brand" aria-label="komercia mcp home">[komercia/mcp]</a>

      <nav class="topnav">
        <a href="#features" class="link-muted" data-t-es="herramientas" data-t-en="features">herramientas</a>
        <a href="#install" class="link-muted" data-t-es="instalación" data-t-en="install">instalación</a>
        <a href="#examples" class="link-muted" data-t-es="ejemplos" data-t-en="examples">ejemplos</a>
      </nav>

      <div class="topbar-actions">
