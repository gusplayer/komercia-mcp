      }
    }

    // ── Code block copy buttons ───────────────────────────
    var codeCopyBtns = document.querySelectorAll('.code-copy');
    for (var ki = 0; ki < codeCopyBtns.length; ki++) {
      (function (btn) {
        btn.addEventListener('click', function () {
          var targetId = btn.getAttribute('data-copy-target');
          if (!targetId) return;
          var el = document.getElementById(targetId);
          if (!el) return;
          var text = el.textContent || '';
          var doCopy = navigator.clipboard
            ? navigator.clipboard.writeText(text)
            : Promise.resolve().then(function () {
                var ta = document.createElement('textarea');
                ta.value = text;
                ta.style.position = 'fixed';
                ta.style.opacity = '0';
                document.body.appendChild(ta);
                ta.select();
                document.execCommand('copy');
                document.body.removeChild(ta);
              });
          doCopy.then(function () {
            btn.classList.add('copied');
            setTimeout(function () { btn.classList.remove('copied'); }, 1800);
          });
        });
      })(codeCopyBtns[ki]);
    }

    // ── Generic modal helpers ─────────────────────────────
    function openModal(modal) {
      modal.setAttribute('aria-hidden', 'false');
      modal.classList.add('open');
      document.documentElement.classList.add('modal-open');
    }
    function closeModal(modal) {
      modal.setAttribute('aria-hidden', 'true');
      modal.classList.remove('open');
      document.documentElement.classList.remove('modal-open');
    }

    // Global ESC handler — closes any open modal
    document.addEventListener('keydown', function (e) {
      if (e.key !== 'Escape') return;
      var openModals = document.querySelectorAll('.modal-overlay.open');
      for (var i = 0; i < openModals.length; i++) closeModal(openModals[i]);
    });

    // ── Install methods modal ─────────────────────────────
    var installModal = document.getElementById('install-modal');
    var installTriggers = document.querySelectorAll('[data-install-target]');
    if (installModal && installTriggers.length) {
      var installCloseBtn = installModal.querySelector('.modal-close');
      var installFilters = installModal.querySelectorAll('.install-filter');
      var installMethodsEls = installModal.querySelectorAll('.install-method');

      function applyInstallFilter(cat) {
        for (var i = 0; i < installFilters.length; i++) {
          if (installFilters[i].getAttribute('data-cat') === cat) installFilters[i].classList.add('active');
          else installFilters[i].classList.remove('active');
        }
        for (var j = 0; j < installMethodsEls.length; j++) {
          var m = installMethodsEls[j];
          if (cat === 'all' || m.getAttribute('data-cat') === cat) m.classList.remove('hidden');
          else m.classList.add('hidden');
        }
      }

      for (var ti = 0; ti < installTriggers.length; ti++) {
        (function (trigger) {
          trigger.addEventListener('click', function () {
            var target = trigger.getAttribute('data-install-target') || 'all';
            applyInstallFilter(target);
            openModal(installModal);
            // Scroll modal body back to top on open
            var body = installModal.querySelector('.modal-body');
            if (body) body.scrollTop = 0;
          });
        })(installTriggers[ti]);
      }

      if (installCloseBtn) installCloseBtn.addEventListener('click', function () { closeModal(installModal); });
      installModal.addEventListener('click', function (e) {
        if (e.target === installModal) closeModal(installModal);
      });
      for (var fi = 0; fi < installFilters.length; fi++) {
        (function (btn) {
          btn.addEventListener('click', function () {
            applyInstallFilter(btn.getAttribute('data-cat') || 'all');
          });
        })(installFilters[fi]);
      }
    }

    // ── Prompt library modal ──────────────────────────────
    var modal = document.getElementById('recetas-modal');
    var openModalBtn = document.getElementById('open-recetas');
    if (modal && openModalBtn) {
      var modalCloseBtn = modal.querySelector('.modal-close');
      var filterBtns = modal.querySelectorAll('.filter-btn:not(.install-filter)');
      var recipes = modal.querySelectorAll('.recipe');

      openModalBtn.addEventListener('click', function () { openModal(modal); });
      if (modalCloseBtn) modalCloseBtn.addEventListener('click', function () { closeModal(modal); });

      modal.addEventListener('click', function (e) {
        if (e.target === modal) closeModal(modal);
      });

      // Category filter
      for (var fi = 0; fi < filterBtns.length; fi++) {
        (function (btn) {
          btn.addEventListener('click', function () {
            var cat = btn.getAttribute('data-cat');
            for (var i = 0; i < filterBtns.length; i++) filterBtns[i].classList.remove('active');
            btn.classList.add('active');
            for (var j = 0; j < recipes.length; j++) {
              var r = recipes[j];
              if (cat === 'all' || r.getAttribute('data-cat') === cat) r.classList.remove('hidden');
              else r.classList.add('hidden');
            }
          });
        })(filterBtns[fi]);
      }

      // Copy prompt (bilingual-aware)
      var copyBtns = modal.querySelectorAll('.recipe-copy');
      for (var ci = 0; ci < copyBtns.length; ci++) {
        (function (btn) {
          btn.addEventListener('click', function () {
            var text = current === 'en'
              ? btn.getAttribute('data-prompt-en')
              : btn.getAttribute('data-prompt-es');
            if (!text) return;
            var doCopy = navigator.clipboard
              ? navigator.clipboard.writeText(text)
              : Promise.resolve().then(function () {
                  var ta = document.createElement('textarea');
                  ta.value = text;
                  ta.style.position = 'fixed';
                  ta.style.opacity = '0';
                  document.body.appendChild(ta);
                  ta.select();
                  document.execCommand('copy');
                  document.body.removeChild(ta);
                });
            doCopy.then(function () {
              var span = btn.querySelector('span');
              if (!span) return;
              var orig = span.textContent;
              span.textContent = current === 'en' ? '[ ✓ copied ]' : '[ ✓ copiado ]';
              btn.classList.add('copied');
              setTimeout(function () {
                span.textContent = orig;
                btn.classList.remove('copied');
              }, 1500);
            });
          });
        })(copyBtns[ci]);
      }
    }
  })();
</script>
