---
import Base from '../layouts/Base.astro';
import AnnouncementBanner from '../components/AnnouncementBanner.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import LoginForm from '../components/LoginForm.astro';
import ChatMock from '../components/ChatMock.astro';
import ScrollAnimate from '../components/ScrollAnimate.astro';
import { generateCsrfToken } from '../lib/csrf.js';

// Issue a CSRF token and set it as an HttpOnly-like cookie for the double-submit pattern.
// We use SameSite=Strict to mitigate CSRF; the cookie is readable by JS so the form can
// read it and send it back as a header.
const csrfToken = generateCsrfToken();
Astro.cookies.set('csrf_token', csrfToken, {
  path: '/',
  sameSite: 'strict',
  httpOnly: false,
  secure: import.meta.env.PROD,
  maxAge: 3600,
});

// Tools catalog data — keeps JSX clean and lets us stagger animations.
const tools = [
  { code: 'get_store_info',              desc: 'Info general: nombre, plan, dominio y estado de tu tienda',         prompt: '"¿Cuáles son los datos de mi tienda?"' },
  { code: 'validate_komercia_apis',      desc: 'Verifica que las APIs de Komercia estén disponibles',                prompt: '"¿Puedo conectarme a mi tienda?"' },
  { code: 'export_products',             desc: 'Catálogo en CSV, JSON, formato Shopify o WooCommerce',               prompt: '"Exporta mis productos a Shopify"' },
  { code: 'export_orders',               desc: 'Historial completo de ventas en CSV',                                prompt: '"Dame mis ventas del último año"' },
  { code: 'export_customers',            desc: 'Lista de clientes con direcciones e historial',                      prompt: '"Exporta todos mis clientes"' },
  { code: 'export_categories',           desc: 'Árbol de categorías de tu catálogo',                                 prompt: '"Muéstrame mis categorías"' },
  { code: 'export_inventory_movements',  desc: 'Historial de movimientos de stock',                                  prompt: '"¿Cómo cambió mi inventario este mes?"' },
  { code: 'export_theme_config',         desc: 'Configuración de diseño: colores, fuentes, tema',                    prompt: '"Guarda la config de mi tema"' },
  { code: 'list_payment_gateways',       desc: 'Pasarelas de pago activas y métodos configurados',                   prompt: '"¿Qué métodos de pago tengo?"' },
  { code: 'download_media_archive',      desc: 'ZIP con todas las imágenes de tu tienda',                            prompt: '"Descarga todas mis fotos de productos"' },
  { code: 'suggest_alternative_platforms', desc: 'Análisis de qué plataforma conviene para migrar',                  prompt: '"¿A qué plataforma me mudo?"' },
];

// FAQ data — same approach for staggered reveals.
const faqs = [
  { q: '¿Qué es exactamente este MCP?',                       a: 'Es el conector oficial de Komercia para Claude.ai. Te permite exportar y consultar todos los datos de tu tienda conversando en lenguaje natural, sin escribir código.' },
  { q: '¿Es gratis?',                                          a: 'Sí, completamente gratis. Solo necesitas una cuenta activa de Komercia y una cuenta de Claude.ai.' },
  { q: '¿Es seguro? ¿Qué hacen con mi contraseña?',            a: 'Tu contraseña se usa una sola vez para autenticarte y nunca se almacena. Generamos un token JWT de solo lectura. El código es open source y auditable en GitHub.' },
  { q: '¿Qué datos puedo exportar?',                           a: 'Productos con variantes e imágenes, órdenes históricas, clientes con direcciones, categorías, configuración de tema, métodos de pago, movimientos de inventario y más.' },
  { q: '¿En qué formatos puedo exportar?',                     a: 'CSV genérico, JSON estructurado, formato Shopify y formato WooCommerce. Claude puede transformar los datos a cualquier otro formato que necesites.' },
  { q: '¿Puedo migrar a otra plataforma con esto?',            a: 'Sí, es uno de sus usos principales. Genera exports listos para Shopify, Tiendanube, WooCommerce, VTEX y otras plataformas.' },
  { q: '¿Necesito saber programar?',                           a: 'No. Si sabes hacer login y copiar/pegar un texto, puedes usarlo. Toda la interacción es en español natural.' },
  { q: '¿Cuánto dura mi token de acceso?',                     a: '6 meses. Después puedes generar uno nuevo desde esta misma página.' },
  { q: '¿Qué pasa con mis datos cuando cierre Komercia?',      a: 'Mientras tu cuenta siga activa, podrás exportar todo. Te recomendamos hacer un backup completo lo antes posible.' },
  { q: '¿Dónde reporto bugs o sugiero mejoras?',               a: 'En GitHub: abre un issue en el repositorio. Es open source y bienvenidas las contribuciones.' },
];
---

<Base
  title="Komercia Exit MCP — Exporta tu tienda con Claude.ai"
  description="El MCP oficial de Komercia. Exporta productos, órdenes, clientes y más conversando con Claude.ai. Gratis, seguro, sin código."
>
  <!-- Section 1: Announcement Banner -->
  <AnnouncementBanner />

  <!-- Section 2: Navbar -->
  <Navbar />

  <!-- Section 3: Hero -->
  <section class="relative overflow-hidden py-24 md:py-32">
    <!-- Decorative layers -->
    <div class="hero-bg"></div>
    <div class="ascii-field"></div>

    <div class="container relative z-10">
      <div class="grid lg:grid-cols-5 gap-12 lg:gap-16 items-center">
        <!-- Left column — 60% (3/5) -->
        <div class="lg:col-span-3">
          <div class="pill-accent mb-6" data-animate>
            <span style="width:6px;height:6px;border-radius:50%;background:var(--accent);display:inline-block"></span>
            MCP Oficial de Komercia
          </div>

          <h1
            class="text-4xl md:text-5xl lg:text-[3.5rem] font-semibold tracking-tight text-balance"
            style="letter-spacing:-0.02em; line-height:1.05"
            data-animate
          >
            Tus datos, tu tienda, <span style="color: var(--accent)">tu próximo paso.</span>
          </h1>

          <p
            class="text-lg mt-6 leading-relaxed"
            style="color:var(--text-secondary); max-width:30rem"
            data-animate
            data-animate-delay="200"
          >
            Exporta, migra o respalda todo lo de tu tienda Komercia conversando con Claude.
            Gratis, seguro, sin código.
          </p>

          <div class="flex flex-wrap gap-3 mt-8" data-animate data-animate-delay="300">
            <a href="#obtener-token" class="btn-primary px-6 py-3 text-base">
              Obtener mi token gratis
            </a>
            <a href="#como-funciona" class="btn-secondary px-6 py-3 text-base">
              Cómo funciona →
            </a>
          </div>
        </div>

        <!-- Right column — 40% (2/5) -->
        <div class="lg:col-span-2 flex justify-center lg:justify-end" data-animate data-animate-delay="400">
          <ChatMock />
        </div>
      </div>
    </div>
  </section>

  <!-- Section 4: Trust bar — flat, dividers only -->
  <div id="trust-bar" class="border-y border-subtle">
    <div class="container py-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-x-6 gap-y-4">
        <!-- Official -->
        <div class="flex items-center gap-3" data-animate>
          <div class="w-6 h-6 rounded-md flex items-center justify-center flex-shrink-0" style="background:color-mix(in srgb, var(--accent) 8%, transparent)">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color:var(--accent)">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            </svg>
          </div>
          <span class="text-sm font-medium" style="color:var(--text-primary)">Oficial Komercia</span>
        </div>
        <!-- Open Source -->
        <div class="flex items-center gap-3" data-animate data-animate-delay="100">
          <div class="w-6 h-6 rounded-md flex items-center justify-center flex-shrink-0" style="background:color-mix(in srgb, var(--accent) 8%, transparent)">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color:var(--accent)">
              <polyline points="16 18 22 12 16 6"/>
              <polyline points="8 6 2 12 8 18"/>
            </svg>
          </div>
          <span class="text-sm font-medium" style="color:var(--text-primary)">100% Open Source</span>
        </div>
        <!-- Free -->
        <div class="flex items-center gap-3" data-animate data-animate-delay="200">
          <div class="w-6 h-6 rounded-md flex items-center justify-center flex-shrink-0" style="background:color-mix(in srgb, var(--accent) 8%, transparent)">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color:var(--accent)">
              <polyline points="20 12 20 22 4 22 4 12"/>
              <rect x="2" y="7" width="20" height="5"/>
              <path d="M12 22V7M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7zM12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"/>
            </svg>
          </div>
          <span class="text-sm font-medium" style="color:var(--text-primary)">Gratis para siempre</span>
        </div>
        <!-- Claude -->
        <div class="flex items-center gap-3" data-animate data-animate-delay="300">
          <div class="w-6 h-6 rounded-md flex items-center justify-center flex-shrink-0" style="background:color-mix(in srgb, var(--accent) 8%, transparent)">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color:var(--accent)">
              <rect x="4" y="4" width="16" height="16" rx="2"/>
              <rect x="9" y="9" width="6" height="6"/>
              <line x1="9" y1="1" x2="9" y2="4"/>
              <line x1="15" y1="1" x2="15" y2="4"/>
              <line x1="9" y1="20" x2="9" y2="23"/>
              <line x1="15" y1="20" x2="15" y2="23"/>
              <line x1="20" y1="9" x2="23" y2="9"/>
              <line x1="20" y1="14" x2="23" y2="14"/>
              <line x1="1" y1="9" x2="4" y2="9"/>
              <line x1="1" y1="14" x2="4" y2="14"/>
            </svg>
          </div>
          <span class="text-sm font-medium" style="color:var(--text-primary)">Powered by Claude</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Section 5: Cómo funciona — flat 3 columns with vertical dividers -->
  <section id="como-funciona" class="section">
    <div class="container">
      <div class="text-center">
        <p class="section-eyebrow" data-animate>Cómo funciona</p>
        <h2 class="section-heading" data-animate data-animate-delay="100">Listo en 3 minutos</h2>
        <p class="section-subheading mx-auto" data-animate data-animate-delay="200">Sin instalar nada. Sin tocar código.</p>
      </div>

      <div class="grid md:grid-cols-3 mt-16">
        <!-- Step 1 -->
        <div class="px-8 py-6 md:border-r border-subtle" data-animate data-animate-delay="100">
          <div class="text-5xl font-semibold" style="color:var(--accent); letter-spacing:-0.03em">01</div>
          <h3 class="text-lg font-semibold mt-6 mb-2">Genera tu token</h3>
          <p class="text-sm text-muted leading-relaxed">
            Inicia sesión con tu cuenta Komercia y obtén tu token de exportación personal en segundos.
          </p>
        </div>
        <!-- Step 2 -->
        <div class="px-8 py-6 md:border-r border-subtle" data-animate data-animate-delay="200">
          <div class="text-5xl font-semibold" style="color:var(--accent); letter-spacing:-0.03em">02</div>
          <h3 class="text-lg font-semibold mt-6 mb-2">Conecta Claude</h3>
          <p class="text-sm text-muted leading-relaxed">
            Pega el token en Claude.ai y agrega el conector MCP. Solo lo haces una vez.
          </p>
        </div>
        <!-- Step 3 -->
        <div class="px-8 py-6" data-animate data-animate-delay="300">
          <div class="text-5xl font-semibold" style="color:var(--accent); letter-spacing:-0.03em">03</div>
          <h3 class="text-lg font-semibold mt-6 mb-2">Conversa y exporta</h3>
          <p class="text-sm text-muted leading-relaxed">
            Pídele a Claude lo que necesites en lenguaje natural. Él hace el resto.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Section 6: Video demo -->
  <section id="demo" class="section">
    <div class="container">
      <div class="text-center">
        <p class="section-eyebrow" data-animate>Demo</p>
        <h2 class="section-heading" data-animate data-animate-delay="100">Velo en acción</h2>
        <p class="section-subheading mx-auto" data-animate data-animate-delay="200">2 minutos para ver todo lo que puedes hacer.</p>
      </div>

      <!-- TODO: reemplazar con <iframe data-yt-id=""> cuando esté el video -->
      <div
        class="aspect-video w-full max-w-3xl mx-auto mt-12 rounded-xl overflow-hidden relative flex items-center justify-center"
        style="background-color: var(--bg-secondary); border: 1px solid var(--border)"
        data-animate
        data-animate-delay="300"
      >
        <div class="absolute inset-0 bg-dot-pattern opacity-30"></div>
        <div class="relative flex flex-col items-center gap-4">
          <div class="w-16 h-16 rounded-full flex items-center justify-center" style="border: 1px solid var(--accent)">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" style="color:var(--accent); margin-left:3px">
              <polygon points="6 4 20 12 6 20 6 4"/>
            </svg>
          </div>
          <p class="text-sm text-muted">Video disponible próximamente</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Section 7: Qué puedes exportar — flat divided grid -->
  <section id="exportar" class="section">
    <div class="container">
      <div class="text-center">
        <p class="section-eyebrow" data-animate>Qué exportas</p>
        <h2 class="section-heading" data-animate data-animate-delay="100">Todo tu negocio, en tus manos</h2>
        <p class="section-subheading mx-auto" data-animate data-animate-delay="200">Cada dato de tu tienda, en el formato que necesites.</p>
      </div>

      <div
        class="grid grid-cols-2 md:grid-cols-4 mt-12 border border-subtle rounded-xl overflow-hidden"
        data-animate
        data-animate-delay="200"
      >
        <!-- Productos -->
        <div class="p-6 border-b md:border-r border-subtle" data-animate style="transition-delay: 60ms">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color:var(--accent)">
            <path d="M16.5 9.4l-9-5.19M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
            <polyline points="3.27 6.96 12 12.01 20.73 6.96"/>
            <line x1="12" y1="22.08" x2="12" y2="12"/>
          </svg>
          <h3 class="text-sm font-semibold mt-4 mb-1">Productos</h3>
          <p class="text-xs text-muted leading-relaxed">Catálogo completo con variantes, precios e imágenes</p>
        </div>
        <!-- Órdenes -->
        <div class="p-6 border-b md:border-r border-subtle" data-animate style="transition-delay: 120ms">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color:var(--accent)">
            <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
            <line x1="3" y1="6" x2="21" y2="6"/>
            <path d="M16 10a4 4 0 0 1-8 0"/>
          </svg>
          <h3 class="text-sm font-semibold mt-4 mb-1">Órdenes</h3>
          <p class="text-xs text-muted leading-relaxed">Historial completo de ventas con detalle</p>
        </div>
        <!-- Clientes -->
        <div class="p-6 border-b md:border-r border-subtle" data-animate style="transition-delay: 180ms">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color:var(--accent)">
            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
            <circle cx="9" cy="7" r="4"/>
            <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
            <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
          </svg>
          <h3 class="text-sm font-semibold mt-4 mb-1">Clientes</h3>
          <p class="text-xs text-muted leading-relaxed">Base de datos con direcciones e historial</p>
        </div>
        <!-- Inventario -->
        <div class="p-6 border-b border-subtle" data-animate style="transition-delay: 240ms">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color:var(--accent)">
            <line x1="18" y1="20" x2="18" y2="10"/>
            <line x1="12" y1="20" x2="12" y2="4"/>
            <line x1="6" y1="20" x2="6" y2="14"/>
          </svg>
          <h3 class="text-sm font-semibold mt-4 mb-1">Inventario</h3>
          <p class="text-xs text-muted leading-relaxed">Movimientos de stock y trazabilidad</p>
        </div>
        <!-- Categorías -->
        <div class="p-6 md:border-r border-subtle border-b md:border-b-0" data-animate style="transition-delay: 300ms">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color:var(--accent)">
            <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/>
            <line x1="12" y1="11" x2="12" y2="17"/>
            <line x1="9" y1="14" x2="15" y2="14"/>
          </svg>
          <h3 class="text-sm font-semibold mt-4 mb-1">Categorías</h3>
          <p class="text-xs text-muted leading-relaxed">Estructura jerárquica de tu catálogo</p>
        </div>
        <!-- Diseño -->
        <div class="p-6 md:border-r border-subtle border-b md:border-b-0" data-animate style="transition-delay: 360ms">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color:var(--accent)">
            <circle cx="13.5" cy="6.5" r="0.5" fill="currentColor"/>
            <circle cx="17.5" cy="10.5" r="0.5" fill="currentColor"/>
            <circle cx="8.5" cy="7.5" r="0.5" fill="currentColor"/>
            <circle cx="6.5" cy="12.5" r="0.5" fill="currentColor"/>
            <path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10c.926 0 1.648-.746 1.648-1.688 0-.437-.18-.835-.437-1.125-.29-.289-.438-.652-.438-1.125a1.64 1.64 0 0 1 1.668-1.668h1.996c3.051 0 5.555-2.503 5.555-5.554C21.965 6.012 17.461 2 12 2z"/>
          </svg>
          <h3 class="text-sm font-semibold mt-4 mb-1">Diseño</h3>
          <p class="text-xs text-muted leading-relaxed">Configuración de tema, colores y fuentes</p>
        </div>
        <!-- Pagos -->
        <div class="p-6 md:border-r border-subtle border-b md:border-b-0" data-animate style="transition-delay: 420ms">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color:var(--accent)">
            <rect x="1" y="4" width="22" height="16" rx="2" ry="2"/>
            <line x1="1" y1="10" x2="23" y2="10"/>
          </svg>
          <h3 class="text-sm font-semibold mt-4 mb-1">Pagos</h3>
          <p class="text-xs text-muted leading-relaxed">Pasarelas activas y métodos configurados</p>
        </div>
        <!-- Imágenes -->
        <div class="p-6" data-animate style="transition-delay: 480ms">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color:var(--accent)">
            <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
            <circle cx="8.5" cy="8.5" r="1.5"/>
            <polyline points="21 15 16 10 5 21"/>
          </svg>
          <h3 class="text-sm font-semibold mt-4 mb-1">Imágenes</h3>
          <p class="text-xs text-muted leading-relaxed">Archivo ZIP con todos los assets</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Section 8: Casos de uso — horizontal flat rows -->
  <section id="casos" class="section">
    <div class="container">
      <div class="text-center">
        <p class="section-eyebrow" data-animate>Casos de uso</p>
        <h2 class="section-heading" data-animate data-animate-delay="100">¿Para qué lo usan los merchants?</h2>
      </div>

      <div class="mt-12 flex flex-col">
        <!-- Migrar -->
        <div class="row-flat grid md:grid-cols-12 gap-6 items-start" data-animate data-animate-delay="100">
          <p class="section-eyebrow md:col-span-2 pt-1">Migración</p>
          <div class="md:col-span-7">
            <h3 class="text-xl font-semibold mb-3" style="letter-spacing:-0.01em">Migrar a otra plataforma</h3>
            <p class="text-sm text-muted leading-relaxed">
              Genera exports listos para Shopify, Tiendanube o WooCommerce. Sin manipular CSVs a mano.
            </p>
          </div>
          <blockquote class="md:col-span-3 text-xs italic md:border-l border-subtle md:pl-4" style="color:var(--accent)">
            "Exporta mis productos en formato Shopify"
          </blockquote>
        </div>
        <!-- Backup -->
        <div class="row-flat grid md:grid-cols-12 gap-6 items-start" data-animate data-animate-delay="200">
          <p class="section-eyebrow md:col-span-2 pt-1">Backup</p>
          <div class="md:col-span-7">
            <h3 class="text-xl font-semibold mb-3" style="letter-spacing:-0.01em">Backup de tu tienda</h3>
            <p class="text-sm text-muted leading-relaxed">
              Mantén una copia segura de todo tu negocio antes de que cierre Komercia.
            </p>
          </div>
          <blockquote class="md:col-span-3 text-xs italic md:border-l border-subtle md:pl-4" style="color:var(--accent)">
            "Descarga todos mis datos en JSON"
          </blockquote>
        </div>
        <!-- Análisis -->
        <div class="row-flat grid md:grid-cols-12 gap-6 items-start" data-animate data-animate-delay="300">
          <p class="section-eyebrow md:col-span-2 pt-1">Análisis</p>
          <div class="md:col-span-7">
            <h3 class="text-xl font-semibold mb-3" style="letter-spacing:-0.01em">Análisis con IA</h3>
            <p class="text-sm text-muted leading-relaxed">
              Pídele a Claude que analice tus ventas, detecte patrones y te sugiera qué hacer.
            </p>
          </div>
          <blockquote class="md:col-span-3 text-xs italic md:border-l border-subtle md:pl-4" style="color:var(--accent)">
            "¿Cuál fue mi producto más vendido este año?"
          </blockquote>
        </div>
      </div>
    </div>
  </section>

  <!-- Section 9: Cómo conectar a Claude -->
  <section id="conectar" class="section">
    <div class="container">
      <div class="text-center">
        <p class="section-eyebrow" data-animate>Configuración</p>
        <h2 class="section-heading" data-animate data-animate-delay="100">Conectarlo es más fácil de lo que crees</h2>
        <p class="section-subheading mx-auto" data-animate data-animate-delay="200">4 pasos, una sola vez.</p>
      </div>

      <div class="grid md:grid-cols-2 gap-16 items-start mt-16">
        <!-- Left: steps -->
        <div class="space-y-6">
          <div class="flex gap-4" data-animate data-animate-delay="100">
            <div class="step-number flex-shrink-0">1</div>
            <div>
              <h4 class="font-semibold mb-1">Abre Claude.ai y ve a <strong>Configuración → Conectores</strong></h4>
              <p class="text-sm text-muted leading-relaxed">Disponible desde el menú de tu perfil en claude.ai.</p>
            </div>
          </div>
          <div class="flex gap-4" data-animate data-animate-delay="200">
            <div class="step-number flex-shrink-0">2</div>
            <div>
              <h4 class="font-semibold mb-1">Click en <strong>"Agregar conector personalizado"</strong></h4>
              <p class="text-sm text-muted leading-relaxed">Busca la opción para agregar un nuevo servidor MCP.</p>
            </div>
          </div>
          <div class="flex gap-4" data-animate data-animate-delay="300">
            <div class="step-number flex-shrink-0">3</div>
            <div>
              <h4 class="font-semibold mb-1">Pega la URL del servidor</h4>
              <p class="text-sm text-muted leading-relaxed mb-2">Copia y pega esta dirección en el campo URL:</p>
              <code class="code-chip">https://mcp.komercia-exit.com</code>
            </div>
          </div>
          <div class="flex gap-4" data-animate data-animate-delay="400">
            <div class="step-number flex-shrink-0">4</div>
            <div>
              <h4 class="font-semibold mb-1">Pega tu token en el campo <strong>Authorization</strong> y guarda</h4>
              <p class="text-sm text-muted leading-relaxed">Usa el token que obtuviste al iniciar sesión con tu cuenta Komercia.</p>
            </div>
          </div>

          <a href="#obtener-token" class="btn-primary mt-8 inline-flex" data-animate data-animate-delay="400">Obtener mi token ahora →</a>
        </div>

        <!-- Right: simplified Claude mock UI -->
        <div data-animate data-animate-delay="200">
          <div class="pill-accent text-xs mb-4 inline-flex">Claude.ai</div>
          <div class="rounded-xl p-7 max-w-xs" style="background-color: var(--bg-secondary); border: 1px solid var(--border)">
            <div class="flex items-center justify-between mb-6">
              <span class="font-semibold text-sm">Agregar conector</span>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-faint">
                <line x1="18" y1="6" x2="6" y2="18"/>
                <line x1="6" y1="6" x2="18" y2="18"/>
              </svg>
            </div>
            <div class="space-y-5">
              <div>
                <p class="text-[10px] font-medium text-muted mb-1.5 uppercase tracking-[0.14em]">URL del servidor</p>
                <div class="code-chip text-xs w-full py-2 px-3 flex items-center">
                  https://mcp.komercia-exit.com
                </div>
              </div>
              <div>
                <p class="text-[10px] font-medium text-muted mb-1.5 uppercase tracking-[0.14em]">Authorization</p>
                <div class="code-chip text-xs w-full py-2 px-3 flex items-center">
                  eyJhbGci...
                </div>
              </div>
            </div>
            <button class="w-full mt-6 py-2 rounded-lg text-sm font-medium" style="background:var(--accent); color: var(--accent-on)">
              Guardar
            </button>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Section 10: Catálogo de tools — using .tool-row -->
  <section id="tools" class="section">
    <div class="container">
      <div class="text-center">
        <p class="section-eyebrow" data-animate>11 herramientas</p>
        <h2 class="section-heading" data-animate data-animate-delay="100">Todo lo que puedes pedirle a Claude</h2>
        <p class="section-subheading mx-auto" data-animate data-animate-delay="200">Cada tool está optimizada para una tarea específica.</p>
      </div>

      <div class="mt-16 flex flex-col" data-animate data-animate-delay="200">
        {tools.map((tool, i) => (
          <div class="tool-row" data-animate style={`transition-delay: ${i * 40}ms`}>
            <div class="md:col-span-3">
              <code class="code-chip text-sm">{tool.code}</code>
            </div>
            <span class="text-sm text-muted md:col-span-6">{tool.desc}</span>
            <span class="text-xs italic md:col-span-3" style="color:var(--accent)">{tool.prompt}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Section 11: Seguridad — flat layout -->
  <section id="seguridad" class="section-tight">
    <div class="container">
      <div class="text-center">
        <p class="section-eyebrow" data-animate>Seguridad</p>
        <h2 class="section-heading" data-animate data-animate-delay="100">Tu seguridad, sin compromisos</h2>
        <p class="section-subheading mx-auto" data-animate data-animate-delay="200">Diseñado desde el inicio para ser seguro y transparente.</p>
      </div>

      <div class="grid md:grid-cols-3 gap-10 mt-16">
        <!-- No passwords -->
        <div data-animate data-animate-delay="100">
          <div class="w-10 h-10 rounded-lg flex items-center justify-center mb-5" style="background:color-mix(in srgb, var(--accent) 8%, transparent); color: var(--accent)">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
              <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
            </svg>
          </div>
          <h3 class="text-base font-semibold mb-2">Sin almacenar contraseñas</h3>
          <p class="text-sm text-muted leading-relaxed">
            Tu password se usa solo para autenticarte y nunca queda en nuestros servidores. Nunca.
          </p>
        </div>
        <!-- Open source -->
        <div data-animate data-animate-delay="200">
          <div class="w-10 h-10 rounded-lg flex items-center justify-center mb-5" style="background:color-mix(in srgb, var(--accent) 8%, transparent); color: var(--accent)">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="16 18 22 12 16 6"/>
              <polyline points="8 6 2 12 8 18"/>
            </svg>
          </div>
          <h3 class="text-base font-semibold mb-2">Código 100% abierto</h3>
          <p class="text-sm text-muted leading-relaxed">
            Todo el código está en GitHub. Auditado por ti, por Komercia, por la comunidad.
          </p>
        </div>
        <!-- Read-only -->
        <div data-animate data-animate-delay="300">
          <div class="w-10 h-10 rounded-lg flex items-center justify-center mb-5" style="background:color-mix(in srgb, var(--accent) 8%, transparent); color: var(--accent)">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
              <polyline points="9 12 11 14 15 10"/>
            </svg>
          </div>
          <h3 class="text-base font-semibold mb-2">Solo lectura</h3>
          <p class="text-sm text-muted leading-relaxed">
            Los tokens generan acceso de solo lectura. El MCP no puede modificar nada en tu tienda.
          </p>
        </div>
      </div>

      <div class="text-center mt-12" data-animate data-animate-delay="400">
        <a href="/security" class="link-accent text-sm inline-flex items-center gap-1">
          Lee nuestro modelo de seguridad completo →
        </a>
      </div>
    </div>
  </section>

  <!-- Section 12: FAQ -->
  <section id="faq" class="section">
    <div class="container-narrow">
      <div class="text-center">
        <p class="section-eyebrow" data-animate>FAQ</p>
        <h2 class="section-heading" data-animate data-animate-delay="100">Preguntas frecuentes</h2>
      </div>

      <div class="mt-12">
        {faqs.map((faq, i) => (
          <details class="faq-item" data-animate style={`transition-delay: ${i * 40}ms`}>
            <summary>
              {faq.q}
              <svg class="chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
            </summary>
            <div class="faq-body">{faq.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Section 13: Final CTA with embedded form -->
  <section id="obtener-token" class="section">
    <div class="container-narrow">
      <div class="text-center">
        <p class="section-eyebrow" data-animate>Empieza ahora</p>
        <h2
          class="text-3xl md:text-[2.5rem] font-semibold tracking-tight mt-4"
          style="letter-spacing:-0.02em; line-height:1.1"
          data-animate
          data-animate-delay="100"
        >
          Tu token, en segundos.
        </h2>
        <p class="section-subheading mx-auto" data-animate data-animate-delay="200">
          Ingresa con tu cuenta Komercia y obtén tu token al instante.
        </p>
      </div>

      <div class="max-w-md mx-auto mt-12 p-8 rounded-2xl bg-surface" data-animate data-animate-delay="300">
        <LoginForm />
      </div>

      <p class="text-xs text-center mt-6 max-w-md mx-auto leading-relaxed" style="color:var(--text-tertiary)" data-animate data-animate-delay="400">
        Tus credenciales se usan solo para verificar tu identidad y nunca se almacenan en texto plano.
      </p>
      <p class="text-sm text-center mt-3 text-muted" data-animate data-animate-delay="400">
        ¿No tienes cuenta de Komercia?
        <a href="https://komercia.co" class="link-accent">Regístrate gratis →</a>
      </p>
    </div>
  </section>

  <!-- Section 14: Footer -->
  <Footer />

  <!-- Scroll animation observer (must render once) -->
  <ScrollAnimate />
</Base>
