---
// uso.astro — Installation guide page with Column design system.
// Per-client install steps for Claude.ai, Claude Code, Claude Desktop, Cursor, self-hosted.
import Base from '../layouts/Base.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import ScrollAnimate from '../components/ScrollAnimate.astro';
import Button from '../components/Button.astro';
import Card from '../components/Card.astro';
import Badge from '../components/Badge.astro';
import SectionHeading from '../components/SectionHeading.astro';
import CodeBlock from '../components/CodeBlock.astro';
import Container from '../components/Container.astro';
import Section from '../components/Section.astro';

const MCP_URL = 'https://api-mcp.komercia.co/sse';

const clients = [
  {
    id: 'claude-ai',
    label: 'Claude.ai',
    badge: 'Recomendado',
    badgeClass: 'pill-label',
    subtitle: 'Web · Desktop · Móvil',
    intro: 'La forma más sencilla. Sin instalar nada extra — solo pegar la URL y tu token en la interfaz de Claude.',
    prereqs: ['Cuenta gratuita o Pro en claude.ai', 'Token de exportación (obténlo abajo)'],
    steps: [
      {
        title: 'Abre Configuración → Conectores',
        body: 'En claude.ai, haz click en tu perfil → <strong>Settings</strong> → <strong>Integrations</strong> (o <em>Conectores</em>).',
      },
      {
        title: 'Agrega un conector personalizado',
        body: 'Click en <strong>"Add custom integration"</strong> → <strong>"MCP Server"</strong>.',
      },
      {
        title: 'Pega la URL del servidor',
        body: 'En el campo URL introduce:',
        code: MCP_URL,
      },
      {
        title: 'Pega tu token en Authorization y guarda',
        body: 'En el campo <strong>Authorization</strong> (o header) pega el JWT que obtuviste al iniciar sesión. Haz click en <strong>Guardar</strong>.',
      },
      {
        title: '¡Listo! Prueba con una pregunta',
        body: 'Abre un chat y pregunta: <em>"¿Cuál es el nombre de mi tienda?"</em>',
      },
    ],
  },
  {
    id: 'claude-code',
    label: 'Claude Code',
    badge: 'CLI',
    badgeClass: 'pill',
    subtitle: 'Terminal · macOS · Linux · Windows',
    intro: 'Claude Code corre en tu máquina, así que se conecta directo al servidor MCP con un solo comando — sin archivos de configuración ni instalaciones extra.',
    prereqs: ['Claude Code instalado (<code class="code-chip text-xs">npm i -g @anthropic-ai/claude-code</code>)', 'Token de exportación (obténlo arriba)'],
    steps: [
      {
        title: 'Registra el servidor con un comando',
        body: 'Corre esto en tu terminal (reemplaza <code class="code-chip text-xs">TU_TOKEN_AQUI</code> con el token que obtuviste):',
        code: `claude mcp add --transport sse komercia ${MCP_URL} \\\n  --header "Authorization: Bearer TU_TOKEN_AQUI"`,
      },
      {
        title: 'Verifica que quedó registrado',
        body: 'Debería aparecer <strong>komercia</strong> en la lista:',
        code: 'claude mcp list',
      },
      {
        title: '¡Listo! Pregúntale a Claude sobre tu tienda',
        body: 'Abre Claude Code en cualquier directorio. El MCP está disponible en todas tus sesiones. Prueba:<br><br><em>"¿Cuántos productos activos tengo?"</em><br><em>"Dame un resumen de mis ventas del último mes"</em><br><em>"Exporta mi catálogo en formato Shopify"</em>',
      },
    ],
    tip: 'Para limitar el servidor a un solo proyecto en vez de globalmente, agrega <code class="code-chip text-xs">--scope project</code> al comando de registro.',
  },
  {
    id: 'claude-desktop',
    label: 'Claude Desktop',
    badge: 'App',
    badgeClass: 'pill',
    subtitle: 'macOS · Windows',
    intro: 'La app de escritorio de Claude admite servidores MCP via un archivo de configuración JSON. Requiere el shim <code class="code-chip text-xs">mcp-remote</code> porque Claude Desktop usa stdio internamente.',
    prereqs: ['Claude Desktop instalado', 'Node 18+ instalado (<code class="code-chip text-xs">node -v</code>)', 'Token de exportación'],
    steps: [
      {
        title: 'Instala mcp-remote',
        body: 'En tu terminal:',
        code: 'npm install -g mcp-remote',
      },
      {
        title: 'Abre el archivo de configuración',
        body: `Edita (o crea) el archivo de configuración de Claude Desktop:<br><br>
<strong>macOS:</strong> <code class="code-chip text-xs">~/Library/Application Support/Claude/claude_desktop_config.json</code><br>
<strong>Windows:</strong> <code class="code-chip text-xs">%APPDATA%\\Claude\\claude_desktop_config.json</code>`,
      },
      {
        title: 'Agrega la entrada de Komercia MCP',
        body: 'Dentro de la clave <code class="code-chip text-xs">mcpServers</code>, añade:',
        code: `{
  "mcpServers": {
    "komercia": {
      "command": "mcp-remote",
      "args": [
        "${MCP_URL}",
        "--header",
        "Authorization: Bearer TU_TOKEN_AQUI"
      ]
    }
  }
}`,
      },
      {
        title: 'Reinicia Claude Desktop',
        body: 'Cierra y vuelve a abrir la app. El servidor <strong>komercia</strong> aparecerá activo.',
      },
      {
        title: 'Prueba en un chat',
        body: 'Escribe: <em>"Dame información de mi tienda"</em>.',
      },
    ],
  },
  {
    id: 'cursor',
    label: 'Cursor y otros IDEs',
    badge: 'IDE',
    badgeClass: 'pill',
    subtitle: 'Cursor · Windsurf · Continue · cualquier cliente MCP',
    intro: 'Cualquier cliente MCP que soporte SSE o HTTP puede conectarse. Aquí el ejemplo con Cursor.',
    prereqs: ['Cursor instalado', 'Token de exportación'],
    steps: [
      {
        title: 'Abre la configuración MCP de Cursor',
        body: '<strong>Settings</strong> → <strong>MCP</strong> → <strong>Add MCP Server</strong>.',
      },
      {
        title: 'Configura el servidor',
        body: 'En el JSON de configuración de Cursor:',
        code: `{
  "mcpServers": {
    "komercia": {
      "url": "${MCP_URL}",
      "headers": {
        "Authorization": "Bearer TU_TOKEN_AQUI"
      }
    }
  }
}`,
      },
      {
        title: 'Guarda y recarga',
        body: 'Guarda el archivo. Cursor detectará el servidor automáticamente.',
      },
      {
        title: 'Activa el servidor en Agent mode',
        body: 'En la barra de Cursor Agent, verifica que <strong>komercia</strong> está activo. Listo para usarlo.',
      },
    ],
    tip: 'Para Windsurf, Continue u otros clientes, la configuración es equivalente — URL + Authorization header. Consulta la doc de tu cliente para la ruta exacta del JSON.',
  },
  {
    id: 'self-hosted',
    label: 'Self-hosted',
    badge: 'Dev',
    badgeClass: 'pill',
    subtitle: 'Corre tu propia instancia localmente o en tu servidor',
    intro: 'Para desarrolladores que quieren correr su propia instancia del servidor. Útil para desarrollo, pruebas o uso privado.',
    prereqs: ['Node 20 LTS', 'pnpm 9+', 'Docker Desktop (para la base de datos local)'],
    steps: [
      {
        title: 'Clona el repositorio',
        body: '',
        code: `git clone https://github.com/gusplayer/komercia-mcp.git
cd komercia-mcp`,
      },
      {
        title: 'Copia las variables de entorno',
        body: 'Copia el template y rellena los valores (Komercia Laravel URL, secrets, etc.):',
        code: `cp .env.example .env
# Edita .env con tus valores`,
      },
      {
        title: 'Instala dependencias y levanta la base de datos',
        body: '',
        code: `pnpm install
docker compose --profile deps up -d
node scripts/migrate.mjs`,
      },
      {
        title: 'Inicia el servidor en modo desarrollo',
        body: '',
        code: 'pnpm dev',
      },
      {
        title: 'Obtén tu token en localhost',
        body: `Abre <code class="code-chip text-xs">http://localhost:4321</code>, inicia sesión con tu cuenta Komercia y copia el token.<br><br>
El servidor MCP corre en <code class="code-chip text-xs">http://localhost:3001</code>. Úsalo como URL en cualquiera de los clientes de arriba.`,
      },
    ],
    tip: 'Para el stack completo en Docker (sin <code class="code-chip text-xs">pnpm dev</code>): <code class="code-chip text-xs">docker compose --profile full up -d --build</code>. Revisa <a href="https://github.com/gusplayer/komercia-mcp#readme" target="_blank" rel="noopener" style="color: var(--color-deep-plum); text-decoration: underline;">el README</a> para más detalle.',
  },
];
---

<Base
  title="Cómo usar Komercia MCP — Guía de instalación"
  description="Guía completa para conectar Komercia MCP a Claude.ai, Claude Code, Claude Desktop, Cursor y más. Varias formas de uso, paso a paso."
>
  <Navbar activePage="uso" />

  <main>

    <!-- Hero -->
    <Section padding="default">
      <Container size="narrow">
        <SectionHeading
          eyebrow="Guía de instalación"
          title="Cómo usar Komercia MCP"
          description="Elige el cliente que más se adapta a tu flujo de trabajo. Todos usan el mismo token."
          align="center"
          size="lg"
        />
      </Container>
    </Section>

    <!-- Quick picker -->
    <Section padding="tight">
      <Container>
        <div class="picker-grid" data-animate>
          {clients.map((c) => (
            <a href={`#${c.id}`} class="picker-card">
              <div style="margin-bottom: 8px;">
                <Badge variant={c.id === 'claude-ai' ? 'success' : 'default'}>{c.badge}</Badge>
              </div>
              <span class="picker-label">{c.label}</span>
              <span class="picker-subtitle">{c.subtitle}</span>
            </a>
          ))}
        </div>
      </Container>
    </Section>

    <!-- Token prereq box -->
    <Section padding="tight">
      <Container>
        <div data-animate>
          <Card variant="callout-plum" padding="lg">
            <div class="prereq-box">
              <div class="prereq-left">
                <p class="section-eyebrow" style="color: rgba(255, 255, 255, 0.85);">Antes de empezar</p>
                <h2
                  style="font-family: var(--font-sans); font-weight: 600; font-size: 24px; line-height: 1.2; color: var(--color-ghost-white); margin: 8px 0 12px;"
                >
                  Necesitas un token de exportación
                </h2>
                <p
                  style="font-family: var(--font-sans); font-weight: 400; font-size: 14px; line-height: 1.6; color: rgba(255, 255, 255, 0.75); max-width: 28rem; margin: 0;"
                >
                  Todos los métodos requieren un token JWT personal. Se genera en segundos con tu cuenta Komercia — gratis y válido por 6 meses.
                </p>
              </div>
              <div class="prereq-right">
                <Button variant="primary" size="md" href="/sign-in">Obtener mi token →</Button>
              </div>
            </div>
          </Card>
        </div>
      </Container>
    </Section>

    <!-- Per-client sections -->
    {clients.map((client, ci) => (
      <Section background={ci % 2 === 0 ? 'white' : 'fog'} id={client.id} padding="default">
        <Container>

          <!-- Section header -->
          <div class="client-header" data-animate>
            <Badge variant={client.badge === 'Recomendado' ? 'success' : 'default'}>{client.badge}</Badge>
            <h2
              style="font-family: var(--font-sans); font-weight: 600; font-size: 32px; line-height: 1.1; letter-spacing: -0.48px; color: var(--color-ink-blue); margin: 0;"
            >
              {client.label}
            </h2>
            <span
              style="font-family: var(--font-sans); font-size: 14px; font-weight: 400; color: var(--color-slate-text);"
            >
              {client.subtitle}
            </span>
          </div>

          <div class="client-grid">
            <!-- Left col-span-4: intro + prereqs + tip -->
            <div class="client-left">
              <p
                style="font-family: var(--font-sans); font-size: 14px; font-weight: 400; color: var(--color-charcoal-text); line-height: 1.5; margin: 0;"
                set:html={client.intro}
                data-animate
              />

              {client.prereqs && (
                <div data-animate style="margin-top: 24px;">
                  <p
                    style="font-family: var(--font-sans); font-size: 11px; font-weight: 500; text-transform: uppercase; letter-spacing: 0.14em; color: var(--color-deep-plum); margin: 0 0 12px;"
                  >
                    Requisitos
                  </p>
                  <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 8px;">
                    {client.prereqs.map((req) => (
                      <li
                        style="display: flex; align-items: flex-start; gap: 8px; font-family: var(--font-sans); font-size: 13px; font-weight: 400; color: var(--color-charcoal-text); line-height: 1.5;"
                      >
                        <svg
                          width="12"
                          height="12"
                          viewBox="0 0 12 12"
                          fill="none"
                          aria-hidden="true"
                          style="flex-shrink: 0; margin-top: 4px; color: var(--color-success-moss);"
                        >
                          <path d="M2.5 6.5L5 9L9.5 3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                        <span set:html={req} />
                      </li>
                    ))}
                  </ul>
                </div>
              )}

              {client.tip && (
                <div class="alert-warning" data-animate style="margin-top: 24px;">
                  <p
                    style="font-family: var(--font-sans); font-size: 11px; font-weight: 500; text-transform: uppercase; letter-spacing: 0.08em; color: var(--color-warning); margin: 0 0 4px;"
                  >
                    Tip
                  </p>
                  <span set:html={client.tip} />
                </div>
              )}
            </div>

            <!-- Right col-span-8: steps -->
            <div class="client-right">
              {client.steps.map((step, si) => (
                <div class="step-block" data-animate style={`transition-delay:${si * 60}ms`}>
                  <div class="step-row">
                    <span class="step-number">{si + 1}</span>
                    <div class="step-content">
                      <h4
                        style="font-family: var(--font-sans); font-size: 14px; font-weight: 500; color: var(--color-ink-blue); margin: 4px 0 0; line-height: 1.4;"
                      >
                        {step.title}
                      </h4>
                      {step.body && (
                        <p
                          style="font-family: var(--font-sans); font-size: 13px; font-weight: 400; color: var(--color-charcoal-text); line-height: 1.6; margin: 4px 0 0;"
                          set:html={step.body}
                        />
                      )}
                      {step.code && (
                        <div style="margin-top: 12px;">
                          <CodeBlock code={step.code} language="bash" />
                        </div>
                      )}
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>

        </Container>
      </Section>
    ))}

    <!-- Bottom CTA -->
    <Section padding="default">
      <Container size="narrow">
        <SectionHeading
          eyebrow="¿Tienes dudas?"
          title="¿Algo no funciona?"
          description="Abre un issue en GitHub o revisa las preguntas frecuentes."
          align="center"
        />
        <div class="cta-row" data-animate data-animate-delay="300">
          <Button
            variant="ghost"
            href="https://github.com/gusplayer/komercia-mcp/issues"
            external
          >
            Abrir issue en GitHub
          </Button>
          <Button variant="ghost" href="/#faq">Ver FAQ</Button>
          <Button variant="primary" href="/sign-in">Obtener token →</Button>
        </div>
      </Container>
    </Section>

  </main>

  <Footer />
  <ScrollAnimate />
</Base>

<style>
  /* Quick picker grid */
  .picker-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
  }

  @media (min-width: 768px) {
    .picker-grid {
      grid-template-columns: repeat(5, 1fr);
    }
  }

  .picker-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    padding: 16px;
    border: 1px solid var(--color-steel-gray);
    border-radius: 8px;
    background: var(--color-ghost-white);
    text-align: center;
    text-decoration: none;
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
  }

  .picker-card:hover {
    border-color: var(--color-deep-plum);
    box-shadow: 0 1px 2px rgba(1, 24, 33, 0.04), 0 4px 12px rgba(1, 24, 33, 0.06);
  }

  .picker-label {
    font-family: var(--font-sans);
    font-size: 14px;
    font-weight: 500;
    color: var(--color-ink-blue);
  }

  .picker-subtitle {
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: 400;
    color: var(--color-slate-text);
    line-height: 1.4;
  }

  /* Prereq callout box */
  .prereq-box {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  @media (min-width: 768px) {
    .prereq-box {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      gap: 24px;
    }
  }

  .prereq-left {
    flex: 1;
  }

  .prereq-right {
    flex-shrink: 0;
  }

  /* Client section header row */
  .client-header {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 12px;
    margin-bottom: 32px;
  }

  /* Client 2-col grid (4/8 split) */
  .client-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 32px;
    align-items: start;
  }

  @media (min-width: 768px) {
    .client-grid {
      grid-template-columns: 4fr 8fr;
      gap: 48px;
    }
  }

  .client-left {
    display: flex;
    flex-direction: column;
  }

  .client-right {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  /* Step row */
  .step-row {
    display: flex;
    gap: 16px;
    align-items: flex-start;
  }

  .step-content {
    flex: 1;
    min-width: 0;
  }

  /* Bottom CTA row */
  .cta-row {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 12px;
    margin-top: 32px;
  }
</style>
