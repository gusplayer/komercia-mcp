---
// TokenDisplay.astro — Standalone token display with copy-to-clipboard action.
// Aligned with the Column design system (light-only, fintech aesthetic).
import Button from './Button.astro';

export interface Props {
  token: string;
}

const { token } = Astro.props;

// Mask the token for display: show first 20 and last 10 chars
const masked =
  token.length > 35
    ? `${token.slice(0, 20)}${'·'.repeat(10)}${token.slice(-10)}`
    : token;
---

<div style="display: flex; flex-direction: column; gap: 16px;">
  <!-- Token box -->
  <pre
    id="token-box"
    class="code-block"
    aria-label="JWT token (masked)"
    style="margin: 0; font-family: 'IBM Plex Mono', monospace; font-size: 12px; word-break: break-all; user-select: all; white-space: pre-wrap;"
  ><span id="token-masked">{masked}</span></pre>

  <!-- Copy button — orange fill, success state changes text only (no color shift) -->
  <Button variant="primary" fullWidth id="copy-btn" class="token-copy-btn">
    <span id="copy-label" class="inline-flex items-center" style="gap: 8px;">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <rect width="14" height="14" x="8" y="8" rx="2" ry="2"/>
        <path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/>
      </svg>
      Copiar token al portapapeles
    </span>
    <span id="copy-success" class="hidden items-center" style="gap: 8px;">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <polyline points="20 6 9 17 4 12"/>
      </svg>
      Copiado
    </span>
  </Button>

  <!-- Hidden data carrier for the raw token -->
  <span id="token-raw" data-token={token} hidden></span>
</div>

<script>
  const btn         = document.getElementById('copy-btn')      as HTMLButtonElement;
  const copyLabel   = document.getElementById('copy-label')    as HTMLSpanElement;
  const copySuccess = document.getElementById('copy-success')  as HTMLSpanElement;
  const tokenRaw    = document.getElementById('token-raw')     as HTMLSpanElement;

  btn.addEventListener('click', async () => {
    const token = tokenRaw?.dataset['token'] ?? '';

    try {
      await navigator.clipboard.writeText(token);
    } catch {
      // Fallback for older browsers without Clipboard API
      const textarea = document.createElement('textarea');
      textarea.value = token;
      textarea.style.position = 'fixed';
      textarea.style.opacity = '0';
      document.body.appendChild(textarea);
      textarea.select();
      document.execCommand('copy');
      document.body.removeChild(textarea);
    }

    // Show copied state — checkmark + text, no color change
    copyLabel.classList.add('hidden');
    copySuccess.classList.remove('hidden');
    copySuccess.classList.add('inline-flex');

    // Revert after 3s
    setTimeout(() => {
      copyLabel.classList.remove('hidden');
      copySuccess.classList.add('hidden');
      copySuccess.classList.remove('inline-flex');
    }, 3000);
  });
</script>
