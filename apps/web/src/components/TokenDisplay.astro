---
export interface Props {
  token: string;
}

const { token } = Astro.props;

// Mask the token for display: show first 20 and last 10 chars
const masked =
  token.length > 35
    ? `${token.slice(0, 20)}${'·'.repeat(10)}${token.slice(-10)}`
    : token;
---

<div class="space-y-4">
  <div
    id="token-box"
    class="relative rounded-lg border border-slate-200 bg-slate-50 p-4 font-mono text-sm text-slate-700 break-all select-all"
    aria-label="JWT token (masked)"
  >
    <span id="token-masked">{masked}</span>
  </div>

  <button
    id="copy-btn"
    type="button"
    class="btn-primary w-full"
    data-token={token}
  >
    <span id="copy-label" class="flex items-center justify-center gap-2">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <rect width="14" height="14" x="8" y="8" rx="2" ry="2"/>
        <path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/>
      </svg>
      Copy token to clipboard
    </span>
    <span id="copy-success" class="hidden items-center justify-center gap-2 text-green-100">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="20 6 9 17 4 12"/>
      </svg>
      Copied!
    </span>
  </button>
</div>

<script>
  const btn = document.getElementById('copy-btn') as HTMLButtonElement;
  const copyLabel = document.getElementById('copy-label') as HTMLSpanElement;
  const copySuccess = document.getElementById('copy-success') as HTMLSpanElement;

  btn.addEventListener('click', async () => {
    const token = btn.dataset['token'] ?? '';

    try {
      await navigator.clipboard.writeText(token);
    } catch {
      // Fallback for older browsers
      const textarea = document.createElement('textarea');
      textarea.value = token;
      textarea.style.position = 'fixed';
      textarea.style.opacity = '0';
      document.body.appendChild(textarea);
      textarea.select();
      document.execCommand('copy');
      document.body.removeChild(textarea);
    }

    copyLabel.classList.add('hidden');
    copySuccess.classList.remove('hidden');
    copySuccess.classList.add('inline-flex');
    btn.classList.add('bg-green-600', 'hover:bg-green-700');
    btn.classList.remove('bg-accent', 'hover:bg-accent-dark');

    setTimeout(() => {
      copyLabel.classList.remove('hidden');
      copySuccess.classList.add('hidden');
      copySuccess.classList.remove('inline-flex');
      btn.classList.remove('bg-green-600', 'hover:bg-green-700');
      btn.classList.add('bg-accent', 'hover:bg-accent-dark');
    }, 3000);
  });
</script>
