---
// RecetasModal.astro — Terminal-style modal that lists 18 curated prompts
// with simulated Claude responses. Shared between the landing examples
// section and the sign-in token page.
//
// Any element with `data-open-recetas` attribute will open the modal.
import { recetas, categories, catCounts } from '../lib/recetas.data';
---

<div id="recetas-modal" class="modal-overlay" aria-hidden="true" role="dialog" aria-modal="true" aria-labelledby="recetas-modal-title">
  <div class="modal-window" role="document">

    <header class="modal-header">
      <span class="modal-title" id="recetas-modal-title">./prompts.library</span>
      <button type="button" class="modal-close" aria-label="Cerrar modal" title="Cerrar (esc)">[ × ]</button>
    </header>

    <div class="modal-info">
      <span data-t-es="18 prompts curados · 4 categorías · click para copiar" data-t-en="18 curated prompts · 4 categories · click to copy">18 prompts curados · 4 categorías · click para copiar</span>
    </div>

    <nav class="modal-filters" aria-label="Filtrar por categoría">
      <button type="button" class="filter-btn active" data-cat="all">
        <span data-t-es="todos" data-t-en="all">todos</span>
        <span class="count">({recetas.length})</span>
      </button>
      {categories.map((c) => {
        const sample = recetas.find((r) => r.cat === c);
        return (
          <button type="button" class="filter-btn" data-cat={c}>
            <span data-t-es={sample?.catEs} data-t-en={sample?.catEn}>{sample?.catEs}</span>
            <span class="count">({catCounts[c]})</span>
          </button>
        );
      })}
    </nav>

    <div class="modal-body">
      {recetas.map((r) => (
        <article class="recipe" data-cat={r.cat}>
          <div class="recipe-meta">
            <span class="recipe-tag">
              <span data-t-es={r.catEs} data-t-en={r.catEn}>{r.catEs}</span>
              · {r.tools.length} {r.tools.length === 1 ? 'tool' : 'tools'}
            </span>
            <button type="button" class="recipe-copy" data-prompt-es={r.promptEs} data-prompt-en={r.promptEn} aria-label="Copiar prompt">
              <span data-t-es="[ copiar ]" data-t-en="[ copy ]">[ copiar ]</span>
            </button>
          </div>
          <p class="recipe-prompt">
            <span class="muted">&gt;</span> <span class="recipe-prompt-text" data-t-es={r.promptEs} data-t-en={r.promptEn}>{r.promptEs}</span>
          </p>
          <div class="recipe-response">
            <div class="recipe-response-label muted">claude:</div>
            {r.responseEs.map((lineEs, i) => {
              const lineEn = r.responseEn[i] ?? lineEs;
              return <div data-t-es={lineEs || ' '} data-t-en={lineEn || ' '}>{lineEs || ' '}</div>;
            })}
          </div>
          <div class="recipe-tools">
            {r.tools.map((t) => <code>{t}</code>)}
          </div>
        </article>
      ))}
    </div>

    <footer class="modal-footer">
      <span class="muted" data-t-es="[ esc ] cerrar · click fuera para cerrar" data-t-en="[ esc ] close · click outside to close">[ esc ] cerrar · click fuera para cerrar</span>
    </footer>
  </div>
</div>

<style is:global>
  /* ── Recetas modal — global styles so they apply identically on
     every page that includes the component. Page tokens (--c-bg etc.)
     are defined on .page in each route's scoped block; the modal
     reuses them via the cascade. ───────────────────────────────── */

  .modal-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.88);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    display: none;
    align-items: flex-start;
    justify-content: center;
    z-index: 100;
    padding: 32px 24px;
    overflow-y: auto;
  }
  .modal-overlay.open { display: flex; }

  .modal-window {
    background: #000000;
    border: 1px solid #383838;
    border-radius: 10px;
    width: 100%;
    max-width: 880px;
    min-width: 0;
    display: flex;
    flex-direction: column;
    margin: auto;
    max-height: calc(100vh - 64px);
    overflow: hidden;
    font-family: 'Space Mono', ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: var(--fs-md);
    letter-spacing: 0.24px;
    color: #ffffff;
  }

  .modal-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 14px 24px;
    border-bottom: 1px solid #383838;
    flex-shrink: 0;
    min-width: 0;
  }
  .modal-window .modal-title {
    font-family: inherit;
    font-size: var(--fs-md);
    color: #ffffff;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .modal-window .muted { color: #888888; }
  .modal-window .caret {
    margin-left: 2px;
    animation: modal-blink 1s steps(1) infinite;
  }
  @keyframes modal-blink { 50% { opacity: 0; } }

  .modal-close {
    background: transparent;
    border: none;
    color: #888888;
    font-family: inherit;
    font-size: var(--fs-md);
    cursor: pointer;
    padding: 4px 8px;
    transition: color 150ms;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .modal-close:hover { color: #ffffff; }

  .modal-info {
    padding: 12px 24px;
    border-bottom: 1px solid #383838;
    color: #888888;
    font-size: var(--fs-base);
    flex-shrink: 0;
  }

  .modal-filters {
    display: flex;
    gap: 8px;
    padding: 12px 24px;
    border-bottom: 1px solid #383838;
    overflow-x: auto;
    flex-shrink: 0;
    -webkit-overflow-scrolling: touch;
  }
  .modal-window .filter-btn {
    background: transparent;
    color: #888888;
    border: 1px solid #383838;
    border-radius: 10px;
    font-family: inherit;
    font-size: var(--fs-base);
    padding: 5px 12px;
    cursor: pointer;
    white-space: nowrap;
    transition: color 150ms, border-color 150ms, background 150ms;
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  .modal-window .filter-btn:hover { color: #ffffff; border-color: #ffffff; }
  .modal-window .filter-btn.active {
    background: #ffffff;
    color: #000000;
    border-color: #ffffff;
  }
  .modal-window .filter-btn .count { opacity: 0.7; font-size: var(--fs-sm); }

  .modal-body {
    flex: 1;
    overflow-y: auto;
    overflow-x: hidden;
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 28px;
    -webkit-overflow-scrolling: touch;
    min-width: 0;
  }

  .recipe {
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding-bottom: 24px;
    border-bottom: 1px dashed #383838;
    min-width: 0;
  }
  .recipe:last-child { border-bottom: none; padding-bottom: 0; }
  .recipe.hidden { display: none; }

  .recipe-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    font-size: var(--fs-sm);
    flex-wrap: wrap;
  }
  .recipe-tag {
    color: #888888;
    text-transform: lowercase;
    letter-spacing: 0.04em;
    min-width: 0;
    overflow-wrap: anywhere;
  }
  .recipe-copy {
    background: transparent;
    color: #888888;
    border: 1px solid #383838;
    border-radius: 10px;
    font-family: inherit;
    font-size: var(--fs-sm);
    padding: 4px 10px;
    cursor: pointer;
    white-space: nowrap;
    transition: color 150ms, border-color 150ms;
  }
  .recipe-copy:hover { color: #ffffff; border-color: #ffffff; }
  .recipe-copy.copied { color: #ffffff; border-color: #ffffff; }

  .recipe-prompt {
    font-size: var(--fs-md);
    color: #ffffff;
    margin: 0;
    line-height: 1.4;
    overflow-wrap: anywhere;
  }

  .recipe-response {
    background: #1d1d1d;
    border-radius: 10px;
    padding: 16px 19px;
    display: flex;
    flex-direction: column;
    font-size: var(--fs-base);
    color: #ffffff;
    line-height: 1.5;
    /* Long ASCII-formatted responses scroll horizontally inside this
       container instead of forcing the whole modal wider on mobile. */
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    min-width: 0;
    max-width: 100%;
  }
  .recipe-response-label { margin-bottom: 8px; }
  .recipe-response > div { white-space: pre; min-height: 1em; }

  .recipe-tools {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }
  .recipe-tools code {
    font-family: inherit;
    font-size: var(--fs-xs);
    color: #888888;
    background: #1d1d1d;
    border: 1px solid #383838;
    border-radius: 4px;
    padding: 2px 8px;
    line-height: 1.4;
  }

  .modal-footer {
    padding: 12px 24px;
    border-top: 1px solid #383838;
    font-size: var(--fs-sm);
    flex-shrink: 0;
  }

  html.modal-open body { overflow: hidden; }

  @media (max-width: 640px) {
    .modal-overlay { padding: 16px 12px; }
    .modal-header { padding: 12px 16px; gap: 8px; }
    .modal-info, .modal-filters, .modal-body, .modal-footer {
      padding-left: 16px; padding-right: 16px;
    }
    .modal-window .modal-title { font-size: var(--fs-sm); }
    .modal-close { font-size: var(--fs-base); padding: 4px 6px; }
    .recipe-response { padding: 12px 14px; font-size: var(--fs-xs); }
    .recipe-prompt { font-size: var(--fs-base); }
  }
</style>

<script>
  // RecetasModal — open/close + filter + copy. Bilingual-aware: reads
  // current lang from localStorage so it works across pages.
  (function () {
    const modal = document.getElementById('recetas-modal');
    if (!modal) return;
    const closeBtn = modal.querySelector('.modal-close');
    const filterBtns = modal.querySelectorAll<HTMLButtonElement>('.filter-btn');
    const recipes = modal.querySelectorAll<HTMLElement>('.recipe');
    const triggers = document.querySelectorAll<HTMLElement>('[data-open-recetas]');

    function openModal() {
      modal!.setAttribute('aria-hidden', 'false');
      modal!.classList.add('open');
      document.documentElement.classList.add('modal-open');
    }
    function closeModal() {
      modal!.setAttribute('aria-hidden', 'true');
      modal!.classList.remove('open');
      document.documentElement.classList.remove('modal-open');
    }

    triggers.forEach((t) => t.addEventListener('click', openModal));
    if (closeBtn) closeBtn.addEventListener('click', closeModal);
    modal.addEventListener('click', (e) => {
      if (e.target === modal) closeModal();
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && modal.classList.contains('open')) closeModal();
    });

    // Filter
    filterBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        const cat = btn.getAttribute('data-cat');
        filterBtns.forEach((b) => b.classList.remove('active'));
        btn.classList.add('active');
        recipes.forEach((r) => {
          if (cat === 'all' || r.getAttribute('data-cat') === cat) r.classList.remove('hidden');
          else r.classList.add('hidden');
        });
      });
    });

    // Copy prompt (uses current lang from localStorage)
    modal.querySelectorAll<HTMLButtonElement>('.recipe-copy').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const lang = localStorage.getItem('lang') === 'en' ? 'en' : 'es';
        const text = lang === 'en'
          ? btn.getAttribute('data-prompt-en')
          : btn.getAttribute('data-prompt-es');
        if (!text) return;
        try {
          await navigator.clipboard.writeText(text);
        } catch {
          const ta = document.createElement('textarea');
          ta.value = text;
          ta.style.position = 'fixed';
          ta.style.opacity = '0';
          document.body.appendChild(ta);
          ta.select();
          document.execCommand('copy');
          document.body.removeChild(ta);
        }
        const span = btn.querySelector('span');
        if (!span) return;
        const orig = span.textContent;
        span.textContent = lang === 'en' ? '[ ✓ copied ]' : '[ ✓ copiado ]';
        btn.classList.add('copied');
        setTimeout(() => {
          span.textContent = orig;
          btn.classList.remove('copied');
        }, 1500);
      });
    });
  })();
</script>
