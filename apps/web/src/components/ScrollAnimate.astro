---
// IntersectionObserver-driven scroll animations.
// Adds `.anim-ready` to <html> so that [data-animate] elements hide,
// then progressively reveals them as they enter the viewport.
// Robust fallback: any element not yet revealed after 2s gets shown anyway.
---

<script is:inline>
  (function () {
    if (typeof window === 'undefined') return;

    var html = document.documentElement;
    var reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    var supportsObserver = 'IntersectionObserver' in window;

    if (reduced || !supportsObserver) {
      // Don't add .anim-ready — elements stay visible.
      return;
    }

    // Activate animation styles before paint
    html.classList.add('anim-ready');

    function reveal(el) {
      el.classList.add('in-view');
    }

    function init() {
      var els = document.querySelectorAll('[data-animate]');
      if (!els.length) return;

      var observer = new IntersectionObserver(
        function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting) {
              reveal(entry.target);
              observer.unobserve(entry.target);
            }
          });
        },
        { rootMargin: '0px 0px -10% 0px', threshold: 0.05 },
      );

      // Reveal anything already in-view on first paint immediately
      var vh = window.innerHeight;
      els.forEach(function (el) {
        var rect = el.getBoundingClientRect();
        if (rect.top < vh * 0.95) {
          reveal(el);
        } else {
          observer.observe(el);
        }
      });

      // Failsafe: after 2s reveal anything still hidden (covers screenshot tools, etc.)
      setTimeout(function () {
        document.querySelectorAll('[data-animate]:not(.in-view)').forEach(reveal);
      }, 2000);
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
  })();
</script>
