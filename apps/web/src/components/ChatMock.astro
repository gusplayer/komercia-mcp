---
// ChatMock.astro — Static visual demo for the hero product card.
// Uses the new Card component for surface, light-only Column tokens for chat bubbles.
import Card from './Card.astro';
---

<Card variant="default" padding="sm" class="chat-mock">
  <!-- Window chrome bar -->
  <div class="chat-window-chrome">
    <span class="chat-window-dot" aria-hidden="true"></span>
    <span class="chat-window-dot" aria-hidden="true"></span>
    <span class="chat-window-dot" aria-hidden="true"></span>
    <span class="chat-window-label">Komercia MCP</span>
  </div>

  <!-- Chat messages area -->
  <div
    id="chat-messages"
    class="chat-messages"
    aria-live="polite"
  >
    <!-- Messages are injected by the animation script below -->
  </div>
</Card>

<style>
  .chat-mock {
    max-width: 380px;
    width: 100%;
    padding: 0 !important;
    overflow: hidden;
  }

  .chat-window-chrome {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 10px 14px;
    border-bottom: 1px solid var(--color-steel-gray);
    background: var(--color-ghost-white);
  }

  .chat-window-dot {
    width: 8px;
    height: 8px;
    border-radius: 9999px;
    background: var(--color-steel-gray);
  }

  .chat-window-label {
    margin-left: 8px;
    font-family: 'Inter', sans-serif;
    font-size: 12px;
    font-weight: 500;
    color: var(--color-slate-text);
    letter-spacing: 0.01em;
  }

  .chat-messages {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 16px;
    min-height: 280px;
    background: var(--color-ghost-white);
    overflow-y: auto;
  }

  .chat-bubble-user {
    align-self: flex-end;
    background: var(--color-deep-plum);
    color: var(--color-ghost-white);
    border-radius: 8px;
    padding: 10px 14px;
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    font-weight: 400;
    max-width: 80%;
    line-height: 1.45;
  }

  .chat-bubble-claude {
    align-self: flex-start;
    background: var(--color-fog-gray);
    border: 1px solid var(--color-steel-gray);
    border-radius: 8px;
    padding: 10px 14px;
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    font-weight: 400;
    max-width: 80%;
    color: var(--color-ink-blue);
    line-height: 1.45;
  }

  .chat-tool-call {
    align-self: flex-start;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--color-ghost-white);
    border: 1px solid var(--color-steel-gray);
    border-radius: 4px;
    padding: 6px 10px;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 11px;
    color: var(--color-charcoal-text);
  }

  .chat-tool-dot {
    width: 6px;
    height: 6px;
    border-radius: 9999px;
    background: var(--color-action-orange);
    flex-shrink: 0;
  }

  @keyframes chat-pulse {
    0%, 80%, 100% { opacity: 0.25; transform: scale(0.75); }
    40%            { opacity: 1;    transform: scale(1); }
  }

  .chat-typing-dot {
    display: inline-block;
    width: 5px;
    height: 5px;
    border-radius: 9999px;
    background: var(--color-steel-gray);
    animation: chat-pulse 1.4s ease-in-out infinite;
  }
</style>

<script>
  (function () {
    var container = document.getElementById('chat-messages');
    if (!container) return;

    // Respect users who prefer reduced motion: render the final state of the
    // conversation immediately and skip the animation/loop entirely.
    var prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // Message sequence definitions — realistic Komercia + Claude interaction
    type ChatMessage = { type: 'user' | 'claude' | 'tool' | 'file'; text: string; html?: string };
    var messages: ChatMessage[] = [
      { type: 'user',   text: '¿Cuál fue mi producto más vendido el mes pasado?' },
      { type: 'tool',   text: '→ export_orders' },
      { type: 'tool',   text: '→ export_products' },
      {
        type: 'claude',
        text: '',
        html: 'Tu top 3 de marzo:<br><strong>Sticker Pack Deluxe</strong> · 47 ventas · $1.84M COP<br><strong>Pines Edición Limitada</strong> · 31 ventas · $1.24M COP<br><strong>Bolsas Tote</strong> · 22 ventas · $880K COP',
      },
      { type: 'user',   text: 'Genérame un CSV con todos los pedidos pagados de marzo' },
      { type: 'tool',   text: '→ export_orders (filter: paid, march)' },
      {
        type: 'claude',
        text: '',
        html: 'Listo. <strong>47 pedidos</strong>, $5.2M COP en ingresos. Descarga el CSV aquí ↓',
      },
    ];

    var timers: ReturnType<typeof setTimeout>[] = [];

    function clearTimers() {
      timers.forEach(function (t) { clearTimeout(t); });
      timers = [];
    }

    function revealElement(el: HTMLElement) {
      // Force reflow so the CSS transition fires correctly
      void el.offsetHeight;
      el.style.opacity = '1';
      el.style.transform = 'translateY(0)';
    }

    function applyEntryStyle(el: HTMLElement) {
      el.style.opacity = '0';
      el.style.transform = 'translateY(6px)';
      el.style.transition = 'opacity 350ms ease, transform 350ms ease';
    }

    function createUserBubble(text: string): HTMLElement {
      var el = document.createElement('div');
      el.className = 'chat-bubble-user';
      el.textContent = text;
      applyEntryStyle(el);
      return el;
    }

    function createClaudeBubble(text: string, html?: string): HTMLElement {
      var el = document.createElement('div');
      el.className = 'chat-bubble-claude';
      if (html) {
        el.innerHTML = html;
      } else {
        el.textContent = text;
      }
      applyEntryStyle(el);
      return el;
    }

    function createToolCall(text: string): HTMLElement {
      var el = document.createElement('div');
      el.className = 'chat-tool-call';
      var dot = document.createElement('span');
      dot.className = 'chat-tool-dot';
      el.appendChild(dot);
      el.appendChild(document.createTextNode(text));
      applyEntryStyle(el);
      return el;
    }

    function createFileAttachment(text: string): HTMLElement {
      var el = document.createElement('div');
      el.className = 'chat-bubble-claude';
      el.style.cssText += '; display: flex; align-items: center; gap: 8px;';
      var icon = document.createElement('span');
      icon.style.cssText = "font-family: 'IBM Plex Mono', monospace; font-size: 11px; color: var(--color-slate-text);";
      icon.textContent = '↗';
      var label = document.createElement('span');
      label.style.cssText = "font-family: 'IBM Plex Mono', monospace; font-size: 12px; color: var(--color-ink-blue);";
      label.textContent = text;
      el.appendChild(icon);
      el.appendChild(label);
      applyEntryStyle(el);
      return el;
    }

    function createTypingIndicator(): HTMLElement {
      var el = document.createElement('div');
      el.className = 'chat-bubble-claude';
      el.style.cssText = 'display: flex; align-items: center; gap: 5px; padding: 12px 14px;';
      for (var i = 0; i < 3; i++) {
        var dot = document.createElement('span');
        dot.className = 'chat-typing-dot';
        dot.style.animationDelay = (i * 0.2) + 's';
        el.appendChild(dot);
      }
      return el;
    }

    function scrollToBottom() {
      if (container) {
        container.scrollTop = container.scrollHeight;
      }
    }

    function renderStaticConversation() {
      if (!container) return;
      container.innerHTML = '';
      messages.forEach(function (msg) {
        var el: HTMLElement;
        if (msg.type === 'user') {
          el = createUserBubble(msg.text);
        } else if (msg.type === 'tool') {
          el = createToolCall(msg.text);
        } else if (msg.type === 'file') {
          el = createFileAttachment(msg.text);
        } else {
          el = createClaudeBubble(msg.text, msg.html);
        }
        // Skip the entry transition: show the final state directly.
        el.style.opacity = '1';
        el.style.transform = 'translateY(0)';
        el.style.transition = 'none';
        container!.appendChild(el);
      });
      scrollToBottom();
    }

    function runSequence() {
      if (!container) return;
      container.innerHTML = '';
      var delay = 400;
      var stepDelay = 900;
      var typingDelay = 700;

      messages.forEach(function (msg) {
        var isAssistant = msg.type === 'claude' || msg.type === 'file';

        if (isAssistant) {
          // Show typing indicator, then replace with the real bubble
          (function (d, m) {
            timers.push(setTimeout(function () {
              var typing = createTypingIndicator();
              container!.appendChild(typing);
              scrollToBottom();

              timers.push(setTimeout(function () {
                container!.removeChild(typing);
                var el: HTMLElement;
                if (m.type === 'file') {
                  el = createFileAttachment(m.text);
                } else {
                  el = createClaudeBubble(m.text, m.html);
                }
                container!.appendChild(el);
                revealElement(el);
                scrollToBottom();
              }, typingDelay));
            }, d));
          })(delay, msg);

          delay += typingDelay + stepDelay;
        } else {
          // User and tool call bubbles appear directly
          (function (d, m) {
            timers.push(setTimeout(function () {
              var el: HTMLElement;
              if (m.type === 'user') {
                el = createUserBubble(m.text);
              } else {
                el = createToolCall(m.text);
              }
              container!.appendChild(el);
              revealElement(el);
              scrollToBottom();
            }, d));
          })(delay, msg);

          delay += stepDelay;
        }
      });

      // Loop: wait briefly after the last message then restart
      timers.push(setTimeout(function () {
        clearTimers();
        runSequence();
      }, delay + 1000));
    }

    if (prefersReducedMotion) {
      renderStaticConversation();
    } else {
      runSequence();
    }
  })();
</script>
