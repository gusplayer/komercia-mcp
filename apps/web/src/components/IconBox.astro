---
/**
 * IconBox — tinted-square-with-icon container, Column-style.
 *
 * Renders a fixed-size square with a soft tint of a theme color and the
 * icon (passed via slot) painted in the full color of that theme.
 *
 * Variants: plum (default), orange, blue, green, cyan, teal, red.
 * Sizes:    sm (32px), md (40px, default), lg (48px).
 */
interface Props {
  variant?: 'plum' | 'orange' | 'blue' | 'green' | 'cyan' | 'teal' | 'red';
  size?: 'sm' | 'md' | 'lg';
  class?: string;
}

const { variant = 'plum', size = 'md', class: className = '' } = Astro.props;

const sizes = {
  sm: { box: '32px', icon: '14px' },
  md: { box: '40px', icon: '18px' },
  lg: { box: '48px', icon: '22px' },
};

const colors = {
  plum:   { bg: 'rgba(17, 26, 74, 0.08)',   fg: 'var(--color-deep-plum)' },
  orange: { bg: 'rgba(236, 101, 43, 0.08)', fg: 'var(--color-action-orange)' },
  blue:   { bg: 'rgba(126, 167, 233, 0.12)', fg: 'var(--color-info-blue)' },
  green:  { bg: 'rgba(68, 180, 139, 0.10)',  fg: 'var(--color-success-moss)' },
  cyan:   { bg: 'rgba(22, 126, 108, 0.08)',  fg: 'var(--color-callout-cyan)' },
  teal:   { bg: 'rgba(136, 222, 235, 0.18)', fg: '#0e7d8a' },
  red:    { bg: 'rgba(220, 38, 38, 0.08)',   fg: 'var(--color-danger)' },
};

const s = sizes[size];
const c = colors[variant];
---

<span
  class={`icon-box ${className}`}
  style={`width: ${s.box}; height: ${s.box}; background: ${c.bg}; color: ${c.fg}; --icon-size: ${s.icon};`}
  aria-hidden="true"
>
  <slot />
</span>
