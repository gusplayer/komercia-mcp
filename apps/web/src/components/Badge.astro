---
// Badge.astro — Small inline label aligned with the Column design system.

interface Props {
  variant?: 'default' | 'success' | 'info' | 'cyan' | 'plum' | 'orange';
  class?: string;
}

const { variant = 'default', class: className = '' } = Astro.props;

const variantClass = variant === 'default' ? 'badge' : `badge badge-${variant}`;
---

<span class={`${variantClass} ${className}`}>
  <slot />
</span>
