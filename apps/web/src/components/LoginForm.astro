---
// LoginForm.astro
// Renders email + password form. On success, replaces itself with the token display inline.
---

<div id="login-section">
  <form id="login-form" novalidate>
    <div class="space-y-5">
      <!-- Email -->
      <div>
        <label for="email" class="block text-xs font-medium mb-2" style="color: var(--text-secondary)">
          Correo electrónico
        </label>
        <input
          id="email"
          name="email"
          type="email"
          autocomplete="email"
          required
          placeholder="tu@correo.com"
          class="input-field"
        />
      </div>

      <!-- Password -->
      <div>
        <label for="password" class="block text-xs font-medium mb-2" style="color: var(--text-secondary)">
          Contraseña
        </label>
        <input
          id="password"
          name="password"
          type="password"
          autocomplete="current-password"
          required
          placeholder="Tu contraseña de Komercia"
          class="input-field"
        />
      </div>

      <!-- Error message -->
      <div
        id="form-error"
        role="alert"
        aria-live="polite"
        class="hidden rounded-lg px-4 py-3 text-sm"
        style="background-color: color-mix(in srgb, var(--danger) 8%, transparent); border: 1px solid color-mix(in srgb, var(--danger) 30%, transparent); color: var(--danger);"
      ></div>

      <!-- Submit -->
      <button
        id="submit-btn"
        type="submit"
        class="btn-primary w-full"
      >
        <span id="btn-label">Obtener mi token</span>
        <svg
          id="btn-spinner"
          class="hidden animate-spin h-4 w-4"
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8H4z"></path>
        </svg>
      </button>
    </div>
  </form>
</div>

<!-- Token display (hidden until login succeeds) -->
<div id="token-section" class="hidden space-y-6">
  <!-- Success header -->
  <div>
    <div class="flex items-center gap-2 mb-3">
      <div class="w-7 h-7 rounded-lg flex items-center justify-center" style="background: color-mix(in srgb, var(--accent) 12%, transparent); border: 1px solid color-mix(in srgb, var(--accent) 30%, transparent);">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="color: var(--accent)">
          <polyline points="20 6 9 17 4 12"/>
        </svg>
      </div>
      <span class="text-sm font-medium" style="color: var(--accent)">Token listo</span>
    </div>
    <div class="flex items-start gap-2 rounded-lg px-4 py-3" style="background: color-mix(in srgb, var(--warning) 8%, transparent); border: 1px solid color-mix(in srgb, var(--warning) 25%, transparent);">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="flex-shrink-0 mt-0.5" style="color: var(--warning)">
        <path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/>
        <path d="M12 9v4M12 17h.01"/>
      </svg>
      <p class="text-sm font-medium" style="color: var(--text-primary)">
        Este es tu token de exportación. Cópialo ahora — no se mostrará de nuevo si sales de esta página.
      </p>
    </div>
  </div>

  <!-- Masked token display -->
  <div>
    <p class="text-[10px] font-medium mb-2 uppercase tracking-[0.18em]" style="color: var(--text-tertiary)">JWT Token</p>
    <div
      id="token-box"
      class="rounded-lg p-4 font-mono text-sm break-all select-all"
      style="background-color: var(--bg-tertiary); border: 1px solid var(--border); color: var(--text-primary);"
      aria-label="JWT token (enmascarado)"
    >
      <span id="token-masked"></span>
    </div>
  </div>

  <!-- Copy button -->
  <button
    id="copy-btn"
    type="button"
    class="btn-primary w-full"
  >
    <span id="copy-label" class="inline-flex items-center gap-2">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <rect width="14" height="14" x="8" y="8" rx="2" ry="2"/>
        <path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/>
      </svg>
      Copiar token al portapapeles
    </span>
    <span id="copy-success" class="hidden items-center gap-2">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="20 6 9 17 4 12"/>
      </svg>
      ¡Copiado!
    </span>
  </button>

  <!-- Instructions -->
  <div class="rounded-xl p-5 space-y-4 !mt-6" style="background-color: var(--bg-tertiary); border: 1px solid var(--border);">
    <h3 class="text-xs font-semibold uppercase tracking-[0.18em]" style="color: var(--text-secondary)">Cómo usar tu token en Claude.ai</h3>
    <ol class="space-y-3">
      <li class="flex items-start gap-3">
        <span class="step-number !w-6 !h-6 !text-xs">1</span>
        <div class="text-sm" style="color: var(--text-secondary)">
          <p class="font-medium mb-0.5" style="color: var(--text-primary)">Abre la configuración de Claude.ai</p>
          <p>Ve a <strong>Configuración → Conectores</strong> y agrega un conector personalizado.</p>
        </div>
      </li>
      <li class="flex items-start gap-3">
        <span class="step-number !w-6 !h-6 !text-xs">2</span>
        <div class="text-sm" style="color: var(--text-secondary)">
          <p class="font-medium mb-0.5" style="color: var(--text-primary)">Introduce la URL del servidor</p>
          <p>Usa <code class="code-chip">https://mcp.komercia-exit.com</code> y pega tu token en Authorization.</p>
        </div>
      </li>
      <li class="flex items-start gap-3">
        <span class="step-number !w-6 !h-6 !text-xs">3</span>
        <div class="text-sm" style="color: var(--text-secondary)">
          <p class="font-medium mb-0.5" style="color: var(--text-primary)">Empieza a conversar</p>
          <p>Pídele a Claude: <em>"Exporta todos mis productos en formato Shopify"</em>.</p>
        </div>
      </li>
    </ol>
    <p class="text-xs pt-3 border-t" style="color: var(--text-tertiary); border-color: var(--border);">
      Token válido por 6 meses. Para renovarlo, <a href="/" class="link-accent">vuelve a iniciar sesión</a>.
    </p>
  </div>

  <!-- Revoke / start over -->
  <div class="text-center pt-2">
    <button
      id="revoke-btn"
      type="button"
      class="text-xs underline transition-colors duration-150"
      style="color: var(--text-tertiary)"
      onmouseover="this.style.color='var(--danger)'"
      onmouseout="this.style.color='var(--text-tertiary)'"
    >
      Revocar este token y empezar de nuevo
    </button>
    <p id="revoke-status" class="hidden mt-2 text-xs"></p>
  </div>
</div>

<script>
  // Read the CSRF token from cookie so we can send it in the header
  function getCsrfToken(): string {
    return (
      document.cookie
        .split(';')
        .map((c) => c.trim())
        .find((c) => c.startsWith('csrf_token='))
        ?.split('=')[1] ?? ''
    );
  }

  function maskToken(token: string): string {
    if (token.length <= 35) return token;
    return `${token.slice(0, 20)}${'·'.repeat(10)}${token.slice(-10)}`;
  }

  function setInputError(input: HTMLInputElement, hasError: boolean): void {
    if (hasError) {
      input.style.borderColor = 'var(--danger)';
      input.style.boxShadow = '0 0 0 3px rgb(239 68 68 / 0.12)';
    } else {
      input.style.borderColor = '';
      input.style.boxShadow = '';
    }
  }

  const form = document.getElementById('login-form') as HTMLFormElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const btnLabel = document.getElementById('btn-label') as HTMLSpanElement;
  const btnSpinner = document.getElementById('btn-spinner') as HTMLElement;
  const formError = document.getElementById('form-error') as HTMLDivElement;
  const loginSection = document.getElementById('login-section') as HTMLDivElement;
  const tokenSection = document.getElementById('token-section') as HTMLDivElement;
  const tokenMasked = document.getElementById('token-masked') as HTMLSpanElement;
  const copyBtn = document.getElementById('copy-btn') as HTMLButtonElement;
  const copyLabel = document.getElementById('copy-label') as HTMLSpanElement;
  const copySuccess = document.getElementById('copy-success') as HTMLSpanElement;
  const emailInput = document.getElementById('email') as HTMLInputElement;
  const passwordInput = document.getElementById('password') as HTMLInputElement;

  let storedToken = '';

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    const email = emailInput.value.trim();
    const password = passwordInput.value;

    // Client-side validation
    let hasError = false;
    if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      setInputError(emailInput, true);
      hasError = true;
    } else {
      setInputError(emailInput, false);
    }
    if (!password) {
      setInputError(passwordInput, true);
      hasError = true;
    } else {
      setInputError(passwordInput, false);
    }

    if (hasError) {
      formError.textContent = 'Por favor ingresa un correo y contraseña válidos.';
      formError.classList.remove('hidden');
      return;
    }

    // Loading state
    submitBtn.disabled = true;
    btnLabel.textContent = 'Iniciando sesión…';
    btnSpinner.classList.remove('hidden');
    formError.classList.add('hidden');

    try {
      const res = await fetch('/api/login', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'X-CSRF-Token': getCsrfToken(),
        },
        body: JSON.stringify({ email, password }),
      });

      const data = (await res.json()) as { token?: string; error?: string };

      if (res.ok && data.token) {
        storedToken = data.token;
        tokenMasked.textContent = maskToken(storedToken);

        // Swap login form for token display
        loginSection.classList.add('hidden');
        tokenSection.classList.remove('hidden');
      } else {
        const msg = data.error ?? 'Ocurrió un error inesperado. Inténtalo de nuevo.';
        formError.textContent = msg;
        formError.classList.remove('hidden');
        setInputError(passwordInput, true);
      }
    } catch {
      formError.textContent = 'No se pudo conectar al servidor. Revisa tu conexión e inténtalo de nuevo.';
      formError.classList.remove('hidden');
    } finally {
      submitBtn.disabled = false;
      btnLabel.textContent = 'Obtener mi token';
      btnSpinner.classList.add('hidden');
    }
  });

  // Clear error styling on input change
  emailInput.addEventListener('input', () => setInputError(emailInput, false));
  passwordInput.addEventListener('input', () => setInputError(passwordInput, false));

  // Copy button
  copyBtn.addEventListener('click', async () => {
    if (!storedToken) return;

    try {
      await navigator.clipboard.writeText(storedToken);
    } catch {
      const textarea = document.createElement('textarea');
      textarea.value = storedToken;
      textarea.style.position = 'fixed';
      textarea.style.opacity = '0';
      document.body.appendChild(textarea);
      textarea.select();
      document.execCommand('copy');
      document.body.removeChild(textarea);
    }

    copyLabel.classList.add('hidden');
    copySuccess.classList.remove('hidden');
    copySuccess.classList.add('inline-flex');

    setTimeout(() => {
      copyLabel.classList.remove('hidden');
      copySuccess.classList.add('hidden');
      copySuccess.classList.remove('inline-flex');
    }, 3000);
  });

  // Revoke button — invalidates the stored session in the DB.
  const revokeBtn = document.getElementById('revoke-btn') as HTMLButtonElement | null;
  const revokeStatus = document.getElementById('revoke-status') as HTMLParagraphElement | null;
  if (revokeBtn && revokeStatus) {
    revokeBtn.addEventListener('click', async () => {
      if (!storedToken) return;
      if (!window.confirm('¿Revocar este token? Cualquiera que lo esté usando perderá acceso de inmediato.')) return;
      revokeBtn.disabled = true;
      revokeStatus.textContent = 'Revocando…';
      revokeStatus.className = 'mt-2 text-xs';
      revokeStatus.style.color = 'var(--text-tertiary)';
      revokeStatus.classList.remove('hidden');
      try {
        const res = await fetch('/api/sessions/revoke', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': getCsrfToken() },
          body: JSON.stringify({ token: storedToken }),
        });
        const data = (await res.json()) as { revoked?: boolean; error?: string };
        if (res.ok && data.revoked) {
          revokeStatus.textContent = 'Token revocado. Redirigiendo al inicio…';
          revokeStatus.style.color = 'var(--accent)';
          setTimeout(() => { window.location.href = '/'; }, 1500);
        } else {
          revokeStatus.textContent = data.error ?? 'No se pudo revocar. Inténtalo de nuevo.';
          revokeStatus.style.color = 'var(--danger)';
          revokeBtn.disabled = false;
        }
      } catch {
        revokeStatus.textContent = 'Error de red. Por favor inténtalo de nuevo.';
        revokeStatus.style.color = 'var(--danger)';
        revokeBtn.disabled = false;
      }
    });
  }
</script>
