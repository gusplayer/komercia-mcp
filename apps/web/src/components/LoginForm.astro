---
// LoginForm.astro
// Renders email + password form. On success, replaces itself with the token display inline.
---

<div id="login-section">
  <form id="login-form" novalidate>
    <div class="space-y-4">
      <!-- Email -->
      <div>
        <label for="email" class="block text-sm font-medium text-slate-700 mb-1">
          Email address
        </label>
        <input
          id="email"
          name="email"
          type="email"
          autocomplete="email"
          required
          placeholder="you@example.com"
          class="w-full rounded-lg border border-slate-200 bg-white px-3 py-2.5 text-sm text-slate-900 placeholder-slate-400 shadow-sm transition focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-200"
        />
      </div>

      <!-- Password -->
      <div>
        <label for="password" class="block text-sm font-medium text-slate-700 mb-1">
          Password
        </label>
        <input
          id="password"
          name="password"
          type="password"
          autocomplete="current-password"
          required
          placeholder="Your Komercia password"
          class="w-full rounded-lg border border-slate-200 bg-white px-3 py-2.5 text-sm text-slate-900 placeholder-slate-400 shadow-sm transition focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-200"
        />
      </div>

      <!-- Error message -->
      <div
        id="form-error"
        role="alert"
        aria-live="polite"
        class="hidden rounded-lg border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700"
      ></div>

      <!-- Submit -->
      <button
        id="submit-btn"
        type="submit"
        class="btn-primary w-full flex items-center justify-center gap-2"
      >
        <span id="btn-label">Get my export token</span>
        <svg
          id="btn-spinner"
          class="hidden animate-spin h-4 w-4 text-white"
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8H4z"></path>
        </svg>
      </button>
    </div>
  </form>
</div>

<!-- Token display (hidden until login succeeds) -->
<div id="token-section" class="hidden space-y-6">
  <!-- Success header -->
  <div>
    <div class="flex items-center gap-2 mb-3">
      <div class="w-8 h-8 rounded-lg bg-green-50 border border-green-200 flex items-center justify-center">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="20 6 9 17 4 12"/>
        </svg>
      </div>
      <span class="text-sm font-medium text-green-700">Token ready</span>
    </div>
    <div class="flex items-start gap-2 rounded-lg border border-amber-200 bg-amber-50 px-4 py-3">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#d97706" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="flex-shrink-0 mt-0.5">
        <path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/>
        <path d="M12 9v4M12 17h.01"/>
      </svg>
      <p class="text-sm text-amber-800 font-medium">
        This is your export token. Copy it now — it won&rsquo;t be shown again if you leave this page.
      </p>
    </div>
  </div>

  <!-- Masked token display -->
  <div>
    <p class="text-xs font-medium text-slate-500 mb-2 uppercase tracking-wide">JWT Token</p>
    <div
      id="token-box"
      class="rounded-lg border border-slate-200 bg-slate-50 p-4 font-mono text-sm text-slate-700 break-all select-all"
      aria-label="JWT token (masked)"
    >
      <span id="token-masked"></span>
    </div>
  </div>

  <!-- Copy button -->
  <button
    id="copy-btn"
    type="button"
    class="btn-primary w-full flex items-center justify-center gap-2"
  >
    <span id="copy-label" class="flex items-center gap-2">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <rect width="14" height="14" x="8" y="8" rx="2" ry="2"/>
        <path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/>
      </svg>
      Copy token to clipboard
    </span>
    <span id="copy-success" class="hidden items-center gap-2 text-green-100">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="20 6 9 17 4 12"/>
      </svg>
      Copied!
    </span>
  </button>

  <!-- Instructions -->
  <div class="card space-y-4 !mt-6">
    <h3 class="text-sm font-semibold text-slate-700">How to use this token in Claude.ai</h3>
    <ol class="space-y-3">
      <li class="flex items-start gap-3">
        <span class="flex-shrink-0 w-6 h-6 rounded-full bg-indigo-50 border border-indigo-100 flex items-center justify-center text-xs font-semibold text-accent">1</span>
        <div class="text-sm text-slate-600">
          <p class="font-medium text-slate-800 mb-0.5">Open Claude.ai Settings</p>
          <p>Go to <strong>Settings &rarr; Integrations</strong> and click <strong>Add integration</strong>.</p>
        </div>
      </li>
      <li class="flex items-start gap-3">
        <span class="flex-shrink-0 w-6 h-6 rounded-full bg-indigo-50 border border-indigo-100 flex items-center justify-center text-xs font-semibold text-accent">2</span>
        <div class="text-sm text-slate-600">
          <p class="font-medium text-slate-800 mb-0.5">Enter the MCP server URL</p>
          <p>Use the Komercia MCP server URL and paste your token as the auth credential.</p>
        </div>
      </li>
      <li class="flex items-start gap-3">
        <span class="flex-shrink-0 w-6 h-6 rounded-full bg-indigo-50 border border-indigo-100 flex items-center justify-center text-xs font-semibold text-accent">3</span>
        <div class="text-sm text-slate-600">
          <p class="font-medium text-slate-800 mb-0.5">Start a new conversation</p>
          <p>Say <em>"Export all my products as a CSV file"</em> or <em>"Show my order history from the last 90 days."</em></p>
        </div>
      </li>
    </ol>
    <p class="text-xs text-slate-400 pt-2 border-t border-slate-100">
      Token valid for 6 months. To get a new token, <a href="/" class="underline hover:text-slate-600">log in again</a>.
      See <a href="/tools" class="underline hover:text-slate-600">all available export tools</a>.
    </p>
  </div>
</div>

<script>
  // Read the CSRF token from cookie so we can send it in the header
  function getCsrfToken(): string {
    return (
      document.cookie
        .split(';')
        .map((c) => c.trim())
        .find((c) => c.startsWith('csrf_token='))
        ?.split('=')[1] ?? ''
    );
  }

  function maskToken(token: string): string {
    if (token.length <= 35) return token;
    return `${token.slice(0, 20)}${'·'.repeat(10)}${token.slice(-10)}`;
  }

  function setInputError(input: HTMLInputElement, hasError: boolean): void {
    if (hasError) {
      input.classList.add('border-red-400', 'ring-red-200', 'focus:border-red-400');
      input.classList.remove('border-slate-200');
    } else {
      input.classList.remove('border-red-400', 'ring-red-200', 'focus:border-red-400');
      input.classList.add('border-slate-200');
    }
  }

  const form = document.getElementById('login-form') as HTMLFormElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const btnLabel = document.getElementById('btn-label') as HTMLSpanElement;
  const btnSpinner = document.getElementById('btn-spinner') as HTMLElement;
  const formError = document.getElementById('form-error') as HTMLDivElement;
  const loginSection = document.getElementById('login-section') as HTMLDivElement;
  const tokenSection = document.getElementById('token-section') as HTMLDivElement;
  const tokenMasked = document.getElementById('token-masked') as HTMLSpanElement;
  const copyBtn = document.getElementById('copy-btn') as HTMLButtonElement;
  const copyLabel = document.getElementById('copy-label') as HTMLSpanElement;
  const copySuccess = document.getElementById('copy-success') as HTMLSpanElement;
  const emailInput = document.getElementById('email') as HTMLInputElement;
  const passwordInput = document.getElementById('password') as HTMLInputElement;

  let storedToken = '';

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    const email = emailInput.value.trim();
    const password = passwordInput.value;

    // Client-side validation
    let hasError = false;
    if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      setInputError(emailInput, true);
      hasError = true;
    } else {
      setInputError(emailInput, false);
    }
    if (!password) {
      setInputError(passwordInput, true);
      hasError = true;
    } else {
      setInputError(passwordInput, false);
    }

    if (hasError) {
      formError.textContent = 'Please enter a valid email and password.';
      formError.classList.remove('hidden');
      return;
    }

    // Loading state
    submitBtn.disabled = true;
    btnLabel.textContent = 'Signing in…';
    btnSpinner.classList.remove('hidden');
    formError.classList.add('hidden');

    try {
      const res = await fetch('/api/login', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'X-CSRF-Token': getCsrfToken(),
        },
        body: JSON.stringify({ email, password }),
      });

      const data = (await res.json()) as { token?: string; error?: string };

      if (res.ok && data.token) {
        storedToken = data.token;
        tokenMasked.textContent = maskToken(storedToken);

        // Swap login form for token display
        loginSection.classList.add('hidden');
        tokenSection.classList.remove('hidden');
      } else {
        const msg = data.error ?? 'An unexpected error occurred. Please try again.';
        formError.textContent = msg;
        formError.classList.remove('hidden');
        setInputError(passwordInput, true);
      }
    } catch {
      formError.textContent = 'Could not reach the server. Check your connection and try again.';
      formError.classList.remove('hidden');
    } finally {
      submitBtn.disabled = false;
      btnLabel.textContent = 'Get my export token';
      btnSpinner.classList.add('hidden');
    }
  });

  // Clear error styling on input change
  emailInput.addEventListener('input', () => setInputError(emailInput, false));
  passwordInput.addEventListener('input', () => setInputError(passwordInput, false));

  // Copy button
  copyBtn.addEventListener('click', async () => {
    if (!storedToken) return;

    try {
      await navigator.clipboard.writeText(storedToken);
    } catch {
      const textarea = document.createElement('textarea');
      textarea.value = storedToken;
      textarea.style.position = 'fixed';
      textarea.style.opacity = '0';
      document.body.appendChild(textarea);
      textarea.select();
      document.execCommand('copy');
      document.body.removeChild(textarea);
    }

    copyLabel.classList.add('hidden');
    copySuccess.classList.remove('hidden');
    copySuccess.classList.add('inline-flex');
    copyBtn.classList.add('bg-green-600', 'hover:bg-green-700');
    copyBtn.classList.remove('bg-accent', 'hover:bg-accent-dark');

    setTimeout(() => {
      copyLabel.classList.remove('hidden');
      copySuccess.classList.add('hidden');
      copySuccess.classList.remove('inline-flex');
      copyBtn.classList.remove('bg-green-600', 'hover:bg-green-700');
      copyBtn.classList.add('bg-accent', 'hover:bg-accent-dark');
    }, 3000);
  });
</script>
