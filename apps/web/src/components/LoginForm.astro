---
// LoginForm.astro — Email + password form. On success, swaps inline with the token display.
// Aligned with the Column design system (light-only, fintech aesthetic).
import Button from './Button.astro';
---

<div id="login-section">
  <form id="login-form" novalidate>
    <div style="display: flex; flex-direction: column; gap: 20px;">
      <!-- Email -->
      <div>
        <label
          for="email"
          style="display: block; margin-bottom: 8px; font-family: 'Inter', sans-serif; font-size: 13px; font-weight: 400; color: var(--color-charcoal-text);"
        >
          Correo electrónico
        </label>
        <input
          id="email"
          name="email"
          type="email"
          autocomplete="email"
          required
          placeholder="tu@correo.com"
          class="input-field"
        />
      </div>

      <!-- Password -->
      <div>
        <label
          for="password"
          style="display: block; margin-bottom: 8px; font-family: 'Inter', sans-serif; font-size: 13px; font-weight: 400; color: var(--color-charcoal-text);"
        >
          Contraseña
        </label>
        <input
          id="password"
          name="password"
          type="password"
          autocomplete="current-password"
          required
          placeholder="Tu contraseña de Komercia"
          class="input-field"
        />
      </div>

      <!-- Error alert -->
      <div
        id="form-error"
        role="alert"
        aria-live="polite"
        class="hidden alert-error"
      ></div>

      <!-- Submit -->
      <Button variant="primary" type="submit" fullWidth id="submit-btn">
        <span id="btn-label">Obtener mi token</span>
        <svg
          id="btn-spinner"
          class="hidden animate-spin"
          width="16"
          height="16"
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24"
          aria-hidden="true"
          style="margin-left: 8px;"
        >
          <circle style="opacity: 0.25;" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path style="opacity: 0.75;" fill="currentColor" d="M4 12a8 8 0 018-8v8H4z"></path>
        </svg>
      </Button>
    </div>
  </form>
</div>

<!-- Token section — hidden until login succeeds -->
<div id="token-section" class="hidden" style="display: none; flex-direction: column; gap: 24px;">

  <!-- Success header -->
  <div>
    <p style="font-family: 'Inter', sans-serif; font-size: 14px; font-weight: 500; color: var(--color-success-moss); margin: 0 0 12px;">
      Token listo
    </p>

    <!-- Warning alert -->
    <div class="alert-warning" role="note">
      Este es tu token MCP. Cópialo ahora — no se mostrará de nuevo si sales de esta página.
    </div>
  </div>

  <!-- Token display -->
  <div>
    <p style="
      font-family: 'Inter', sans-serif;
      font-size: 10px;
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: 0.18em;
      color: var(--color-slate-text);
      margin: 0 0 8px;
    ">JWT Token</p>
    <pre
      id="token-box"
      class="code-block"
      aria-label="JWT token (enmascarado)"
      style="margin: 0; font-family: 'IBM Plex Mono', monospace; font-size: 12px; word-break: break-all; user-select: all; white-space: pre-wrap;"
    ><span id="token-masked"></span></pre>
  </div>

  <!-- Copy button -->
  <Button variant="primary" fullWidth id="copy-btn">
    <span id="copy-label" class="inline-flex items-center" style="gap: 8px;">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <rect width="14" height="14" x="8" y="8" rx="2" ry="2"/>
        <path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/>
      </svg>
      Copiar token al portapapeles
    </span>
    <span id="copy-success" class="hidden items-center" style="gap: 8px;">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <polyline points="20 6 9 17 4 12"/>
      </svg>
      ¡Copiado!
    </span>
  </Button>

  <!-- Quick connect snippets -->
  <div style="border-top: 1px solid var(--color-steel-gray); padding-top: 24px; display: flex; flex-direction: column; gap: 20px;">
    <p class="snippet-section-label">Conecta en un clic</p>

    <!-- Claude Code -->
    <div class="snippet-block">
      <div class="snippet-meta">
        <span class="snippet-client">Claude Code</span>
        <span class="snippet-where">Terminal · un solo comando</span>
      </div>
      <div class="snippet-row">
        <code id="cmd-claude-code" class="snippet-code">claude mcp add --transport sse komercia https://api-mcp.komercia.co/sse --header "Authorization: Bearer …"</code>
        <button class="snippet-copy-btn" data-target="cmd-claude-code" aria-label="Copiar comando Claude Code">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>
        </button>
      </div>
    </div>

    <!-- Claude.ai -->
    <div class="snippet-block">
      <div class="snippet-meta">
        <span class="snippet-client">Claude.ai</span>
        <span class="snippet-where">Settings → Integrations → Add MCP Server</span>
      </div>
      <div style="display: flex; flex-direction: column; gap: 8px;">
        <div>
          <p class="snippet-field-label">Server URL</p>
          <div class="snippet-row">
            <code id="cmd-claudeai-url" class="snippet-code">https://api-mcp.komercia.co/sse</code>
            <button class="snippet-copy-btn" data-target="cmd-claudeai-url" aria-label="Copiar URL">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>
            </button>
          </div>
        </div>
        <div>
          <p class="snippet-field-label">Authorization header</p>
          <div class="snippet-row">
            <code id="cmd-claudeai-auth" class="snippet-code">Bearer …</code>
            <button class="snippet-copy-btn" data-target="cmd-claudeai-auth" aria-label="Copiar header">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>
            </button>
          </div>
        </div>
      </div>
    </div>

    <!-- Claude Desktop -->
    <div class="snippet-block">
      <div class="snippet-meta">
        <span class="snippet-client">Claude Desktop</span>
        <span class="snippet-where">claude_desktop_config.json</span>
      </div>
      <div class="snippet-row" style="align-items: flex-start;">
        <code id="cmd-desktop" class="snippet-code" style="white-space: pre; font-size: 11px; line-height: 1.5;"></code>
        <button class="snippet-copy-btn" data-target="cmd-desktop" aria-label="Copiar JSON" style="margin-top: 2px; flex-shrink: 0;">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>
        </button>
      </div>
    </div>

    <p style="font-family: 'Inter', sans-serif; font-size: 12px; color: var(--color-slate-text); margin: 0;">
      Token válido por 6 meses · <a href="/uso" class="instructions-renew-link">Ver guía completa →</a>
    </p>
  </div>

  <!-- Revoke / start over -->
  <div style="text-align: center; padding-top: 8px;">
    <button id="revoke-btn" type="button" class="revoke-btn">
      Revocar este token y empezar de nuevo
    </button>
    <p id="revoke-status" class="hidden" style="margin-top: 8px; font-family: 'Inter', sans-serif; font-size: 12px;"></p>
  </div>
</div>

<style>
  .instructions-renew-link {
    color: var(--color-charcoal-text);
    text-decoration: underline;
    transition: color 150ms ease;
  }
  .instructions-renew-link:hover { color: var(--color-ink-blue); }

  /* Snippet blocks */
  .snippet-section-label {
    font-family: 'Inter', sans-serif;
    font-size: 11px;
    font-weight: 500;
    color: var(--color-deep-plum);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin: 0;
  }
  .snippet-block {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .snippet-meta {
    display: flex;
    align-items: baseline;
    gap: 8px;
  }
  .snippet-client {
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    font-weight: 500;
    color: var(--color-ink-blue);
  }
  .snippet-where {
    font-family: 'Inter', sans-serif;
    font-size: 11px;
    color: var(--color-slate-text);
  }
  .snippet-field-label {
    font-family: 'Inter', sans-serif;
    font-size: 11px;
    color: var(--color-slate-text);
    margin: 0 0 4px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 500;
  }
  .snippet-row {
    display: flex;
    align-items: center;
    gap: 8px;
    background: var(--color-fog-gray);
    border: 1px solid var(--color-steel-gray);
    border-radius: 6px;
    padding: 8px 10px;
  }
  .snippet-code {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 11px;
    color: var(--color-ink-blue);
    flex: 1;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    background: none;
    border: none;
    padding: 0;
    user-select: all;
  }
  .snippet-copy-btn {
    background: none;
    border: none;
    padding: 4px;
    cursor: pointer;
    color: var(--color-slate-text);
    border-radius: 4px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: color 0.15s, background 0.15s;
  }
  .snippet-copy-btn:hover { color: var(--color-ink-blue); background: var(--color-steel-gray); }
  .snippet-copy-btn.copied { color: var(--color-success-moss); }

  /* Revoke button — plain text style, hover reveals danger color */
  .revoke-btn {
    background: none;
    border: none;
    padding: 0;
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    font-weight: 400;
    color: var(--color-slate-text);
    cursor: pointer;
    text-decoration: none;
    transition: color 150ms ease, text-decoration-color 150ms ease;
  }
  .revoke-btn:hover {
    color: var(--color-danger);
    text-decoration: underline;
  }

  /* Token section uses flex when not hidden */
  #token-section:not(.hidden) {
    display: flex !important;
  }
</style>

<script>
  // Read the CSRF token from cookie so we can send it in the header
  function getCsrfToken(): string {
    return (
      document.cookie
        .split(';')
        .map((c) => c.trim())
        .find((c) => c.startsWith('csrf_token='))
        ?.split('=')[1] ?? ''
    );
  }

  function maskToken(token: string): string {
    if (token.length <= 35) return token;
    return `${token.slice(0, 20)}${'·'.repeat(10)}${token.slice(-10)}`;
  }

  function setInputError(input: HTMLInputElement, hasError: boolean): void {
    if (hasError) {
      input.style.borderColor = 'var(--color-danger)';
      input.style.boxShadow = '0 0 0 3px rgba(220, 38, 38, 0.12)';
    } else {
      input.style.borderColor = '';
      input.style.boxShadow = '';
    }
  }

  const form         = document.getElementById('login-form')    as HTMLFormElement;
  const submitBtn    = document.getElementById('submit-btn')    as HTMLButtonElement;
  const btnLabel     = document.getElementById('btn-label')     as HTMLSpanElement;
  const btnSpinner   = document.getElementById('btn-spinner')   as HTMLElement;
  const formError    = document.getElementById('form-error')    as HTMLDivElement;
  const loginSection = document.getElementById('login-section') as HTMLDivElement;
  const tokenSection = document.getElementById('token-section') as HTMLDivElement;
  const tokenMasked  = document.getElementById('token-masked')  as HTMLSpanElement;
  const copyBtn      = document.getElementById('copy-btn')      as HTMLButtonElement;
  const copyLabel    = document.getElementById('copy-label')    as HTMLSpanElement;
  const copySuccess  = document.getElementById('copy-success')  as HTMLSpanElement;
  const emailInput   = document.getElementById('email')         as HTMLInputElement;
  const passwordInput = document.getElementById('password')     as HTMLInputElement;

  let storedToken = '';

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    const email    = emailInput.value.trim();
    const password = passwordInput.value;

    // Client-side validation
    let hasError = false;
    if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      setInputError(emailInput, true);
      hasError = true;
    } else {
      setInputError(emailInput, false);
    }
    if (!password) {
      setInputError(passwordInput, true);
      hasError = true;
    } else {
      setInputError(passwordInput, false);
    }

    if (hasError) {
      formError.textContent = 'Por favor ingresa un correo y contraseña válidos.';
      formError.classList.remove('hidden');
      return;
    }

    // Loading state
    submitBtn.disabled = true;
    btnLabel.textContent = 'Iniciando sesión…';
    btnSpinner.classList.remove('hidden');
    formError.classList.add('hidden');

    try {
      const res = await fetch('/api/login', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'X-CSRF-Token': getCsrfToken(),
        },
        body: JSON.stringify({ email, password }),
      });

      const data = (await res.json()) as { token?: string; error?: string };

      if (res.ok && data.token) {
        storedToken = data.token;
        tokenMasked.textContent = maskToken(storedToken);

        // Populate command snippets with real token
        const mcpUrl = 'https://api-mcp.komercia.co/sse';
        function setSnippet(id: string, val: string) {
          const el = document.getElementById(id);
          if (el) el.textContent = val;
        }
        setSnippet('cmd-claude-code', `claude mcp add --transport sse komercia ${mcpUrl} --header "Authorization: Bearer ${storedToken}"`);
        setSnippet('cmd-claudeai-url', mcpUrl);
        setSnippet('cmd-claudeai-auth', `Bearer ${storedToken}`);
        setSnippet('cmd-desktop', JSON.stringify({
          mcpServers: {
            komercia: {
              command: 'mcp-remote',
              args: [mcpUrl, '--header', `Authorization: Bearer ${storedToken}`],
            },
          },
        }, null, 2));

        // Swap login form for token display
        loginSection.classList.add('hidden');
        tokenSection.classList.remove('hidden');
      } else {
        const msg = data.error ?? 'Ocurrió un error inesperado. Inténtalo de nuevo.';
        formError.textContent = msg;
        formError.classList.remove('hidden');
        setInputError(passwordInput, true);
      }
    } catch {
      formError.textContent = 'No se pudo conectar al servidor. Revisa tu conexión e inténtalo de nuevo.';
      formError.classList.remove('hidden');
    } finally {
      submitBtn.disabled = false;
      btnLabel.textContent = 'Obtener mi token';
      btnSpinner.classList.add('hidden');
    }
  });

  // Clear error styling on input change
  emailInput.addEventListener('input', () => setInputError(emailInput, false));
  passwordInput.addEventListener('input', () => setInputError(passwordInput, false));

  // Copy button
  copyBtn.addEventListener('click', async () => {
    if (!storedToken) return;

    try {
      await navigator.clipboard.writeText(storedToken);
    } catch {
      // Fallback for older browsers
      const textarea = document.createElement('textarea');
      textarea.value = storedToken;
      textarea.style.position = 'fixed';
      textarea.style.opacity = '0';
      document.body.appendChild(textarea);
      textarea.select();
      document.execCommand('copy');
      document.body.removeChild(textarea);
    }

    copyLabel.classList.add('hidden');
    copySuccess.classList.remove('hidden');
    copySuccess.classList.add('inline-flex');

    setTimeout(() => {
      copyLabel.classList.remove('hidden');
      copySuccess.classList.add('hidden');
      copySuccess.classList.remove('inline-flex');
    }, 3000);
  });

  // Generic copy handler for all snippet copy buttons
  document.querySelectorAll<HTMLButtonElement>('.snippet-copy-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const targetId = btn.getAttribute('data-target');
      if (!targetId) return;
      const el = document.getElementById(targetId);
      if (!el) return;
      const text = el.textContent ?? '';
      try {
        await navigator.clipboard.writeText(text);
      } catch {
        const ta = document.createElement('textarea');
        ta.value = text;
        ta.style.position = 'fixed';
        ta.style.opacity = '0';
        document.body.appendChild(ta);
        ta.select();
        document.execCommand('copy');
        document.body.removeChild(ta);
      }
      btn.classList.add('copied');
      const orig = btn.innerHTML;
      btn.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>';
      setTimeout(() => { btn.innerHTML = orig; btn.classList.remove('copied'); }, 2000);
    });
  });

  // Revoke button — uses CSS class for hover, no inline event handlers
  const revokeBtn    = document.getElementById('revoke-btn')    as HTMLButtonElement | null;
  const revokeStatus = document.getElementById('revoke-status') as HTMLParagraphElement | null;

  if (revokeBtn && revokeStatus) {
    revokeBtn.addEventListener('click', async () => {
      if (!storedToken) return;
      if (!window.confirm('¿Revocar este token? Cualquiera que lo esté usando perderá acceso de inmediato.')) return;

      revokeBtn.disabled = true;
      revokeStatus.textContent = 'Revocando…';
      revokeStatus.style.color = 'var(--color-slate-text)';
      revokeStatus.classList.remove('hidden');

      try {
        const res = await fetch('/api/sessions/revoke', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'X-CSRF-Token': getCsrfToken(),
          },
          body: JSON.stringify({ token: storedToken }),
        });

        const data = (await res.json()) as { revoked?: boolean; error?: string };

        if (res.ok && data.revoked) {
          revokeStatus.textContent = 'Token revocado. Redirigiendo al inicio…';
          revokeStatus.style.color = 'var(--color-charcoal-text)';
          setTimeout(() => { window.location.href = '/'; }, 1500);
        } else {
          revokeStatus.textContent = data.error ?? 'No se pudo revocar. Inténtalo de nuevo.';
          revokeStatus.style.color = 'var(--color-danger)';
          revokeBtn.disabled = false;
        }
      } catch {
        revokeStatus.textContent = 'Error de red. Por favor inténtalo de nuevo.';
        revokeStatus.style.color = 'var(--color-danger)';
        revokeBtn.disabled = false;
      }
    });
  }
</script>
