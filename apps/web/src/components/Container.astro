---
// Container.astro — Width-constrained content wrapper.

interface Props {
  size?: 'narrow' | 'default' | 'wide';
  class?: string;
  as?: 'div' | 'main' | 'section' | 'article';
}

const { size = 'default', class: className = '', as = 'div' } = Astro.props;

const sizeClass = size === 'narrow' ? 'container-narrow' : 'container';
const Tag = as;
---

<Tag class={`${sizeClass} ${className}`}>
  <slot />
</Tag>
