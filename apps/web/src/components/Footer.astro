---
// Footer.astro — Site footer aligned with the Column design system.
// Light fog-gray background, steel-gray border-top, plum brand mark, charcoal links.
import Badge from './Badge.astro';

const productLinks = [
  { label: 'Cómo funciona', href: '/#como-funciona' },
  { label: 'Cómo usarlo', href: '/uso' },
  { label: 'Recetas', href: '/recetas' },
  { label: 'Tools', href: '/#tools' },
  { label: 'FAQ', href: '/#faq' },
];

const docsLinks = [
  { label: 'Guía rápida', href: '/sign-in' },
  { label: 'Catálogo de tools', href: '/#tools' },
  { label: 'Seguridad', href: '/#seguridad' },
];

const resourceLinks = [
  { label: 'GitHub', href: 'https://github.com/gusplayer/komercia-mcp', external: true },
  { label: 'Reportar bug', href: 'https://github.com/gusplayer/komercia-mcp/issues', external: true },
  { label: 'Komercia', href: 'https://komercia.co', external: true },
  { label: 'Claude.ai', href: 'https://claude.ai', external: true },
];

const legalLinks = [
  { label: 'Licencia MIT', href: 'https://github.com/gusplayer/komercia-mcp/blob/main/LICENSE', external: true },
];
---

<footer style="background: var(--color-fog-gray); border-top: 1px solid var(--color-steel-gray);">
  <div style="max-width: 1200px; margin: 0 auto; padding: 64px 24px 48px;">
    <!-- Top grid: brand col (span 2 on lg) + 4 link columns -->
    <div class="footer-grid">

      <!-- Col 1 (span 2 on lg): Brand -->
      <div class="footer-brand">
        <a
          href="/"
          style="display: inline-flex; align-items: center; gap: 8px; text-decoration: none; margin-bottom: 16px;"
          aria-label="Komercia MCP — home"
        >
          <span
            aria-hidden="true"
            style="display: inline-block; width: 8px; height: 8px; border-radius: 2px; background: var(--color-deep-plum);"
          ></span>
          <span style="font-family: 'Inter', sans-serif; font-size: 16px; color: var(--color-ink-blue); font-weight: 600;">Komercia</span><span style="font-family: 'Inter', sans-serif; font-size: 16px; color: var(--color-slate-text); font-weight: 400;"> MCP</span>
        </a>
        <p style="font-family: 'Inter', sans-serif; font-size: 14px; font-weight: 400; color: var(--color-slate-text); margin: 0 0 12px; line-height: 1.6;">
          El MCP oficial de Komercia para Claude.ai.
        </p>
        <p style="font-family: 'Inter', sans-serif; font-size: 12px; font-weight: 400; color: var(--color-slate-text); margin: 0;">
          Open source · MIT License
        </p>
      </div>

      <!-- Col 2: Producto -->
      <div>
        <p class="footer-group-heading">Producto</p>
        <ul style="list-style: none; margin: 0; padding: 0;">
          {productLinks.map((link) => (
            <li>
              <a href={link.href} class="footer-link">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Col 3: Documentación -->
      <div>
        <p class="footer-group-heading">Documentación</p>
        <ul style="list-style: none; margin: 0; padding: 0;">
          {docsLinks.map((link) => (
            <li>
              <a href={link.href} class="footer-link">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Col 4: Recursos -->
      <div>
        <p class="footer-group-heading">Recursos</p>
        <ul style="list-style: none; margin: 0; padding: 0;">
          {resourceLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="footer-link"
                {...(link.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Col 5: Legal -->
      <div>
        <p class="footer-group-heading">Legal</p>
        <ul style="list-style: none; margin: 0; padding: 0;">
          {legalLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="footer-link"
                {...(link.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

    </div>

    <!-- Bottom row -->
    <div
      style="border-top: 1px solid var(--color-steel-gray); padding-top: 32px; margin-top: 32px; display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between; gap: 16px;"
    >
      <p style="font-family: 'Inter', sans-serif; font-size: 12px; font-weight: 400; color: var(--color-slate-text); margin: 0;">
        © 2026 Komercia MCP · Hecho en Colombia · MIT License
      </p>
      <div style="display: flex; align-items: center; gap: 8px;">
        <Badge variant="default">Powered by Claude</Badge>
        <Badge variant="default">Built with Astro</Badge>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 40px 32px;
  }

  .footer-brand {
    grid-column: span 2;
  }

  @media (min-width: 1024px) {
    .footer-grid {
      grid-template-columns: 2fr 1fr 1fr 1fr 1fr;
      gap: 32px;
    }
    .footer-brand {
      grid-column: span 1;
    }
  }

  .footer-group-heading {
    font-family: 'Inter', sans-serif;
    font-size: 11px;
    font-weight: 500;
    color: var(--color-deep-plum);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin: 0 0 16px;
  }

  .footer-link {
    display: block;
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    font-weight: 400;
    color: var(--color-charcoal-text);
    text-decoration: none;
    padding: 4px 0;
    transition: color 0.15s ease;
  }

  .footer-link:hover {
    color: var(--color-ink-blue);
  }
</style>
