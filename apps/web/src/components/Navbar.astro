---
// Navbar.astro — Sticky top navigation with CSS Grid layout, dark mode, and language toggle.

export interface Props {
  activePage?: string;
}

const { activePage } = Astro.props;

const navLinks = [
  { label: 'Instalación',   labelEn: 'Install',     href: '/#install',  key: 'install' },
  { label: 'Cómo usarlo',   labelEn: 'How to use',  href: '/uso',       key: 'uso' },
  { label: 'Herramientas',  labelEn: 'Tools',       href: '/#features', key: 'tools' },
];
---

<nav class="navbar" id="main-nav">
  <div class="navbar-inner">

    <!-- Left: Logo -->
    <div class="navbar-left">
      <a href="/" class="navbar-logo" aria-label="Komercia MCP — home">
        <span class="logo-mark" aria-hidden="true"></span>
        <span class="logo-name">Komercia</span><span class="logo-suffix"> MCP</span>
      </a>
    </div>

    <!-- Center: Nav links (hidden on mobile) -->
    <nav class="navbar-center hidden md:flex" aria-label="Main navigation">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class={activePage === link.key ? 'nav-link nav-link-active' : 'nav-link'}
          data-t-es={link.label}
          data-t-en={link.labelEn}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <!-- Right: icon controls + CTA -->
    <div class="navbar-right">

      <!-- GitHub link -->
      <a
        href="https://github.com/gusplayer/komercia-mcp"
        target="_blank"
        rel="noopener noreferrer"
        class="navbar-icon-btn hidden md:inline-flex"
        aria-label="GitHub repository"
      >
        <!-- GitHub mark SVG -->
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 2C6.477 2 2 6.477 2 12c0 4.418 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.009-.868-.013-1.703-2.782.604-3.369-1.341-3.369-1.341-.454-1.154-1.11-1.462-1.11-1.462-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0 1 12 6.836a9.59 9.59 0 0 1 2.504.337c1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.202 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.579.688.481C19.138 20.163 22 16.418 22 12c0-5.523-4.477-10-10-10z"/>
        </svg>
      </a>

      <!-- Language toggle -->
      <button
        id="lang-toggle"
        class="navbar-lang-btn hidden md:inline-flex"
        aria-label="Toggle language"
      >
        <span id="lang-label">EN</span>
      </button>

      <!-- Dark mode toggle -->
      <button
        id="theme-toggle"
        class="navbar-icon-btn hidden md:inline-flex"
        aria-label="Toggle dark mode"
      >
        <!-- Moon icon (shown in light mode) -->
        <svg id="icon-moon" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
        <!-- Sun icon (shown in dark mode) -->
        <svg id="icon-sun" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="hidden">
          <circle cx="12" cy="12" r="5"/>
          <line x1="12" y1="1" x2="12" y2="3"/>
          <line x1="12" y1="21" x2="12" y2="23"/>
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
          <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
          <line x1="1" y1="12" x2="3" y2="12"/>
          <line x1="21" y1="12" x2="23" y2="12"/>
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
          <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
        </svg>
      </button>

      <!-- CTA: Obtener token -->
      <a
        href="/sign-in"
        class="navbar-cta hidden md:inline-flex"
        data-t-es="Obtener token"
        data-t-en="Get token"
      >Obtener token</a>

      <!-- Mobile hamburger -->
      <button
        id="mobile-menu-btn"
        class="md:hidden btn-ghost"
        aria-label="Open menu"
        aria-expanded="false"
        style="width: 36px; height: 36px; padding: 0; display: inline-flex; align-items: center; justify-content: center;"
      >
        <svg id="hamburger-icon" width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
          <line x1="2" y1="5" x2="16" y2="5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          <line x1="2" y1="9" x2="16" y2="9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          <line x1="2" y1="13" x2="16" y2="13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
        <svg id="close-icon" width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true" class="hidden">
          <line x1="3" y1="3" x2="15" y2="15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          <line x1="15" y1="3" x2="3" y2="15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </button>

    </div>
  </div>
</nav>

<!-- Mobile dropdown menu -->
<div
  id="mobile-menu"
  class="hidden md:hidden"
  style="position: fixed; top: 64px; left: 0; right: 0; z-index: 49; background: var(--color-ghost-white); border-bottom: 1px solid var(--color-steel-gray); padding: 16px 24px 24px;"
>
  <nav aria-label="Mobile navigation">
    {navLinks.map((link) => (
      <a
        href={link.href}
        class="mobile-nav-link"
        data-t-es={link.label}
        data-t-en={link.labelEn}
      >
        {link.label}
      </a>
    ))}
    <div style="display: flex; flex-direction: column; gap: 8px; padding-top: 16px;">
      <a
        href="/sign-in"
        class="navbar-cta"
        style="justify-content: center;"
        data-t-es="Obtener token"
        data-t-en="Get token"
      >Obtener token</a>
    </div>
    <!-- Mobile utility row: lang + dark mode -->
    <div style="display: flex; align-items: center; gap: 8px; padding-top: 12px;">
      <button id="lang-toggle-mobile" class="navbar-lang-btn" aria-label="Toggle language">
        <span id="lang-label-mobile">EN</span>
      </button>
      <button id="theme-toggle-mobile" class="navbar-icon-btn" aria-label="Toggle dark mode">
        <svg id="icon-moon-mobile" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
        <svg id="icon-sun-mobile" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="hidden">
          <circle cx="12" cy="12" r="5"/>
          <line x1="12" y1="1" x2="12" y2="3"/>
          <line x1="12" y1="21" x2="12" y2="23"/>
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
          <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
          <line x1="1" y1="12" x2="3" y2="12"/>
          <line x1="21" y1="12" x2="23" y2="12"/>
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
          <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
        </svg>
      </button>
    </div>
  </nav>
</div>

<style>
  /* ── Layout: CSS Grid 3-column ─────────────────────────────────── */
  .navbar-inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    height: 64px;
    max-width: var(--page-max);
    margin-inline: auto;
    padding-inline: 24px;
  }
  .navbar-left   { display: flex; align-items: center; }
  .navbar-center { display: flex; align-items: center; gap: 32px; justify-content: center; }
  .navbar-right  { display: flex; align-items: center; gap: 8px; justify-content: flex-end; }

  /* ── Logo ──────────────────────────────────────────────────────── */
  .navbar-logo   { display: flex; align-items: center; gap: 8px; text-decoration: none; }
  .logo-mark     { display: inline-block; width: 8px; height: 8px; border-radius: 2px; background: var(--color-deep-plum); }
  .logo-name     { font-family: 'Inter', sans-serif; font-size: 16px; color: var(--color-ink-blue); font-weight: 600; }
  .logo-suffix   { font-family: 'Inter', sans-serif; font-size: 16px; color: var(--color-slate-text); font-weight: 400; }

  /* ── Desktop nav links ─────────────────────────────────────────── */
  .nav-link {
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    font-weight: 400;
    color: var(--color-charcoal-text);
    text-decoration: none;
    transition: color 0.15s ease;
  }
  .nav-link:hover  { color: var(--color-ink-blue); }
  .nav-link-active { font-weight: 500; color: var(--color-ink-blue); }

  /* ── Mobile nav links ──────────────────────────────────────────── */
  .mobile-nav-link {
    display: block;
    font-family: 'Inter', sans-serif;
    font-size: 15px;
    font-weight: 400;
    color: var(--color-charcoal-text);
    text-decoration: none;
    padding: 12px 0;
    border-bottom: 1px solid var(--color-steel-gray);
    transition: color 0.15s ease;
  }
  .mobile-nav-link:hover { color: var(--color-ink-blue); }

  /* ── Icon button (GitHub, dark mode) ──────────────────────────── */
  .navbar-icon-btn {
    background: transparent;
    border: 1px solid var(--color-steel-gray);
    border-radius: 6px;
    color: var(--color-slate-text);
    width: 32px;
    height: 32px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: color 0.15s, border-color 0.15s, background 0.15s;
    text-decoration: none;
    flex-shrink: 0;
  }
  .navbar-icon-btn:hover {
    color: var(--color-ink-blue);
    border-color: var(--color-ink-blue);
    background: var(--color-fog-gray);
  }

  /* ── Language toggle button ────────────────────────────────────── */
  .navbar-lang-btn {
    background: transparent;
    border: 1px solid var(--color-steel-gray);
    border-radius: 6px;
    color: var(--color-slate-text);
    height: 32px;
    padding: 0 10px;
    font-family: 'Inter', sans-serif;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.04em;
    display: inline-flex;
    align-items: center;
    cursor: pointer;
    transition: color 0.15s, border-color 0.15s, background 0.15s;
    flex-shrink: 0;
  }
  .navbar-lang-btn:hover {
    color: var(--color-ink-blue);
    border-color: var(--color-ink-blue);
    background: var(--color-fog-gray);
  }

  /* ── CTA button ────────────────────────────────────────────────── */
  .navbar-cta {
    background: var(--color-action-orange);
    color: #ffffff;
    border: 1px solid var(--color-action-orange);
    border-radius: 8px;
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    font-weight: 500;
    padding: 8px 14px;
    display: inline-flex;
    align-items: center;
    cursor: pointer;
    transition: background 0.15s;
    text-decoration: none;
    white-space: nowrap;
  }
  .navbar-cta:hover { background: #d65620; border-color: #d65620; }
</style>

<script is:inline>
  (function () {
    /* ── Element refs ────────────────────────────────────────────── */
    var nav            = document.getElementById('main-nav');
    var mobileMenuBtn  = document.getElementById('mobile-menu-btn');
    var mobileMenu     = document.getElementById('mobile-menu');
    var hamburgerIcon  = document.getElementById('hamburger-icon');
    var closeIcon      = document.getElementById('close-icon');

    var themeBtn       = document.getElementById('theme-toggle');
    var themeBtnMobile = document.getElementById('theme-toggle-mobile');
    var iconMoon       = document.getElementById('icon-moon');
    var iconSun        = document.getElementById('icon-sun');
    var iconMoonMobile = document.getElementById('icon-moon-mobile');
    var iconSunMobile  = document.getElementById('icon-sun-mobile');

    var langBtn        = document.getElementById('lang-toggle');
    var langBtnMobile  = document.getElementById('lang-toggle-mobile');
    var langLabel      = document.getElementById('lang-label');
    var langLabelMobile = document.getElementById('lang-label-mobile');

    /* ── Scroll handler ──────────────────────────────────────────── */
    if (nav) {
      function onScroll() {
        if (window.scrollY > 8) {
          nav.classList.add('scrolled');
        } else {
          nav.classList.remove('scrolled');
        }
      }
      window.addEventListener('scroll', onScroll, { passive: true });
      onScroll();
    }

    /* ── Mobile menu toggle ──────────────────────────────────────── */
    if (mobileMenuBtn && mobileMenu && hamburgerIcon && closeIcon) {
      var isOpen = false;

      function setOpen(open) {
        isOpen = open;
        if (open) {
          mobileMenu.classList.remove('hidden');
          hamburgerIcon.classList.add('hidden');
          closeIcon.classList.remove('hidden');
          mobileMenuBtn.setAttribute('aria-expanded', 'true');
        } else {
          mobileMenu.classList.add('hidden');
          hamburgerIcon.classList.remove('hidden');
          closeIcon.classList.add('hidden');
          mobileMenuBtn.setAttribute('aria-expanded', 'false');
        }
      }

      mobileMenuBtn.addEventListener('click', function () { setOpen(!isOpen); });

      // Close when a mobile link is clicked
      var mobileLinks = mobileMenu.querySelectorAll('a');
      mobileLinks.forEach(function (link) {
        link.addEventListener('click', function () { setOpen(false); });
      });
    }

    /* ── Dark mode ───────────────────────────────────────────────── */
    function applyTheme(isDark) {
      if (isDark) {
        document.documentElement.classList.add('dark');
      } else {
        document.documentElement.classList.remove('dark');
      }
      // Swap moon/sun icons
      if (iconMoon && iconSun) {
        if (isDark) {
          iconMoon.classList.add('hidden');
          iconSun.classList.remove('hidden');
        } else {
          iconMoon.classList.remove('hidden');
          iconSun.classList.add('hidden');
        }
      }
      if (iconMoonMobile && iconSunMobile) {
        if (isDark) {
          iconMoonMobile.classList.add('hidden');
          iconSunMobile.classList.remove('hidden');
        } else {
          iconMoonMobile.classList.remove('hidden');
          iconSunMobile.classList.add('hidden');
        }
      }
    }

    function toggleTheme() {
      var isDark = document.documentElement.classList.contains('dark');
      var next = !isDark;
      localStorage.setItem('theme', next ? 'dark' : 'light');
      applyTheme(next);
    }

    // Initialize theme on load
    (function () {
      var saved = localStorage.getItem('theme');
      var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      applyTheme(saved === 'dark' || (!saved && prefersDark));
    })();

    if (themeBtn)       themeBtn.addEventListener('click', toggleTheme);
    if (themeBtnMobile) themeBtnMobile.addEventListener('click', toggleTheme);

    /* ── Language toggle ─────────────────────────────────────────── */
    function applyTranslations(lang) {
      // Update all translatable elements
      var els = document.querySelectorAll('[data-t-es]');
      els.forEach(function (el) {
        el.textContent = lang === 'en' ? el.getAttribute('data-t-en') : el.getAttribute('data-t-es');
      });
      // Update html lang attribute
      document.documentElement.lang = lang === 'en' ? 'en' : 'es';
      // Update lang toggle labels — shows what you'll switch TO
      var nextLabel = lang === 'es' ? 'EN' : 'ES';
      if (langLabel)       langLabel.textContent = nextLabel;
      if (langLabelMobile) langLabelMobile.textContent = nextLabel;
    }

    function toggleLang() {
      var current = localStorage.getItem('lang') || 'es';
      var next = current === 'es' ? 'en' : 'es';
      localStorage.setItem('lang', next);
      applyTranslations(next);
    }

    // Initialize language on load
    (function () {
      var saved = localStorage.getItem('lang') || 'es';
      applyTranslations(saved);
    })();

    if (langBtn)       langBtn.addEventListener('click', toggleLang);
    if (langBtnMobile) langBtnMobile.addEventListener('click', toggleLang);
  })();
</script>
