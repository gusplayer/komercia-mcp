# =============================================================================
# KOMERCIA-MCP — Environment Variable Template
#
# Copy this file to .env and fill in the real values.
# Run: cp .env.example .env
#
# NEVER commit .env files to version control.
# =============================================================================

# --- Auth ---------------------------------------------------------------

# JWT signing secret (HS256). Minimum 256 bits (64 hex chars).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# JWT expiration for issued merchant tokens (6 months default).
JWT_EXPIRY_SECONDS=15552000

# --- Database (Postgres via Neon) ----------------------------------------

# Format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=

# --- Email (Resend) -------------------------------------------------------

RESEND_API_KEY=re_
RESEND_FROM_NAME=Komercia Export Tool
RESEND_FROM_EMAIL=noreply@komercia-exit.com

# --- Komercia Backends ----------------------------------------------------
# These are the 3 API backends the MCP server proxies. Filled in after discovery.

KOMERCIA_BACKEND_1_URL=
KOMERCIA_BACKEND_2_URL=
KOMERCIA_BACKEND_3_URL=

# Optional: static API key if backends require server-to-server auth
KOMERCIA_INTERNAL_API_KEY=

# --- MCP Server (apps/mcp-server) ----------------------------------------

MCP_PORT=3001

# Transport: "stdio" for local Claude Desktop, "http" for remote Claude.ai
MCP_TRANSPORT=stdio

NODE_ENV=development

# CORS allowed origins (comma-separated) when transport=http
MCP_ALLOWED_ORIGINS=https://claude.ai

# Rate limit: max requests per merchant per window
RATE_LIMIT_MAX=10
RATE_LIMIT_WINDOW_MS=60000

# Optional Redis for rate-limit + token revocation storage (falls back to in-memory)
REDIS_URL=

# --- Web (apps/web) -------------------------------------------------------

WEB_PORT=4321
WEB_BASE_URL=http://localhost:4321

# Magic link expiry (15 minutes)
MAGIC_LINK_EXPIRY_SECONDS=900

# Rate limit: max magic link requests per IP per hour
MAGIC_LINK_RATE_LIMIT_PER_IP=5
MAGIC_LINK_RATE_LIMIT_PER_EMAIL=3

# --- Feature Flags --------------------------------------------------------

# Enable JWT revocation list (stores jti in DB/Redis)
ENABLE_TOKEN_REVOCATION=false

# Enable analytics (PostHog / Plausible)
ANALYTICS_ENABLED=false
ANALYTICS_KEY=
