# =============================================================================
# KOMERCIA-MCP — Environment Variable Template
#
# Copy this file to .env and fill in the real values.
# Run: cp .env.example .env
#
# NEVER commit .env files to version control.
# =============================================================================

# --- Auth ---------------------------------------------------------------

# JWT signing secret (HS256). Minimum 256 bits (64 hex chars).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# JWT expiration for issued merchant tokens (6 months default).
JWT_EXPIRY_SECONDS=15552000

# --- Database (Postgres via Neon) ----------------------------------------

# Format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=

# --- Komercia Backends ----------------------------------------------------
# MCP server routes requests to the right backend per resource type.

# NodeJS backend — panel, products, orders, customers export (CSV), categories
KOMERCIA_NODE_URL=https://api.komercia.app
# NodeJS public API key (hardcoded in storefront, safe to commit)
KOMERCIA_NODE_PUBLIC_KEY=c6979297-txfg-4962-7sag-709c76a71755

# Laravel v2 backend — OAuth2 auth, product/order/customer export (Excel), categories
KOMERCIA_LARAVEL_URL=https://api2.komercia.co
# Laravel OAuth2 client credentials (server-to-server, for password grant)
# CLIENT_SECRET is optional — some installations do not require it.
KOMERCIA_LARAVEL_CLIENT_ID=2
KOMERCIA_LARAVEL_CLIENT_SECRET=

# Editor backend — theme settings, templates
KOMERCIA_EDITOR_URL=https://editor.komercia.app

# --- Komercia Session Storage (server-side credential store) --------------
# Merchant Komercia tokens are stored server-side, keyed by JWT jti.
# The web app authenticates the merchant and stores the resulting tokens here.
# The MCP server reads them on every tool call — credentials never leave the server.

# Encryption key for stored Komercia tokens (AES-256-GCM, 32 bytes = 64 hex chars).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
KOMERCIA_SESSION_ENCRYPTION_KEY=

# --- MCP Server (apps/mcp-server) ----------------------------------------

MCP_PORT=3001

# Transport: "stdio" for local Claude Desktop, "http" for remote Claude.ai
MCP_TRANSPORT=http

NODE_ENV=development

# CORS allowed origins (comma-separated) when transport=http
MCP_ALLOWED_ORIGINS=https://claude.ai,https://mcp.komercia.co

# Rate limit: max requests per merchant per window
RATE_LIMIT_MAX=10
RATE_LIMIT_WINDOW_MS=60000

# Optional Redis for rate-limit + token revocation storage (falls back to in-memory)
REDIS_URL=

# --- Web (apps/web) -------------------------------------------------------

WEB_PORT=4321

# Production: https://mcp.komercia.co  |  Local dev: http://localhost:4321
WEB_BASE_URL=http://localhost:4321

# MCP server canonical URL (used by web for OAuth completion redirects).
# Production: https://api-mcp.komercia.co  |  Local dev: http://localhost:3001
MCP_SERVER_URL=https://api-mcp.komercia.co

# Rate limit: max login attempts per IP per minute
LOGIN_RATE_LIMIT_PER_IP=10

# --- OAuth 2.1 (PKCE + DCR) ----------------------------------------------
# Lets Claude.ai web users connect without pasting a bearer token.
# Read by the NestJS MCP server.

# Issuer canonical URI; used for `iss`/`aud` claims and resource validation
OAUTH_ISSUER_URL=https://api-mcp.komercia.co

# TTLs (seconds)
OAUTH_AUTH_REQUEST_TTL_SECONDS=600
OAUTH_AUTH_CODE_TTL_SECONDS=90
OAUTH_COMPLETION_TICKET_TTL_SECONDS=120
OAUTH_ACCESS_TOKEN_TTL_SECONDS=15552000

# Dynamic Client Registration rate limit (per IP, per minute)
OAUTH_DCR_RATE_LIMIT_PER_IP=10

# --- Feature Flags --------------------------------------------------------

# Enable JWT revocation list (stores jti in DB/Redis)
ENABLE_TOKEN_REVOCATION=false

# Enable analytics (PostHog / Plausible)
ANALYTICS_ENABLED=false
ANALYTICS_KEY=
