{
  "name": "@komercia-mcp/komercia-client",
  "version": "0.1.0",
  "description": "Unified HTTP client for Komercia's backend APIs with retry and timeout support",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --build --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@komercia-mcp/shared": "workspace:*",
    "p-retry": "^6.2.0",
    "undici": "^7.0.0"
  },
  "devDependencies": {
    "@komercia-mcp/eslint-config": "workspace:*",
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^2.1.0",
    "eslint": "^9.14.0",
    "msw": "^2.14.6",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  }
}
