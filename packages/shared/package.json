{
  "name": "@komercia-mcp/shared",
  "version": "0.1.0",
  "description": "Shared types, JWT utilities, and Zod schemas for komercia-mcp",
  "license": "MIT",
  "author": "Gustavo Moreno (https://github.com/gusplayer)",
  "homepage": "https://github.com/gusplayer/komercia-mcp/tree/main/packages/shared#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gusplayer/komercia-mcp.git",
    "directory": "packages/shared"
  },
  "bugs": "https://github.com/gusplayer/komercia-mcp/issues",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --build --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "jose": "^6.2.3",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@komercia-mcp/eslint-config": "workspace:*",
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^2.1.0",
    "eslint": "^9.14.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  }
}
