{
  "name": "@komercia-mcp/shared",
  "version": "0.1.0",
  "description": "Shared types, JWT utilities, and Zod schemas for komercia-mcp",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --build --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "jose": "^5.9.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@komercia-mcp/eslint-config": "workspace:*",
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.3.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
